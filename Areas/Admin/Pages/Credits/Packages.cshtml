@page
@model PackagesModel
@{
    ViewData["Title"] = "بسته‌های اعتباری";
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">@TempData["Success"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h5 class="mb-1">بسته‌های اعتباری</h5>
        <small class="text-muted">مدیریت بسته‌های قابل خرید توسط کاربران</small>
    </div>
    <button class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#pkgModal" onclick="openCreate()">
        <i class="fas fa-plus me-1"></i> بسته جدید
    </button>
</div>

<div class="card shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th>نام</th>
                    <th class="text-center">اعتبار</th>
                    <th class="text-center">قیمت (ریال)</th>
                    <th class="text-center">هر اعتبار</th>
                    <th class="text-center">بهترین انتخاب</th>
                    <th class="text-center">ترتیب</th>
                    <th class="text-center">وضعیت</th>
                    <th class="text-center">عملیات</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var p in Model.Packages)
                {
                    <tr>
                        <td class="fw-semibold">@p.Name</td>
                        <td class="text-center">@p.CreditAmount</td>
                        <td class="text-center">@p.PriceRial.N0Fa()</td>
                        <td class="text-center text-muted small">@((p.PriceRial / p.CreditAmount).N0Fa()) ریال</td>
                        <td class="text-center">
                            @if (p.IsBestValue) { <i class="fas fa-star text-warning"></i> }
                        </td>
                        <td class="text-center">@p.SortOrder</td>
                        <td class="text-center">
                            @if (p.IsActive) { <span class="badge bg-success">فعال</span> }
                            else { <span class="badge bg-secondary">غیرفعال</span> }
                        </td>
                        <td class="text-center">
                            <button class="btn btn-sm btn-outline-primary me-1"
                                    onclick="openEdit(@p.Id,'@p.Name',@p.CreditAmount,@p.PriceRial,@p.IsActive.ToString().ToLower(),@p.IsBestValue.ToString().ToLower(),@p.SortOrder)">
                                <i class="fas fa-edit"></i>
                            </button>
                            <form method="post" asp-page-handler="Toggle" class="d-inline">
                                <input type="hidden" name="id" value="@p.Id" />
                                <button type="submit" class="btn btn-sm @(p.IsActive ? "btn-outline-warning" : "btn-outline-success")">
                                    <i class="fas @(p.IsActive ? "fa-pause" : "fa-play")"></i>
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<div class="modal fade" id="pkgModal" tabindex="-1">
    <div class="modal-dialog">
        <form method="post" asp-page-handler="Save">
            <div class="modal-content">
                <div class="modal-header">
                    <h6 class="modal-title" id="pkgModalTitle">بسته جدید</h6>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" asp-for="Form.Id" id="fId" />
                    <div class="mb-3">
                        <label class="form-label">نام بسته <span class="text-danger">*</span></label>
                        <input asp-for="Form.Name" class="form-control" id="fName" />
                    </div>
                    <div class="row g-3">
                        <div class="col-6">
                            <label class="form-label">تعداد اعتبار <span class="text-danger">*</span></label>
                            <input asp-for="Form.CreditAmount" type="number" class="form-control" id="fCredit" dir="ltr" />
                        </div>
                        <div class="col-6">
                            <label class="form-label">قیمت (ریال) <span class="text-danger">*</span></label>
                            <input asp-for="Form.PriceRial" type="number" class="form-control" id="fPrice" dir="ltr" />
                        </div>
                        <div class="col-6">
                            <label class="form-label">ترتیب نمایش</label>
                            <input asp-for="Form.SortOrder" type="number" class="form-control" id="fSort" dir="ltr" />
                        </div>
                    </div>
                    <div class="mt-3 d-flex gap-4">
                        <div class="form-check">
                            <input asp-for="Form.IsActive" class="form-check-input" type="checkbox" id="fActive" />
                            <label class="form-check-label" asp-for="Form.IsActive">فعال</label>
                        </div>
                        <div class="form-check">
                            <input asp-for="Form.IsBestValue" class="form-check-input" type="checkbox" id="fBest" />
                            <label class="form-check-label" asp-for="Form.IsBestValue">بهترین انتخاب</label>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">انصراف</button>
                    <button type="submit" class="btn btn-primary btn-sm">ذخیره</button>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script src="~/js/pages/admin/Packages.js"></script>
}
