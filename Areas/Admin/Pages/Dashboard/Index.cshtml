@page
@model IndexModel
@{ ViewData["Title"] = "داشبورد"; }

<!-- کارت‌های آماری -->
<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-body">
                <div class="text-muted small mb-1">درآمد امروز</div>
                <div class="fs-4 fw-bold text-success">@Model.RevenueToday.N0Fa() <small class="fs-6 text-muted">ریال</small></div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-body">
                <div class="text-muted small mb-1">درآمد این هفته</div>
                <div class="fs-4 fw-bold text-primary">@Model.RevenueWeek.N0Fa() <small class="fs-6 text-muted">ریال</small></div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-body">
                <div class="text-muted small mb-1">درآمد این ماه</div>
                <div class="fs-4 fw-bold text-info">@Model.RevenueMonth.N0Fa() <small class="fs-6 text-muted">ریال</small></div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-body">
                <div class="text-muted small mb-1">اجراهای امروز</div>
                <div class="fs-4 fw-bold">@Model.ExecutionsToday</div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-body">
                <div class="text-muted small mb-1">کاربران جدید امروز</div>
                <div class="fs-4 fw-bold text-warning">@Model.NewUsersToday</div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-body">
                <div class="text-muted small mb-1">کاربران جدید این هفته</div>
                <div class="fs-4 fw-bold text-warning">@Model.NewUsersWeek</div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-body d-flex align-items-center justify-content-between">
                <div>
                    <div class="text-muted small mb-1">در انتظار بررسی</div>
                    <div class="fs-4 fw-bold text-danger">@Model.PendingReviewCount</div>
                </div>
                @if (Model.PendingReviewCount > 0)
                {
                    <a asp-area="Admin" asp-page="/Apps/Review" class="btn btn-sm btn-outline-danger">بررسی</a>
                }
            </div>
        </div>
    </div>
</div>

<!-- نمودارها -->
<div class="row g-3">
    <div class="col-md-6">
        <div class="card shadow-sm border-0">
            <div class="card-body">
                <h6 class="fw-semibold mb-3">رشد کاربران (۳۰ روز اخیر)</h6>
                <canvas id="userChart" height="120"></canvas>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card shadow-sm border-0">
            <div class="card-body">
                <h6 class="fw-semibold mb-3">درآمد (۳۰ روز اخیر — ریال)</h6>
                <canvas id="revenueChart" height="120"></canvas>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    var adminDashboardData = {
        userGrowthLabels: @Html.Raw(Model.UserGrowthLabels),
        userGrowthData: @Html.Raw(Model.UserGrowthData),
        revenueLabels: @Html.Raw(Model.RevenueLabels),
        revenueData: @Html.Raw(Model.RevenueData)
    };
</script>
<script src="~/js/pages/admin/Dashboard.js"></script>
}
