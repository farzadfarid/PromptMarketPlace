@page
@model IndexModel
@using PromptMarketPlace.Models.Enums
@{
    ViewData["Title"] = "درخواست‌های برداشت";
    var statusLabels = new Dictionary<WithdrawalStatus, (string label, string color)> {
        { WithdrawalStatus.Pending,  ("در انتظار", "warning") },
        { WithdrawalStatus.Approved, ("تایید شده", "info")    },
        { WithdrawalStatus.Paid,     ("پرداخت شده","success") },
        { WithdrawalStatus.Rejected, ("رد شده",    "danger")  },
    };
}

@if (TempData["Success"] != null) { <div class="alert alert-success alert-dismissible fade show">@TempData["Success"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div> }
@if (TempData["Warning"] != null) { <div class="alert alert-warning alert-dismissible fade show">@TempData["Warning"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div> }

<h5 class="mb-4">درخواست‌های در انتظار (@Model.Pending.Count)</h5>

@if (!Model.Pending.Any())
{
    <div class="card shadow-sm text-center py-4 mb-4">
        <p class="text-muted mb-0">هیچ درخواست در انتظاری وجود ندارد.</p>
    </div>
}
else
{
    <div class="card shadow-sm mb-4">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>سازنده</th>
                        <th class="text-center">مبلغ (تومان)</th>
                        <th>شبا</th>
                        <th>نام صاحب حساب</th>
                        <th>تاریخ درخواست</th>
                        <th class="text-center">عملیات</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var row in Model.Pending)
                    {
                        var w = row.Request;
                        <tr>
                            <td>
                                <div class="fw-semibold small">@w.Creator?.User?.DisplayName</div>
                                <small class="text-muted">@w.Creator?.User?.Email</small>
                            </td>
                            <td class="text-center fw-semibold">@w.Amount.N0Fa()</td>
                            <td><code class="small">@row.Sheba</code></td>
                            <td class="small">@row.AccountOwner</td>
                            <td class="small text-muted">@w.CreatedAt.ToShamsi("yy/MM/dd HH:mm")</td>
                            <td class="text-center">
                                <button type="button" class="btn btn-sm btn-success"
                                        data-bs-toggle="modal" data-bs-target="#approveModal_@w.Id">
                                    <i class="fas fa-check me-1"></i>تایید
                                </button>
                                <button type="button" class="btn btn-sm btn-outline-danger"
                                        data-bs-toggle="modal" data-bs-target="#rejectModal_@w.Id">
                                    رد
                                </button>
                            </td>
                        </tr>

                        <!-- Modal تایید -->
                        <div class="modal fade" id="approveModal_@w.Id" tabindex="-1">
                            <div class="modal-dialog">
                                <div class="modal-content">
                                    <div class="modal-header">
                                        <h6 class="modal-title">تایید پرداخت</h6>
                                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                    </div>
                                    <form method="post" asp-page-handler="Approve">
                                        <input type="hidden" name="id" value="@w.Id" />
                                        <div class="modal-body">
                                            <p class="small">مبلغ: <strong>@w.Amount.N0Fa() تومان</strong> — شبا: <code>@row.Sheba</code></p>
                                            <label class="form-label fw-semibold small">شناسه تراکنش بانکی</label>
                                            <input name="PaymentRef" class="form-control form-control-sm" placeholder="اختیاری" />
                                        </div>
                                        <div class="modal-footer">
                                            <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">انصراف</button>
                                            <button type="submit" class="btn btn-success btn-sm">تایید پرداخت</button>
                                        </div>
                                    </form>
                                </div>
                            </div>
                        </div>

                        <!-- Modal رد -->
                        <div class="modal fade" id="rejectModal_@w.Id" tabindex="-1">
                            <div class="modal-dialog">
                                <div class="modal-content">
                                    <div class="modal-header">
                                        <h6 class="modal-title">رد درخواست</h6>
                                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                    </div>
                                    <form method="post" asp-page-handler="Reject">
                                        <input type="hidden" name="id" value="@w.Id" />
                                        <div class="modal-body">
                                            <label class="form-label fw-semibold small">دلیل رد</label>
                                            <textarea name="AdminNote" class="form-control form-control-sm" rows="2"></textarea>
                                        </div>
                                        <div class="modal-footer">
                                            <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">انصراف</button>
                                            <button type="submit" class="btn btn-danger btn-sm">رد درخواست</button>
                                        </div>
                                    </form>
                                </div>
                            </div>
                        </div>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

<div class="d-flex align-items-center justify-content-between mb-3 flex-wrap gap-2">
    <h6 class="mb-0 text-muted">بررسی‌شده‌ها</h6>
    <div class="d-flex gap-1 flex-wrap">
        @foreach (var s in new (WithdrawalStatus? status, string label)[] {
            (null,                        "همه"),
            (WithdrawalStatus.Paid,     "پرداخت شده"),
            (WithdrawalStatus.Rejected, "رد شده"),
            (WithdrawalStatus.Approved, "تایید شده"),
        })
        {
            <a asp-page="/Withdrawals/Index" asp-area="Admin"
               asp-route-FilterStatus="@s.status" asp-route-ProcessedPage="1"
               class="btn btn-sm @(Model.FilterStatus == s.status ? "btn-primary" : "btn-outline-secondary") py-0">@s.label</a>
        }
    </div>
    <small class="text-muted">@Model.ProcessedTotalCount.N0Fa() مورد</small>
</div>

<div class="card shadow-sm">
    <div class="table-responsive">
        <table class="table table-sm mb-0">
            <thead class="table-light">
                <tr>
                    <th>سازنده</th>
                    <th class="text-center">مبلغ (تومان)</th>
                    <th>شبا</th>
                    <th class="text-center">وضعیت</th>
                    <th>یادداشت ادمین</th>
                    <th>تاریخ بررسی</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Processed.Any())
                {
                    <tr><td colspan="6" class="text-center text-muted py-3">موردی یافت نشد.</td></tr>
                }
                @foreach (var row in Model.Processed)
                {
                    var w = row.Request;
                    var (sl, sc) = statusLabels[w.Status];
                    <tr>
                        <td class="small">
                            <div class="fw-semibold">@w.Creator?.User?.DisplayName</div>
                            <small class="text-muted">@w.Creator?.User?.Email</small>
                        </td>
                        <td class="text-center small fw-semibold">@w.Amount.N0Fa()</td>
                        <td><code class="small">@row.Sheba</code></td>
                        <td class="text-center"><span class="badge bg-@sc">@sl</span></td>
                        <td class="small text-muted">@(w.AdminNote ?? "-")</td>
                        <td class="small text-muted">@(w.ProcessedAt?.ToShamsi("yy/MM/dd") ?? "-")</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@{
    var totalProcessedPages = (int)Math.Ceiling(Model.ProcessedTotalCount / 20.0);
}
@if (totalProcessedPages > 1)
{
    <nav class="mt-3">
        <ul class="pagination pagination-sm justify-content-center">
            @for (int i = 1; i <= totalProcessedPages; i++)
            {
                <li class="page-item @(i == Model.ProcessedPage ? "active" : "")">
                    <a class="page-link" asp-page="/Withdrawals/Index" asp-area="Admin"
                       asp-route-ProcessedPage="@i" asp-route-FilterStatus="@Model.FilterStatus">@i.ToFarsiDigits()</a>
                </li>
            }
        </ul>
    </nav>
}
