@page "/Admin/Apps/{id:int}"
@model DetailModel
@using PromptMarketPlace.Models.Enums
@{
    ViewData["Title"] = Model.App.Title;
    var a = Model.App;
    var statusLabels = new Dictionary<AppStatus, (string label, string color)> {
        { AppStatus.Draft,       ("پیش‌نویس",  "secondary") },
        { AppStatus.UnderReview, ("در بررسی",  "warning")   },
        { AppStatus.Active,      ("فعال",       "success")   },
        { AppStatus.Suspended,   ("تعلیق شده", "danger")    },
    };
    var (sl, sc) = statusLabels[a.Status];
}

@if (TempData["Success"] != null) { <div class="alert alert-success alert-dismissible fade show">@TempData["Success"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div> }

<!-- Breadcrumb -->
<div class="d-flex align-items-center mb-3">
    <nav aria-label="breadcrumb" class="mb-0">
        <ol class="breadcrumb mb-0">
            <li class="breadcrumb-item"><a asp-area="Admin" asp-page="/Apps/Index">ابزارها</a></li>
            <li class="breadcrumb-item active" style="color:#fff">@a.Title</li>
        </ol>
    </nav>
    <a asp-area="Admin" asp-page="/Apps/Index" class="btn btn-sm btn-outline-secondary ms-auto">
        <i class="fas fa-arrow-right me-1"></i>بازگشت به لیست
    </a>
</div>

<!-- Header -->
<div class="card shadow-sm mb-4">
    <div class="card-body">
        <div class="d-flex gap-3 align-items-start">
            @if (!string.IsNullOrEmpty(a.ThumbnailUrl))
            {
                <img src="@a.ThumbnailUrl" class="rounded" style="width:80px;height:80px;object-fit:cover;flex-shrink:0" />
            }
            else
            {
                <div class="rounded bg-secondary d-flex align-items-center justify-content-center text-white"
                     style="width:80px;height:80px;flex-shrink:0;font-size:2rem">
                    <i class="fas fa-robot"></i>
                </div>
            }
            <div class="flex-grow-1">
                <div class="d-flex align-items-center gap-2 flex-wrap">
                    <h5 class="fw-bold mb-0 text-white">@a.Title</h5>
                    <span class="badge bg-@sc">@sl</span>
                    @{
                        var outIcon = a.OutputType switch {
                            OutputType.Text  => ("fa-align-left",  "secondary"),
                            OutputType.Image => ("fa-image",       "info"),
                            OutputType.Video => ("fa-video",       "danger"),
                            OutputType.Audio => ("fa-music",       "warning"),
                            _                => ("fa-file",        "secondary")
                        };
                    }
                    <span class="badge bg-@outIcon.Item2"><i class="fas @outIcon.Item1 me-1"></i>@a.OutputType</span>
                </div>
                <div class="text-muted small mt-1">@a.ShortDescription</div>
                <div class="mt-2 d-flex gap-2 flex-wrap">
                    <a href="/app/@a.Slug" target="_blank" class="btn btn-sm btn-outline-secondary">
                        <i class="fas fa-external-link-alt me-1"></i>مشاهده عمومی
                    </a>
                    @if (a.Status == AppStatus.Active)
                    {
                        <form method="post" asp-page-handler="ToggleStatus" asp-route-id="@a.Id" class="d-inline">
                            <input type="hidden" name="targetStatus" value="Suspended" />
                            <button type="submit" class="btn btn-sm btn-outline-danger"
                                    data-confirm="ابزار تعلیق شود؟"
                                    data-confirm-type="warning">
                                <i class="fas fa-ban me-1"></i>تعلیق
                            </button>
                        </form>
                    }
                    @if (a.Status == AppStatus.Draft || a.Status == AppStatus.Suspended || a.Status == AppStatus.UnderReview)
                    {
                        <form method="post" asp-page-handler="ToggleStatus" asp-route-id="@a.Id" class="d-inline">
                            <input type="hidden" name="targetStatus" value="Active" />
                            <button type="submit" class="btn btn-sm btn-outline-success"
                                    data-confirm="ابزار فعال شود؟">
                                <i class="fas fa-check me-1"></i>فعال‌سازی
                            </button>
                        </form>
                    }
                    @if (a.Status == AppStatus.UnderReview)
                    {
                        <a asp-area="Admin" asp-page="/Apps/Review" class="btn btn-sm btn-warning">
                            <i class="fas fa-eye me-1"></i>بررسی در صف
                        </a>
                    }
                    <button type="button" class="btn btn-sm btn-outline-primary"
                            data-bs-toggle="modal" data-bs-target="#msgModal">
                        <i class="fas fa-comment-dots me-1"></i>ارسال پیام
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row g-4">
    <!-- ستون چپ: اطلاعات -->
    <div class="col-lg-4">
        <!-- اطلاعات کلی -->
        <div class="card shadow-sm mb-3">
            <div class="card-body">
                <h6 class="fw-semibold mb-3">اطلاعات ابزار</h6>
                <dl class="row mb-0 small">
                    <dt class="col-5 text-muted">سازنده</dt>
                    <dd class="col-7">
                        <a asp-area="Admin" asp-page="/Users/Detail" asp-route-id="@a.Creator.UserId"
                           class="text-decoration-none">@a.Creator.User?.DisplayName</a>
                    </dd>
                    <dt class="col-5 text-muted">دسته‌بندی</dt>
                    <dd class="col-7">
                        @(a.Category?.Name ?? "—")
                        <button class="btn btn-link btn-sm p-0 mt-1 text-warning d-block"
                                data-bs-toggle="collapse" data-bs-target="#changeCategoryBox">
                            <i class="fas fa-edit me-1"></i>تغییر
                        </button>
                        <div class="collapse mt-2" id="changeCategoryBox">
                            <form method="post" asp-page-handler="ChangeCategory">
                                <input type="hidden" name="id" value="@a.Id" />
                                <select name="newCategoryId" class="form-select form-select-sm mb-1"
                                        asp-items="Model.CategorySelectList">
                                </select>
                                <button type="submit" class="btn btn-warning btn-sm w-100">
                                    <i class="fas fa-save me-1"></i>اعمال
                                </button>
                            </form>
                        </div>
                    </dd>
                    <dt class="col-5 text-muted">مدل AI</dt>
                    <dd class="col-7">
                        <span class="fw-semibold">@a.AiModel?.Name</span>
                        <small class="text-muted d-block" dir="ltr">@a.AiModel?.ModelId</small>
                        <button class="btn btn-link btn-sm p-0 mt-1 text-warning"
                                data-bs-toggle="collapse" data-bs-target="#changeModelBox">
                            <i class="fas fa-exchange-alt me-1"></i>تغییر مدل
                        </button>
                        <div class="collapse mt-2" id="changeModelBox">
                            <form method="post" asp-page-handler="ChangeModel">
                                <input type="hidden" name="id" value="@a.Id" />
                                <select name="newModelId" class="form-select form-select-sm mb-1"
                                        asp-items="Model.ModelSelectList">
                                </select>
                                <button type="submit" class="btn btn-warning btn-sm w-100">
                                    <i class="fas fa-save me-1"></i>اعمال مدل جدید
                                </button>
                            </form>
                        </div>
                    </dd>
                    <dt class="col-5 text-muted">Slug</dt>
                    <dd class="col-7 text-muted" dir="ltr">@a.Slug</dd>
                    <dt class="col-5 text-muted">ایجاد</dt>
                    <dd class="col-7">@a.CreatedAt.ToShamsi("yyyy/MM/dd")</dd>
                    <dt class="col-5 text-muted">آخرین تغییر</dt>
                    <dd class="col-7">@a.UpdatedAt.ToShamsi("yyyy/MM/dd")</dd>
                    <dt class="col-5 text-muted">تگ‌ها</dt>
                    <dd class="col-7">
                        @foreach (var t in a.Tags)
                        { <span class="badge me-1" style="background:rgba(249,115,22,.15);border:1px solid rgba(249,115,22,.3);color:#fed7aa">@t.TagName</span> }
                        @if (!a.Tags.Any()) { <span class="text-muted">—</span> }
                    </dd>
                </dl>
            </div>
        </div>

        <!-- آمار -->
        <div class="card shadow-sm mb-3">
            <div class="card-body">
                <h6 class="fw-semibold mb-3">آمار</h6>
                <div class="row g-2 text-center">
                    <div class="col-4">
                        <div class="fw-bold fs-5 text-primary">@a.ExecutionCount.N0Fa()</div>
                        <div class="text-muted" style="font-size:.7rem">اجرا</div>
                    </div>
                    <div class="col-4">
                        <div class="fw-bold fs-5 text-warning">@a.AverageRating.ToString("F1")</div>
                        <div class="text-muted" style="font-size:.7rem">امتیاز</div>
                    </div>
                    <div class="col-4">
                        <div class="fw-bold fs-5">@Model.ReviewTotalCount.N0Fa()</div>
                        <div class="text-muted" style="font-size:.7rem">نظر</div>
                    </div>
                </div>
            </div>
        </div>

        <!-- هزینه اجرا -->
        <div class="card shadow-sm mb-3">
            <div class="card-body">
                <h6 class="fw-semibold mb-3">هزینه اجرا</h6>
                <form method="post" asp-page-handler="SetCreditCost" asp-route-id="@a.Id"
                      class="d-flex gap-2 align-items-center">
                    <input type="number" name="creditCost" value="@a.CreditCost" min="1"
                           class="form-control form-control-sm" style="width:90px" dir="ltr" />
                    <span class="text-muted small">اعتبار</span>
                    <button type="submit" class="btn btn-sm btn-outline-primary">ذخیره</button>
                </form>
            </div>
        </div>

        <!-- مصرف توکن واقعی -->
        <div class="card shadow-sm mb-3">
            <div class="card-body">
                <h6 class="fw-semibold mb-3 d-flex align-items-center gap-2 flex-wrap">
                    <i class="fas fa-microchip me-1" style="color:#6366f1;"></i>مصرف توکن واقعی
                    @if (Model.IsUnprofitable)
                    {
                        <span class="badge bg-danger" style="font-size:.6rem;">
                            <i class="fas fa-exclamation-triangle me-1"></i>احتمال زیان‌دهی
                        </span>
                    }
                    <button type="button" class="btn btn-link p-0 ms-auto text-muted help-popover-btn"
                            data-help-id="tokenStats" title="راهنما" style="line-height:1">
                        <i class="fas fa-question-circle"></i>
                    </button>
                </h6>
                <dl class="row mb-0 small">
                    <dt class="col-7 text-muted">هزینه اعتبار تنظیم شده</dt>
                    <dd class="col-5 fw-semibold">@a.CreditCost اعتبار</dd>
                    <dt class="col-7 text-muted">ظرفیت هر اعتبار</dt>
                    <dd class="col-5 text-muted">~۱٬۰۰۰ توکن</dd>
                    @if (Model.AvgTokensAll.HasValue)
                    {
                        <dt class="col-7 text-muted">میانگین توکن (کل)</dt>
                        <dd class="col-5 fw-semibold">@Model.AvgTokensAll.Value.N0Fa()</dd>
                    }
                    @if (Model.AvgTokens30d.HasValue)
                    {
                        <dt class="col-7 text-muted">میانگین توکن (۳۰ روز)</dt>
                        <dd class="col-5 fw-semibold @(Model.IsUnprofitable ? "text-danger" : "")">@Model.AvgTokens30d.Value.N0Fa()</dd>
                    }
                </dl>
                @if (!Model.AvgTokensAll.HasValue)
                {
                    <p class="text-muted small mb-0 mt-2">هنوز اجرایی با ثبت توکن وجود ندارد.</p>
                }
                @if (Model.IsUnprofitable)
                {
                    <div class="alert alert-danger py-2 px-3 mt-2 mb-0 small">
                        <i class="fas fa-exclamation-triangle me-1"></i>
                        میانگین مصرف ۳۰ روز اخیر از سقف اعتبار تنظیم شده بیشتر است. افزایش هزینه اجرا یا بهینه‌سازی پرامپت توصیه می‌شود.
                    </div>
                }
            </div>
        </div>

        <!-- ماشین حساب تخمین توکن -->
        <div class="card shadow-sm mb-3">
            <div class="card-header d-flex align-items-center gap-2 py-2">
                <h6 class="mb-0 small fw-semibold flex-grow-1">
                    <i class="fas fa-calculator me-2" style="color:#6366f1;"></i>ماشین حساب تخمین توکن
                </h6>
                <button type="button" class="btn btn-link p-0 text-muted help-popover-btn"
                        data-help-id="calculator" title="راهنما" style="line-height:1;font-size:.9rem">
                    <i class="fas fa-question-circle"></i>
                </button>
                <button class="btn btn-sm btn-outline-secondary py-0 px-2"
                        data-bs-toggle="collapse" data-bs-target="#tokenCalcBox">
                    نمایش / پنهان
                </button>
            </div>
            <div class="collapse" id="tokenCalcBox">
                <div class="card-body pt-2"
                     id="adminTokenCalc"
                     data-prompt="@Model.PromptCharCount"
                     data-sys="@Model.SystemContextCharCount"
                     data-fields="@(System.Text.Json.JsonSerializer.Serialize(a.InputFields.Select(f => f.Type.ToString())))">
                    <table class="table table-sm small mb-2">
                        <tbody>
                            <tr>
                                <td class="text-muted">System Context</td>
                                <td class="text-end fw-semibold" id="atc-sys">0</td>
                                <td class="text-muted ps-1" style="font-size:.7rem">توکن</td>
                            </tr>
                            <tr>
                                <td class="text-muted">پرامپت قالب</td>
                                <td class="text-end fw-semibold" id="atc-prompt">0</td>
                                <td class="text-muted ps-1" style="font-size:.7rem">توکن</td>
                            </tr>
                            <tr>
                                <td class="text-muted">فیلدهای ورودی (@a.InputFields.Count.N0Fa() فیلد)</td>
                                <td class="text-end fw-semibold" id="atc-fields">0</td>
                                <td class="text-muted ps-1" style="font-size:.7rem">توکن</td>
                            </tr>
                            <tr>
                                <td>
                                    <div class="text-muted">خروجی تخمینی</div>
                                    <div class="d-flex align-items-center gap-1 mt-1">
                                        <input type="range" id="atc-slider" min="100" max="4000" step="100" value="500"
                                               class="form-range flex-grow-1" oninput="updateAdminCalc()">
                                        <span id="atc-out-lbl" class="text-primary fw-semibold" style="min-width:36px;font-size:.8rem">500</span>
                                    </div>
                                </td>
                                <td class="text-end fw-semibold" id="atc-out">500</td>
                                <td class="text-muted ps-1" style="font-size:.7rem">توکن</td>
                            </tr>
                        </tbody>
                        <tfoot>
                            <tr class="fw-bold">
                                <td class="border-top pt-2">مجموع تخمینی</td>
                                <td class="text-end border-top pt-2" id="atc-total">—</td>
                                <td class="text-muted ps-1 border-top pt-2" style="font-size:.7rem">توکن</td>
                            </tr>
                        </tfoot>
                    </table>
                    <div class="text-center py-2 rounded" style="background:rgba(99,102,241,.08);border:1px solid rgba(99,102,241,.2);">
                        <div class="text-muted small">هزینه اجرای پیشنهادی</div>
                        <div class="fw-bold fs-5 text-primary" id="atc-credits">—</div>
                        <div class="text-muted" style="font-size:.68rem">اعتبار &nbsp;|&nbsp; ۱٬۰۰۰ توکن = ۱ اعتبار</div>
                    </div>
                </div>
            </div>
        </div>

        <!-- فیلدهای ورودی -->
        @if (a.InputFields.Any())
        {
            <div class="card shadow-sm mb-3">
                <div class="card-body">
                    <h6 class="fw-semibold mb-3">فیلدهای ورودی (@a.InputFields.Count.N0Fa())</h6>
                    @foreach (var f in a.InputFields.OrderBy(f => f.SortOrder))
                    {
                        <div class="d-flex justify-content-between align-items-center border-bottom py-1 small">
                            <span>@f.Label</span>
                            <span class="badge" style="background:rgba(249,115,22,.15);border:1px solid rgba(249,115,22,.3);color:#fed7aa">@f.Type</span>
                        </div>
                    }
                </div>
            </div>
        }

        <!-- پرامپت -->
        <div class="card shadow-sm">
            <div class="card-header d-flex justify-content-between align-items-center py-2">
                <h6 class="mb-0 small fw-semibold">پرامپت سیستمی</h6>
                <button class="btn btn-sm btn-outline-secondary py-0"
                        onclick="document.getElementById('promptBox').classList.toggle('d-none')">
                    نمایش/پنهان
                </button>
            </div>
            <div class="card-body" id="promptBox">
                <pre class="small mb-0" style="white-space:pre-wrap;max-height:300px;overflow-y:auto">@Model.DecryptedPrompt</pre>
                @if (!string.IsNullOrEmpty(a.SystemContext))
                {
                    <hr />
                    <div class="small text-muted fw-semibold mb-1">System Context:</div>
                    <pre class="small mb-0" style="white-space:pre-wrap">@a.SystemContext</pre>
                }
            </div>
        </div>
    </div>

    <!-- ستون راست: اجراها و نظرات -->
    <div class="col-lg-8">
        <!-- اجراها -->
        <div class="card shadow-sm mb-4">
            <div class="card-body">
                <div class="d-flex align-items-center justify-content-between mb-3 flex-wrap gap-2">
                    <h6 class="fw-semibold mb-0">اجراها</h6>
                    <div class="d-flex gap-1 flex-wrap">
                        @foreach (var s in new[] { (ExecutionStatus?)null, ExecutionStatus.Completed, ExecutionStatus.Failed, ExecutionStatus.Refunded })
                        {
                            var lbl = s switch { ExecutionStatus.Completed => "موفق", ExecutionStatus.Failed => "ناموفق", ExecutionStatus.Refunded => "بازگشتی", _ => "همه" };
                            <a asp-area="Admin" asp-page="/Apps/Detail" asp-route-id="@a.Id"
                               asp-route-FilterStatus="@s" asp-route-ExecPage="1"
                               class="btn btn-sm @(Model.FilterStatus == s ? "btn-primary" : "btn-outline-secondary") py-0">@lbl</a>
                        }
                    </div>
                    <small class="text-muted">@Model.ExecutionTotalCount.N0Fa() اجرا</small>
                </div>

                @{
                    var totalExecPages = (int)Math.Ceiling(Model.ExecutionTotalCount / 15.0);
                }
                @if (!Model.RecentExecutions.Any())
                {
                    <p class="text-muted small text-center mb-0">اجرایی ثبت نشده.</p>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-sm table-hover mb-0">
                            <thead class="table-light">
                                <tr><th>کاربر</th><th class="text-center">وضعیت</th><th class="text-center">اعتبار</th><th>تاریخ</th><th></th></tr>
                            </thead>
                            <tbody>
                                @foreach (var e in Model.RecentExecutions)
                                {
                                    var (el, ec) = e.Status switch {
                                        ExecutionStatus.Completed => ("موفق",     "success"),
                                        ExecutionStatus.Failed    => ("ناموفق",   "danger"),
                                        ExecutionStatus.Refunded  => ("بازگشتی", "info"),
                                        _                         => ("در جریان", "warning")
                                    };
                                    <tr style="cursor:pointer"
                                        onclick="window.location='/Admin/Executions/@e.Id?userId=@e.UserId'">
                                        <td class="small">@e.User?.DisplayName</td>
                                        <td class="text-center"><span class="badge bg-@ec">@el</span></td>
                                        <td class="text-center small">@e.CreditUsed.N0Fa()</td>
                                        <td class="small text-muted">@e.CreatedAt.ToShamsi("yy/MM/dd HH:mm")</td>
                                        <td><i class="fas fa-chevron-left text-muted small"></i></td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                    @if (totalExecPages > 1)
                    {
                        <nav class="mt-3">
                            <ul class="pagination pagination-sm justify-content-center mb-0">
                                @for (int i = 1; i <= totalExecPages; i++)
                                {
                                    <li class="page-item @(i == Model.ExecPage ? "active" : "")">
                                        <a class="page-link" asp-area="Admin" asp-page="/Apps/Detail"
                                           asp-route-id="@a.Id" asp-route-ExecPage="@i"
                                           asp-route-FilterStatus="@Model.FilterStatus">@i.ToFarsiDigits()</a>
                                    </li>
                                }
                            </ul>
                        </nav>
                    }
                }
            </div>
        </div>

        <!-- نمونه خروجی‌ها -->
        @if (a.ShowcaseItems.Any())
        {
            <div class="card shadow-sm mb-4">
                <div class="card-body">
                    <div class="d-flex align-items-center justify-content-between mb-3">
                        <h6 class="fw-semibold mb-0">
                            <i class="fas fa-images me-2" style="color:#f97316;"></i>نمونه خروجی‌ها
                        </h6>
                        <span class="badge rounded-pill" style="background:rgba(249,115,22,.15);border:1px solid rgba(249,115,22,.3);color:#fed7aa;font-size:.72rem;">
                            @a.ShowcaseItems.Count.N0Fa() نمونه
                        </span>
                    </div>
                    <div class="row g-3">
                        @{ int showcaseIdx = 0; }
                        @foreach (var item in a.ShowcaseItems)
                        {
                            showcaseIdx++;
                            <div class="col-md-6">
                                <div class="showcase-card h-100 rounded-3 overflow-hidden" style="border:1px solid rgba(255,255,255,.07);">
                                    <div class="px-3 py-2 d-flex align-items-center justify-content-between"
                                         style="background:rgba(249,115,22,.08);border-bottom:1px solid rgba(249,115,22,.12);">
                                        <span style="font-size:.72rem;color:#f97316;font-weight:600;">
                                            نمونه @showcaseIdx.ToFarsiDigits()
                                        </span>
                                        @if (!string.IsNullOrEmpty(item.Caption))
                                        {
                                            <span class="text-muted" style="font-size:.7rem;">@item.Caption</span>
                                        }
                                    </div>
                                    @if (item.OutputType == OutputType.Image && !string.IsNullOrEmpty(item.OutputUrl))
                                    {
                                        <img src="@item.OutputUrl" class="w-100" style="max-height:220px;object-fit:cover;display:block;" />
                                    }
                                    else if (!string.IsNullOrEmpty(item.OutputText))
                                    {
                                        <div style="max-height:220px;overflow-y:auto;">
                                            <pre style="white-space:pre-wrap;font-size:.8rem;line-height:1.85;font-family:inherit;color:inherit;margin:0;padding:18px 22px;">@item.OutputText</pre>
                                        </div>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        }

        <!-- نظرات -->
        <div class="card shadow-sm">
            <div class="card-body">
                <div class="d-flex align-items-center justify-content-between mb-3 flex-wrap gap-2">
                    <h6 class="fw-semibold mb-0">نظرات</h6>
                    <div class="d-flex gap-1 flex-wrap">
                        <a asp-area="Admin" asp-page="/Apps/Detail" asp-route-id="@a.Id"
                           asp-route-ReviewPage="1" asp-route-ExecPage="@Model.ExecPage"
                           asp-route-FilterStatus="@Model.FilterStatus"
                           class="btn btn-sm @(Model.FilterRating == null ? "btn-primary" : "btn-outline-secondary") py-0">همه</a>
                        @for (int star = 5; star >= 1; star--)
                        {
                            var s = star;
                            <a asp-area="Admin" asp-page="/Apps/Detail" asp-route-id="@a.Id"
                               asp-route-FilterRating="@s" asp-route-ReviewPage="1"
                               asp-route-ExecPage="@Model.ExecPage" asp-route-FilterStatus="@Model.FilterStatus"
                               class="btn btn-sm @(Model.FilterRating == s ? "btn-warning" : "btn-outline-secondary") py-0">
                                @s.ToFarsiDigits() <i class="fas fa-star" style="font-size:.7rem"></i>
                            </a>
                        }
                    </div>
                    <small class="text-muted">@Model.ReviewTotalCount.N0Fa() نظر</small>
                    @{ var pendingRevCount = Model.Reviews.Count(r => !r.IsApproved); }
                    @if (pendingRevCount > 0)
                    {
                        <span class="badge bg-warning text-dark ms-1" style="font-size:.6rem">@pendingRevCount در انتظار</span>
                    }
                </div>

                @{
                    var totalReviewPages = (int)Math.Ceiling(Model.ReviewTotalCount / 10.0);
                }
                @if (!Model.Reviews.Any())
                {
                    <p class="text-muted small text-center mb-0">نظری ثبت نشده.</p>
                }
                else
                {
                    @foreach (var r in Model.Reviews)
                    {
                        <div class="border-bottom pb-2 mb-2">
                            <div class="d-flex justify-content-between align-items-start gap-2">
                                <div class="flex-grow-1">
                                    <div class="d-flex align-items-center gap-2 flex-wrap">
                                        <span class="small fw-semibold">@r.User?.DisplayName</span>
                                        <span class="text-warning small">
                                            @for (int s = 1; s <= 5; s++)
                                            { <i class="fas fa-star@(s <= r.Rating ? "" : " text-muted opacity-25")" style="font-size:.7rem"></i> }
                                        </span>
                                        <span class="text-muted" style="font-size:.65rem">(@r.Rating ستاره)</span>
                                        @if (r.IsApproved)
                                        {
                                            <span class="badge bg-success-subtle text-success" style="font-size:.6rem">منتشر</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-warning-subtle text-warning" style="font-size:.6rem">در انتظار</span>
                                        }
                                        <span class="text-muted" style="font-size:.65rem">@r.CreatedAt.ToShamsi("yy/MM/dd")</span>
                                    </div>
                                    @if (!string.IsNullOrEmpty(r.Comment))
                                    { <p class="small text-muted mb-0 mt-1">@r.Comment</p> }
                                    @if (!string.IsNullOrEmpty(r.CreatorReply))
                                    { <p class="small text-primary mb-0 mt-1"><i class="fas fa-reply fa-xs me-1"></i>@r.CreatorReply</p> }
                                </div>
                                <div class="d-flex gap-1 flex-shrink-0">
                                    @if (!r.IsApproved)
                                    {
                                        <form method="post" asp-page-handler="ApproveReview" asp-route-id="@a.Id">
                                            <input type="hidden" name="reviewId" value="@r.Id" />
                                            <button type="submit" class="btn btn-xs btn-outline-success" title="تایید" style="font-size:.7rem;padding:.15rem .4rem;">
                                                <i class="fas fa-check"></i>
                                            </button>
                                        </form>
                                    }
                                    <form method="post" asp-page-handler="DeleteReview" asp-route-id="@a.Id">
                                        <input type="hidden" name="reviewId" value="@r.Id" />
                                        <button type="submit" class="btn btn-xs btn-outline-danger" title="حذف"
                                                style="font-size:.7rem;padding:.15rem .4rem;"
                                                onclick="return confirm('حذف شود؟')">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    }
                    @if (totalReviewPages > 1)
                    {
                        <nav class="mt-3">
                            <ul class="pagination pagination-sm justify-content-center mb-0">
                                @for (int i = 1; i <= totalReviewPages; i++)
                                {
                                    <li class="page-item @(i == Model.ReviewPage ? "active" : "")">
                                        <a class="page-link" asp-area="Admin" asp-page="/Apps/Detail"
                                           asp-route-id="@a.Id" asp-route-ReviewPage="@i"
                                           asp-route-FilterRating="@Model.FilterRating"
                                           asp-route-ExecPage="@Model.ExecPage"
                                           asp-route-FilterStatus="@Model.FilterStatus">@i.ToFarsiDigits()</a>
                                    </li>
                                }
                            </ul>
                        </nav>
                    }
                }
            </div>
        </div>
    </div>
</div>

<!-- Modal ارسال پیام -->
<div class="modal fade" id="msgModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <form method="post" asp-page-handler="SendMessage" asp-route-id="@a.Id">
                <div class="modal-header border-0 pb-0">
                    <h6 class="modal-title fw-bold"><i class="fas fa-comment-dots me-2" style="color:#6366f1;"></i>پیام به سازنده</h6>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="p-2 mb-3 rounded" style="background:rgba(249,115,22,.06);border:1px solid rgba(249,115,22,.2);">
                        <div class="d-flex align-items-center gap-2 text-muted small">
                            <i class="fas fa-robot" style="color:#f97316;"></i>
                            <span>درباره ابزار: <strong class="text-white">@a.Title</strong></span>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label small fw-semibold">موضوع</label>
                        <input type="text" name="subject" class="form-control" required maxlength="200"
                               value="درباره ابزار: @a.Title" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label small fw-semibold">پیام</label>
                        <textarea name="message" class="form-control" rows="4" required placeholder="پیام خود را بنویسید..."></textarea>
                    </div>
                </div>
                <div class="modal-footer border-0 pt-0">
                    <button type="button" class="btn btn-outline-secondary btn-sm" data-bs-dismiss="modal">انصراف</button>
                    <button type="submit" class="btn btn-primary btn-sm px-4">
                        <i class="fas fa-paper-plane ms-1"></i>ارسال پیام
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
<script>
(function () {
    // ─── Calculator ───────────────────────────────────────
    var FIELD_TOKENS = { Textarea: 300, Text: 50, Select: 5, Number: 5, Checkbox: 3 };
    var el = document.getElementById('adminTokenCalc');
    if (el) {
        var promptTokens = Math.round((parseInt(el.dataset.prompt) || 0) / 3.5);
        var sysTokens    = Math.round((parseInt(el.dataset.sys)    || 0) / 3.5);
        var fields       = JSON.parse(el.dataset.fields || '[]');
        var fieldTokens  = fields.reduce(function (s, t) { return s + (FIELD_TOKENS[t] || 30); }, 0);

        document.getElementById('atc-sys').textContent    = sysTokens.toLocaleString('fa-IR');
        document.getElementById('atc-prompt').textContent = promptTokens.toLocaleString('fa-IR');
        document.getElementById('atc-fields').textContent = fieldTokens.toLocaleString('fa-IR');

        window.updateAdminCalc = function () {
            var outVal = parseInt(document.getElementById('atc-slider').value) || 500;
            document.getElementById('atc-out-lbl').textContent = outVal.toLocaleString('fa-IR');
            document.getElementById('atc-out').textContent     = outVal.toLocaleString('fa-IR');
            var total   = sysTokens + promptTokens + fieldTokens + outVal;
            var credits = Math.ceil(total / 1000);
            document.getElementById('atc-total').textContent   = total.toLocaleString('fa-IR');
            document.getElementById('atc-credits').textContent = credits.toLocaleString('fa-IR') + ' اعتبار';
        };
        updateAdminCalc();
    }

    // ─── Help Popovers ───────────────────────────────────
    var helpData = {
        tokenStats: {
            title: '<i class="fas fa-microchip me-1 text-primary"></i> مصرف توکن واقعی',
            content: [
                '<div style="font-size:.82rem;line-height:1.75;direction:rtl;text-align:right">',
                '<p class="mb-2">این بخش آمار واقعی مصرف توکن در اجراهای موفق ابزار را نمایش می‌دهد. هر اجرای هوش مصنوعی یک بار توکن مصرف می‌کند؛ هرچه توکن بیشتری مصرف شود، هزینه واقعی بیشتر است.</p>',
                '<hr class="my-2">',
                '<dl class="mb-0">',
                '<dt class="mb-1">📊 میانگین توکن (کل)</dt>',
                '<dd class="text-muted mb-2">میانگین تعداد توکن در <strong>تمام اجراهای موفق</strong> از ابتدای ایجاد ابزار. هم توکن‌های ورودی (پرامپت + فیلدها) و هم توکن خروجی (پاسخ AI) را شامل می‌شود.</dd>',
                '<dt class="mb-1">📅 میانگین توکن (۳۰ روز)</dt>',
                '<dd class="text-muted mb-2">میانگین <strong>۳۰ روز اخیر</strong>؛ نشان می‌دهد آیا مصرف ابزار در حال افزایش است یا کاهش. این عدد برای تصمیم‌گیری درباره تغییر هزینه اجرا مهم‌تر است.</dd>',
                '<dt class="mb-1">💰 ظرفیت هر اعتبار</dt>',
                '<dd class="text-muted mb-2">استاندارد پلتفرم: <strong>هر ۱ اعتبار = ۱٬۰۰۰ توکن</strong>. بر این اساس اگر ابزار به‌طور میانگین ۲٬۵۰۰ توکن مصرف کند، هزینه واقعی آن ۲.۵ اعتبار است.</dd>',
                '<dt class="mb-1">⚠️ هشدار زیان‌دهی</dt>',
                '<dd class="text-muted mb-0">اگر میانگین ۳۰ روز از مقدار <em>(اعتبار تنظیم‌شده × ۱۰۰۰)</em> بیشتر شود، این هشدار فعال می‌شود. یعنی درآمد دریافتی از کاربر، هزینه واقعی API را پوشش نمی‌دهد.</dd>',
                '</dl>',
                '</div>'
            ].join('')
        },
        calculator: {
            title: '<i class="fas fa-calculator me-1 text-primary"></i> ماشین حساب تخمین توکن',
            content: [
                '<div style="font-size:.82rem;line-height:1.75;direction:rtl;text-align:right">',
                '<p class="mb-2">این ابزار تخمین می‌زند که <strong>هر اجرای این ابزار</strong> چه مقدار توکن مصرف می‌کند. عدد نهایی برای تعیین هزینه اجرای مناسب کمک می‌کند.</p>',
                '<hr class="my-2">',
                '<dl class="mb-0">',
                '<dt class="mb-1">📝 System Context</dt>',
                '<dd class="text-muted mb-2">متن System Context ابزار به توکن تبدیل می‌شود. فرمول: <strong>تعداد کاراکتر ÷ ۳.۵</strong> (فارسی و انگلیسی مختلط).</dd>',
                '<dt class="mb-1">📄 پرامپت قالب</dt>',
                '<dd class="text-muted mb-2">طول پرامپت اصلی ابزار (بخشی که هرگز تغییر نمی‌کند). با همان فرمول کاراکتر ÷ ۳.۵ تخمین زده می‌شود.</dd>',
                '<dt class="mb-1">🔢 فیلدهای ورودی</dt>',
                '<dd class="text-muted mb-2">بر اساس نوع فیلد تخمین زده می‌شود:<br>',
                '<code>Textarea ≈ ۳۰۰</code> &nbsp; <code>Text ≈ ۵۰</code> &nbsp; <code>Select ≈ ۵</code> &nbsp; <code>Number/Checkbox ≈ ۵</code></dd>',
                '<dt class="mb-1">🤖 خروجی تخمینی</dt>',
                '<dd class="text-muted mb-2">توکن‌هایی که AI در پاسخ تولید می‌کند. با slider قابل تنظیم است. برای پاسخ‌های کوتاه ۳۰۰-۵۰۰، برای پاسخ‌های بلند ۱۰۰۰-۲۰۰۰ توصیه می‌شود.</dd>',
                '<dt class="mb-1">💡 هزینه پیشنهادی</dt>',
                '<dd class="text-muted mb-0">فرمول: <strong>⌈مجموع توکن ÷ ۱۰۰۰⌉</strong>. حداقل هزینه‌ای که باید برای ابزار تنظیم کنید تا زیان‌ده نباشد.</dd>',
                '</dl>',
                '</div>'
            ].join('')
        }
    };

    document.querySelectorAll('.help-popover-btn').forEach(function (btn) {
        var id = btn.dataset.helpId;
        var data = helpData[id];
        if (!data) return;
        new bootstrap.Popover(btn, {
            html: true,
            title: data.title,
            content: data.content,
            trigger: 'click',
            placement: 'auto',
            customClass: 'help-popover'
        });
    });

    document.addEventListener('click', function (e) {
        if (!e.target.closest('.help-popover-btn') && !e.target.closest('.popover')) {
            document.querySelectorAll('.help-popover-btn').forEach(function (btn) {
                var pop = bootstrap.Popover.getInstance(btn);
                if (pop) pop.hide();
            });
        }
    });
})();
</script>
}
