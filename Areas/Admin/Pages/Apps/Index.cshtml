@page
@model IndexModel
@using PromptMarketPlace.Models.Enums
@{
    ViewData["Title"] = "همه ابزارها";
    var statusLabels = new Dictionary<AppStatus, (string label, string color)> {
        { AppStatus.Draft,        ("پیش‌نویس",      "secondary") },
        { AppStatus.UnderReview,  ("در بررسی",       "warning")   },
        { AppStatus.Active,       ("فعال",           "success")   },
        { AppStatus.Suspended,    ("تعلیق شده",      "danger")    },
    };
}

@if (TempData["Success"] != null) { <div class="alert alert-success alert-dismissible fade show">@TempData["Success"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div> }

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h5 class="mb-1">ابزارها</h5>
        <small class="text-muted">مجموع: @Model.TotalCount ابزار</small>
    </div>
</div>

<div class="card shadow-sm mb-3">
    <div class="card-body py-2">
        <form method="get" class="d-flex gap-2 flex-wrap align-items-center">
            <input type="text" name="Search" value="@Model.Search"
                   class="form-control form-control-sm" placeholder="عنوان ابزار" style="width:200px" />
            <select name="FilterStatus" class="form-select form-select-sm" style="width:auto">
                <option value="">همه وضعیت‌ها</option>
                @foreach (var s in Enum.GetValues<AppStatus>())
                { <option value="@s" selected="@(Model.FilterStatus == s.ToString())">@statusLabels[s].label</option> }
            </select>
            <select name="FilterCategory" class="form-select form-select-sm" style="width:auto">
                <option value="">همه دسته‌ها</option>
                @foreach (var c in Model.Categories)
                { <option value="@c.Id" selected="@(Model.FilterCategory == c.Id)">@c.Name</option> }
            </select>
            <button type="submit" class="btn btn-outline-secondary btn-sm">جستجو</button>
        </form>
    </div>
</div>

<div class="card shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th>عنوان</th>
                    <th>دسته</th>
                    <th>سازنده</th>
                    <th class="text-center">اجراها</th>
                    <th class="text-center">امتیاز</th>
                    <th class="text-center">وضعیت</th>
                    <th>آخرین تغییر</th>
                    <th class="text-center">عملیات</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var a in Model.Apps)
                {
                    var (sl, sc) = statusLabels[a.Status];
                    <tr style="cursor:pointer" onclick="window.location='/Admin/Apps/@a.Id'">
                        <td class="fw-semibold small">@a.Title</td>
                        <td class="small text-muted">@a.Category?.Name</td>
                        <td class="small">@a.Creator?.User?.DisplayName</td>
                        <td class="text-center small">@a.ExecutionCount</td>
                        <td class="text-center small">@a.AverageRating.ToString("F1")</td>
                        <td class="text-center"><span class="badge bg-@sc">@sl</span></td>
                        <td class="small text-muted">@a.UpdatedAt.ToShamsi("yy/MM/dd")</td>
                        <td class="text-center">
                            <div class="d-flex gap-1 justify-content-center">
                                @if (a.Status == AppStatus.Active)
                                {
                                    <form method="post" asp-page-handler="ToggleStatus">
                                        <input type="hidden" name="id" value="@a.Id" />
                                        <input type="hidden" name="targetStatus" value="Suspended" />
                                        <button type="submit" class="btn btn-sm btn-outline-danger"
                                                data-confirm="ابزار تعلیق شود؟"
                                                data-confirm-type="warning">تعلیق</button>
                                    </form>
                                }
                                @if (a.Status == AppStatus.Draft || a.Status == AppStatus.Suspended || a.Status == AppStatus.UnderReview)
                                {
                                    <form method="post" asp-page-handler="ToggleStatus">
                                        <input type="hidden" name="id" value="@a.Id" />
                                        <input type="hidden" name="targetStatus" value="Active" />
                                        <button type="submit" class="btn btn-sm btn-outline-success"
                                                data-confirm="ابزار فعال شود؟">فعال‌سازی</button>
                                    </form>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@{
    var totalPages = (int)Math.Ceiling(Model.TotalCount / 30.0);
}
@if (totalPages > 1)
{
    <nav class="mt-3">
        <ul class="pagination pagination-sm">
            @for (int i = 1; i <= totalPages; i++)
            {
                <li class="page-item @(i == Model.PageNumber ? "active" : "")">
                    <a class="page-link" asp-page="/Apps/Index" asp-area="Admin"
                       asp-all-route-data='@(new Dictionary<string,string>{{"Search",Model.Search??""}, {"FilterStatus",Model.FilterStatus??""}, {"FilterCategory",Model.FilterCategory?.ToString()??""}, {"PageNumber",i.ToString()}})'>@i</a>
                </li>
            }
        </ul>
    </nav>
}
