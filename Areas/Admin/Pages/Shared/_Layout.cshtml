@inject PromptMarketPlace.Services.Interfaces.IMessageService _msgSvc
@{ var _adminUnread = await _msgSvc.UnreadCountAsync(forAdmin: true); }
<!DOCTYPE html>
<html lang="fa" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - پنل ادمین</title>
    <link href="~/css/vazirmatn.css" rel="stylesheet" />
    <link href="~/css/bootstrap5-3-3.css" rel="stylesheet" />
    <link href="~/css/font-awesome.css" rel="stylesheet" />
    <link href="~/css/site.css" rel="stylesheet" />
    <link href="~/css/pages/admin/admin-layout.css" rel="stylesheet" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body class="admin-layout">
<div class="admin-shell">

    <!-- Sidebar -->
    <aside class="admin-sidebar">
        <div class="admin-sidebar__header">
            <div class="admin-brand">
                <div class="admin-brand__icon">
                    <i class="fas fa-robot"></i>
                </div>
                <div>
                    <div class="admin-brand__name">پرامپت مارکت</div>
                    <div class="admin-brand__label">پنل مدیریت</div>
                </div>
            </div>
        </div>

        <nav class="admin-nav">
            <a class="admin-nav__item @(ViewContext.RouteData.Values["page"]?.ToString()?.Contains("Dashboard") == true ? "active" : "")"
               asp-area="Admin" asp-page="/Dashboard/Index">
                <i class="fas fa-chart-pie"></i><span>داشبورد</span>
            </a>

            <div class="admin-nav__section">کاربران</div>
            <a class="admin-nav__item @(ViewContext.RouteData.Values["page"]?.ToString()?.Contains("Users") == true ? "active" : "")"
               asp-area="Admin" asp-page="/Users/Index">
                <i class="fas fa-users"></i><span>مدیریت کاربران</span>
            </a>

            <div class="admin-nav__section">ابزارها</div>
            <a class="admin-nav__item @(ViewContext.RouteData.Values["page"]?.ToString()?.Contains("Review") == true ? "active" : "")"
               asp-area="Admin" asp-page="/Apps/Review">
                <i class="fas fa-clipboard-check"></i>
                <span>صف بررسی</span>
            </a>
            <a class="admin-nav__item @(ViewContext.RouteData.Values["page"]?.ToString() == "/Apps/Index" ? "active" : "")"
               asp-area="Admin" asp-page="/Apps/Index">
                <i class="fas fa-th-large"></i><span>همه ابزارها</span>
            </a>

            <div class="admin-nav__section">مالی</div>
            <a class="admin-nav__item @(ViewContext.RouteData.Values["page"]?.ToString()?.Contains("Payments") == true ? "active" : "")"
               asp-area="Admin" asp-page="/Payments/Index">
                <i class="fas fa-credit-card"></i><span>پرداخت‌ها</span>
            </a>
            <a class="admin-nav__item @(ViewContext.RouteData.Values["page"]?.ToString()?.Contains("Withdrawals") == true ? "active" : "")"
               asp-area="Admin" asp-page="/Withdrawals/Index">
                <i class="fas fa-money-bill-wave"></i><span>درخواست برداشت</span>
            </a>
            <a class="admin-nav__item @(ViewContext.RouteData.Values["page"]?.ToString()?.Contains("Packages") == true ? "active" : "")"
               asp-area="Admin" asp-page="/Credits/Packages">
                <i class="fas fa-coins"></i><span>بسته‌های اعتباری</span>
            </a>
            <a class="admin-nav__item @(ViewContext.RouteData.Values["page"]?.ToString()?.Contains("Pricing") == true ? "active" : "")"
               asp-area="Admin" asp-page="/Credits/Pricing">
                <i class="fas fa-tags"></i><span>تعرفه اعتبار</span>
            </a>

            <div class="admin-nav__section">هوش مصنوعی</div>
            <a class="admin-nav__item @(ViewContext.RouteData.Values["page"]?.ToString()?.Contains("Providers") == true ? "active" : "")"
               asp-area="Admin" asp-page="/AI/Providers">
                <i class="fas fa-server"></i><span>سرویس‌دهنده‌ها</span>
            </a>
            <a class="admin-nav__item @(ViewContext.RouteData.Values["page"]?.ToString()?.Contains("Models") == true ? "active" : "")"
               asp-area="Admin" asp-page="/AI/Models">
                <i class="fas fa-microchip"></i><span>مدل‌ها</span>
            </a>

            <div class="admin-nav__section">محتوا</div>
            <a class="admin-nav__item @(ViewContext.RouteData.Values["page"]?.ToString()?.Contains("Categories") == true ? "active" : "")"
               asp-area="Admin" asp-page="/Categories/Index">
                <i class="fas fa-tags"></i><span>دسته‌بندی‌ها</span>
            </a>
            <a class="admin-nav__item @(ViewContext.RouteData.Values["page"]?.ToString()?.Contains("Reviews") == true ? "active" : "")"
               asp-area="Admin" asp-page="/Reviews/Index">
                <i class="fas fa-star-half-alt"></i><span>نظرات</span>
            </a>

            <a class="admin-nav__item @(ViewContext.RouteData.Values["page"]?.ToString()?.Contains("Messages") == true ? "active" : "")"
               asp-area="Admin" asp-page="/Messages/Index">
                <i class="fas fa-comments"></i><span>پیام‌ها</span>
                @if (_adminUnread > 0)
                {
                    <span class="creator-nav__badge" style="background:#ef4444;">@_adminUnread</span>
                }
            </a>

            <div class="admin-nav__section">گزارش‌ها</div>
            <a class="admin-nav__item @(ViewContext.RouteData.Values["page"]?.ToString()?.Contains("Revenue") == true ? "active" : "")"
               asp-area="Admin" asp-page="/Reports/Revenue">
                <i class="fas fa-chart-bar"></i><span>درآمد</span>
            </a>
            <a class="admin-nav__item @(ViewContext.RouteData.Values["page"]?.ToString()?.Contains("TopApps") == true ? "active" : "")"
               asp-area="Admin" asp-page="/Reports/TopApps">
                <i class="fas fa-fire"></i><span>پرکاربردترین</span>
            </a>
            <a class="admin-nav__item @(ViewContext.RouteData.Values["page"]?.ToString()?.Contains("TopCreators") == true ? "active" : "")"
               asp-area="Admin" asp-page="/Reports/TopCreators">
                <i class="fas fa-trophy"></i><span>پردرآمدترین</span>
            </a>

            <div class="admin-nav__section">تنظیمات</div>
            <a class="admin-nav__item @(ViewContext.RouteData.Values["page"]?.ToString()?.Contains("Settings") == true ? "active" : "")"
               asp-area="Admin" asp-page="/Settings/Index">
                <i class="fas fa-cog"></i><span>تنظیمات سیستم</span>
            </a>
        </nav>

        <div class="admin-sidebar__footer">
            <a href="/" class="admin-sidebar__back">
                <i class="fas fa-arrow-right"></i>بازگشت به سایت
            </a>
            <form method="post" asp-area="" asp-page="/Auth/Logout" class="mt-2">
                <button type="submit" class="admin-sidebar__logout">
                    <i class="fas fa-arrow-right-from-bracket"></i>خروج از حساب
                </button>
            </form>
        </div>
    </aside>

    <!-- Main -->
    <div class="admin-main">
        <header class="admin-topbar">
            <div class="admin-topbar__title">
                <h6 class="mb-0 fw-semibold">@ViewData["Title"]</h6>
            </div>
            <div class="admin-topbar__actions">
                <a href="/" class="btn btn-sm btn-ghost d-none d-md-inline-flex align-items-center gap-2">
                    <i class="fas fa-external-link-alt fa-xs"></i>مشاهده سایت
                </a>
                <div class="admin-topbar__badge">
                    <i class="fas fa-shield-halved text-primary me-1"></i>
                    <span class="small fw-medium">ادمین</span>
                </div>
            </div>
        </header>

        <main class="admin-content">
            @RenderBody()
        </main>
    </div>
</div>

<script src="~/js/jquery-3.7.1.js"></script>
<script src="~/js/bootstrap5-3-3.js"></script>
<script src="~/js/chart.umd.min.js"></script>
<link rel="stylesheet" href="~/css/confirm-dialog.css" />
<script src="~/js/confirm-dialog.js"></script>
<script>
document.addEventListener('DOMContentLoaded', function () {
    document.querySelectorAll('.validation-summary-valid').forEach(function (ul) {
        var a = ul.closest('.alert'); if (a) a.style.display = 'none';
    });
});
</script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
