@page
@model ProvidersModel
@{
    ViewData["Title"] = "سرویس‌دهنده‌های هوش مصنوعی";
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h5 class="mb-1">سرویس‌دهنده‌های AI</h5>
        <small class="text-muted">مدیریت گیت‌وی‌های هوش مصنوعی و API Key ها</small>
    </div>
    <button class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#providerModal" onclick="openCreate()">
        <i class="fas fa-plus me-1"></i> سرویس‌دهنده جدید
    </button>
</div>

<div class="card shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th>نام</th>
                    <th>آدرس پایه</th>
                    <th>API Key</th>
                    <th>توضیح</th>
                    <th>وضعیت</th>
                    <th class="text-center">عملیات</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var p in Model.Providers)
                {
                    <tr>
                        <td class="fw-semibold">@p.Name</td>
                        <td><code class="small">@p.BaseUrl</code></td>
                        <td>
                            @if (p.ApiKeyEncrypted != null)
                            {
                                <span class="badge bg-success-subtle text-success border border-success-subtle">
                                    <i class="fas fa-key me-1"></i>تنظیم شده
                                </span>
                            }
                            else
                            {
                                <span class="badge bg-warning-subtle text-warning border border-warning-subtle">
                                    <i class="fas fa-exclamation-triangle me-1"></i>تنظیم نشده
                                </span>
                            }
                        </td>
                        <td class="text-muted small">@p.Description</td>
                        <td>
                            @if (p.IsActive)
                            {
                                <span class="badge bg-success">فعال</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">غیرفعال</span>
                            }
                        </td>
                        <td class="text-center">
                            <button class="btn btn-sm btn-outline-primary me-1"
                                    onclick="openEdit(@p.Id, '@p.Name', '@p.BaseUrl', '@(p.Description ?? "")', @(p.ApiKeyEncrypted != null ? "true" : "false"))">
                                <i class="fas fa-edit"></i>
                            </button>
                            <form method="post" asp-page-handler="Toggle" class="d-inline">
                                <input type="hidden" name="id" value="@p.Id" />
                                <button type="submit" class="btn btn-sm @(p.IsActive ? "btn-outline-warning" : "btn-outline-success")"
                                        title="@(p.IsActive ? "غیرفعال کن" : "فعال کن")">
                                    <i class="fas @(p.IsActive ? "fa-pause" : "fa-play")"></i>
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- Modal -->
<div class="modal fade" id="providerModal" tabindex="-1">
    <div class="modal-dialog">
        <form method="post" asp-page-handler="Save">
            <div class="modal-content">
                <div class="modal-header">
                    <h6 class="modal-title" id="modalTitle">سرویس‌دهنده جدید</h6>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" asp-for="Form.Id" id="formId" />

                    <div class="mb-3">
                        <label class="form-label">نام <span class="text-danger">*</span></label>
                        <input asp-for="Form.Name" class="form-control" placeholder="مثال: OpenRouter" />
                        <span asp-validation-for="Form.Name" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">آدرس پایه API <span class="text-danger">*</span></label>
                        <input asp-for="Form.BaseUrl" class="form-control" placeholder="https://openrouter.ai/api/v1" dir="ltr" />
                        <span asp-validation-for="Form.BaseUrl" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">API Key</label>
                        <input asp-for="Form.ApiKey" type="password" class="form-control" dir="ltr"
                               placeholder="برای تغییر وارد کنید، در غیر اینصورت خالی بگذارید" />
                        <div id="apiKeyHint" class="form-text text-muted d-none">
                            <i class="fas fa-info-circle me-1"></i>API Key قبلاً تنظیم شده. برای تغییر، مقدار جدید وارد کنید.
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">توضیح</label>
                        <textarea asp-for="Form.Description" class="form-control" rows="2"></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">انصراف</button>
                    <button type="submit" class="btn btn-primary btn-sm">ذخیره</button>
                </div>
            </div>
        </form>
    </div>
</div>

@section Styles {
    <link rel="stylesheet" href="~/css/pages/admin/Providers.css" />
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/pages/admin/Providers.js"></script>
}
