@page
@model ProvidersModel
@using PromptMarketPlace.Models.Enums
@{
    ViewData["Title"] = "سرویس‌دهنده‌های هوش مصنوعی";
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show">
        @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h5 class="mb-1">سرویس‌دهنده‌های AI</h5>
        <small class="text-muted">برای هر نوع خروجی، یک سرویس‌دهنده را فعال کنید</small>
    </div>
    <button class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#providerModal" onclick="openCreate()">
        <i class="fas fa-plus me-1"></i> سرویس‌دهنده جدید
    </button>
</div>

@* خلاصه وضعیت capability ها *@
<div class="row g-3 mb-4">
    @{
        var capSummary = new[]
        {
            ("متن + کد", "fa-font", Model.Providers.FirstOrDefault(p => p.IsActiveForText)?.Name),
            ("تصویر", "fa-image", Model.Providers.FirstOrDefault(p => p.IsActiveForImage)?.Name),
            ("ویدیو", "fa-video", Model.Providers.FirstOrDefault(p => p.IsActiveForVideo)?.Name),
            ("صدا", "fa-microphone", Model.Providers.FirstOrDefault(p => p.IsActiveForAudio)?.Name),
        };
    }
    @foreach (var (label, icon, name) in capSummary)
    {
        <div class="col-6 col-md-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body py-3 text-center">
                    <i class="fas @icon text-muted mb-2 d-block"></i>
                    <div class="small text-muted mb-1">@label</div>
                    @if (name != null)
                    {
                        <div class="fw-semibold text-success small">@name</div>
                    }
                    else
                    {
                        <div class="fw-semibold text-warning small">تنظیم نشده</div>
                    }
                </div>
            </div>
        </div>
    }
</div>

<div class="card shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th>سرویس‌دهنده</th>
                    <th class="text-center">API Key</th>
                    <th class="text-center" title="متن، کد و فرم">
                        <i class="fas fa-font me-1 text-muted"></i>متن
                    </th>
                    <th class="text-center">
                        <i class="fas fa-image me-1 text-muted"></i>تصویر
                    </th>
                    <th class="text-center">
                        <i class="fas fa-video me-1 text-muted"></i>ویدیو
                    </th>
                    <th class="text-center">
                        <i class="fas fa-microphone me-1 text-muted"></i>صدا
                    </th>
                    <th class="text-center">وضعیت</th>
                    <th class="text-center">عملیات</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var p in Model.Providers)
                {
                    <tr class="@(!p.IsActive ? "opacity-50" : "")">
                        <td>
                            <div class="fw-semibold">@p.Name</div>
                            <code class="small text-muted">@p.BaseUrl</code>
                            @{
                                var (ptLabel, ptColor) = p.ProviderType switch {
                                    ProviderType.AvalAi       => ("AvalAI",    "info"),
                                    ProviderType.Anthropic    => ("Anthropic", "warning"),
                                    ProviderType.ChatQt       => ("ChatQT",    "secondary"),
                                    ProviderType.GoogleGemini => ("Google",     "danger"),
                                    ProviderType.VertexAi     => ("Vertex AI",  "success"),
                                    _                         => ("OpenAI سازگار", "primary")
                                };
                            }
                            <span class="badge bg-@ptColor-subtle text-@ptColor border border-@ptColor-subtle ms-1" style="font-size:0.65rem">@ptLabel</span>
                            @if (!string.IsNullOrEmpty(p.Description))
                            {
                                <div class="text-muted" style="font-size:0.75rem">@p.Description</div>
                            }
                        </td>
                        <td class="text-center">
                            @if (p.ApiKeyEncrypted != null)
                            {
                                <span class="badge bg-success-subtle text-success border border-success-subtle">
                                    <i class="fas fa-key me-1"></i>ست شده
                                </span>
                            }
                            else
                            {
                                <span class="badge bg-warning-subtle text-warning border border-warning-subtle">
                                    <i class="fas fa-exclamation-triangle me-1"></i>ست نشده
                                </span>
                            }
                        </td>

                        @* Capability Toggles *@
                        <td class="text-center">
                            <button class="btn btn-sm capability-toggle @(p.IsActiveForText ? "btn-success" : "btn-outline-secondary")"
                                    data-provider-id="@p.Id"
                                    data-capability="Text"
                                    data-active="@p.IsActiveForText.ToString().ToLower()"
                                    onclick="toggleCapability(this)"
                                    title="@(p.IsActiveForText ? "فعال — کلیک برای غیرفعال" : "کلیک برای فعال کردن")">
                                <i class="fas @(p.IsActiveForText ? "fa-check-circle" : "fa-circle")"></i>
                            </button>
                        </td>
                        <td class="text-center">
                            <button class="btn btn-sm capability-toggle @(p.IsActiveForImage ? "btn-success" : "btn-outline-secondary")"
                                    data-provider-id="@p.Id"
                                    data-capability="Image"
                                    data-active="@p.IsActiveForImage.ToString().ToLower()"
                                    onclick="toggleCapability(this)"
                                    title="@(p.IsActiveForImage ? "فعال — کلیک برای غیرفعال" : "کلیک برای فعال کردن")">
                                <i class="fas @(p.IsActiveForImage ? "fa-check-circle" : "fa-circle")"></i>
                            </button>
                        </td>
                        <td class="text-center">
                            <button class="btn btn-sm capability-toggle @(p.IsActiveForVideo ? "btn-success" : "btn-outline-secondary")"
                                    data-provider-id="@p.Id"
                                    data-capability="Video"
                                    data-active="@p.IsActiveForVideo.ToString().ToLower()"
                                    onclick="toggleCapability(this)"
                                    title="@(p.IsActiveForVideo ? "فعال — کلیک برای غیرفعال" : "کلیک برای فعال کردن")">
                                <i class="fas @(p.IsActiveForVideo ? "fa-check-circle" : "fa-circle")"></i>
                            </button>
                        </td>
                        <td class="text-center">
                            <button class="btn btn-sm capability-toggle @(p.IsActiveForAudio ? "btn-success" : "btn-outline-secondary")"
                                    data-provider-id="@p.Id"
                                    data-capability="Audio"
                                    data-active="@p.IsActiveForAudio.ToString().ToLower()"
                                    onclick="toggleCapability(this)"
                                    title="@(p.IsActiveForAudio ? "فعال — کلیک برای غیرفعال" : "کلیک برای فعال کردن")">
                                <i class="fas @(p.IsActiveForAudio ? "fa-check-circle" : "fa-circle")"></i>
                            </button>
                        </td>

                        <td class="text-center">
                            @if (p.IsActive)
                            {
                                <span class="badge bg-success">فعال</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">غیرفعال</span>
                            }
                        </td>

                        <td class="text-center">
                            <button class="btn btn-sm btn-outline-secondary me-1"
                                    onclick="checkBalance(this, @p.Id)"
                                    title="بررسی موجودی">
                                <i class="fas fa-coins"></i>
                            </button>
                            <button class="btn btn-sm btn-outline-info me-1"
                                    onclick="testConnectionByRow(this, @p.Id, '@p.BaseUrl')"
                                    title="تست اتصال">
                                <i class="fas fa-plug"></i>
                            </button>
                            <button class="btn btn-sm btn-outline-primary me-1"
                                    onclick="openEdit(@p.Id, '@p.Name', '@p.BaseUrl', '@(p.Description ?? "")', @(p.ApiKeyEncrypted != null ? "true" : "false"), @((int)p.ProviderType))"
                                    title="ویرایش">
                                <i class="fas fa-edit"></i>
                            </button>
                            <form method="post" asp-page-handler="Toggle" class="d-inline">
                                <input type="hidden" name="id" value="@p.Id" />
                                <button type="submit" class="btn btn-sm @(p.IsActive ? "btn-outline-warning" : "btn-outline-success")"
                                        title="@(p.IsActive ? "غیرفعال کن" : "فعال کن")">
                                    <i class="fas @(p.IsActive ? "fa-pause" : "fa-play")"></i>
                                </button>
                            </form>
                            <form method="post" asp-page-handler="Delete" class="d-inline"
                                  data-confirm="آیا از حذف «@p.Name» مطمئن هستید؟">
                                <input type="hidden" name="id" value="@p.Id" />
                                <button type="submit" class="btn btn-sm btn-outline-danger" title="حذف">
                                    <i class="fas fa-trash"></i>
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@if (!Model.Providers.Any())
{
    <div class="text-center text-muted py-5">
        <i class="fas fa-server fa-2x mb-3 d-block opacity-25"></i>
        هنوز سرویس‌دهنده‌ای تعریف نشده. روی «سرویس‌دهنده جدید» کلیک کنید.
    </div>
}

<div class="card shadow-sm mt-4 border-0">
    <div class="card-header bg-transparent border-0 pt-3 pb-0">
        <h6 class="mb-0 text-muted"><i class="fas fa-lightbulb me-2"></i>راهنمای سرویس‌دهنده‌های شناخته‌شده</h6>
    </div>
    <div class="card-body">
        <div class="row g-3">
            @foreach (var known in new[] {
                ("ChatQT", "https://api.chatqt.com/api/v1", "متن + تصویر — قیمت دلاری", "fa-bolt"),
                ("AvalAI", "https://api.avalai.ir/v1", "متن + تصویر + ویدیو + صدا — قیمت تومانی", "fa-star"),
                ("OpenAI", "https://api.openai.com/v1", "GPT, DALL-E, Whisper, TTS", "fa-brain"),
                ("Anthropic (Claude)", "https://api.anthropic.com/v1", "Claude Opus, Sonnet, Haiku", "fa-robot"),
                ("Google Gemini", "https://generativelanguage.googleapis.com/v1beta", "Gemini Pro, Flash, Veo", "fa-google"),
            })
            {
                <div class="col-md-4">
                    <div class="d-flex align-items-start gap-2 p-2 rounded border bg-light">
                        <i class="fas @known.Item4 text-primary mt-1"></i>
                        <div>
                            <div class="fw-semibold small">@known.Item1</div>
                            <code class="text-muted" style="font-size:0.7rem">@known.Item2</code>
                            <div class="text-muted" style="font-size:0.72rem">@known.Item3</div>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

<!-- Modal افزودن/ویرایش -->
<div class="modal fade" id="providerModal" tabindex="-1">
    <div class="modal-dialog">
        <form method="post" asp-page-handler="Save">
            <div class="modal-content">
                <div class="modal-header">
                    <h6 class="modal-title" id="modalTitle">سرویس‌دهنده جدید</h6>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" asp-for="Form.Id" id="formId" />

                    <div class="mb-3">
                        <label class="form-label">نوع سرویس‌دهنده <span class="text-danger">*</span></label>
                        <select asp-for="Form.ProviderType" class="form-select" id="formProviderType">
                            <option value="0">OpenAI سازگار (OpenAI, OpenRouter...)</option>
                            <option value="1">AvalAI</option>
                            <option value="2">Anthropic (Claude)</option>
                            <option value="3">ChatQT</option>
                            <option value="4">Google (Gemini + Imagen + Veo)</option>
                            <option value="5">Google Vertex AI (OAuth2 — Veo 3.1)</option>
                        </select>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">نام <span class="text-danger">*</span></label>
                        <input asp-for="Form.Name" class="form-control" placeholder="مثال: ChatQT" />
                        <span asp-validation-for="Form.Name" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">آدرس پایه API <span class="text-danger">*</span></label>
                        <input asp-for="Form.BaseUrl" class="form-control" dir="ltr"
                               placeholder="https://api.chatqt.com/api/v1" />
                        <span asp-validation-for="Form.BaseUrl" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">API Key</label>
                        <div class="input-group">
                            <input asp-for="Form.ApiKey" type="text" class="form-control" dir="ltr" id="formApiKeyInput"
                                   placeholder="برای تغییر وارد کنید، در غیر اینصورت خالی بگذارید" />
                            <button type="button" class="btn btn-outline-secondary d-none" id="showApiKeyBtn"
                                    onclick="showApiKey()" title="نمایش API Key فعلی">
                                <i class="fas fa-eye"></i>
                            </button>
                        </div>
                        <div id="apiKeyHint" class="form-text text-muted d-none">
                            <i class="fas fa-info-circle me-1"></i>API Key قبلاً تنظیم شده. برای تغییر، مقدار جدید وارد کنید.
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">توضیح</label>
                        <textarea asp-for="Form.Description" class="form-control" rows="2"></textarea>
                    </div>

                    <div id="modalTestResult" class="d-none alert py-2 mb-0" role="alert">
                        <i id="modalTestIcon" class="fas me-1"></i>
                        <span id="modalTestMessage"></span>
                    </div>
                </div>
                <div class="modal-footer d-flex">
                    <button type="button" class="btn btn-outline-info btn-sm me-auto" id="modalTestBtn"
                            onclick="testConnectionFromModal()">
                        <i class="fas fa-plug me-1"></i> تست اتصال
                    </button>
                    <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">انصراف</button>
                    <button type="submit" class="btn btn-primary btn-sm">ذخیره</button>
                </div>
            </div>
        </form>
    </div>
</div>

<!-- Balance Modal -->
<div class="modal fade" id="balanceModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered" style="max-width:360px">
        <div class="modal-content border-0 rounded-4 shadow-lg overflow-hidden">
            <div class="modal-header border-0 pb-0">
                <h6 class="modal-title fw-bold"><i class="fas fa-coins text-warning me-2"></i>موجودی / مصرف</h6>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body pt-2 pb-4">
                <div id="balanceLoading" class="text-center py-3">
                    <div class="spinner-border text-primary spinner-border-sm me-2"></div>
                    <span class="text-muted">در حال دریافت اطلاعات...</span>
                </div>
                <div id="balanceResult" class="d-none text-center">
                    <div class="fs-4 fw-bold text-primary" id="balanceValue"></div>
                    <div class="text-muted small mt-1" id="balanceLabel"></div>
                </div>
                <div id="balanceError" class="d-none alert alert-danger py-2 small mb-0"></div>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <link rel="stylesheet" href="~/css/pages/admin/Providers.css" />
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/pages/admin/Providers.js"></script>
}
