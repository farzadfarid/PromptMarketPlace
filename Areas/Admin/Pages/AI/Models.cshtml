@page
@model ModelsModel
@using PromptMarketPlace.Models.Enums
@{
    ViewData["Title"] = "مدل‌های هوش مصنوعی";
    var capLabels = new Dictionary<AiCapability, string> {
        { AiCapability.TextGeneration,  "متن" },
        { AiCapability.CodeGeneration,  "کد" },
        { AiCapability.ImageGeneration, "تصویر" },
        { AiCapability.VideoGeneration, "ویدیو" },
        { AiCapability.AudioGeneration, "صدا" },
    };
    var capColors = new Dictionary<AiCapability, string> {
        { AiCapability.TextGeneration,  "primary" },
        { AiCapability.CodeGeneration,  "info" },
        { AiCapability.ImageGeneration, "success" },
        { AiCapability.VideoGeneration, "danger" },
        { AiCapability.AudioGeneration, "warning" },
    };
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show">
        @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h5 class="mb-1">مدل‌های AI</h5>
        <small class="text-muted">تعریف و مدیریت مدل‌های هوش مصنوعی قابل استفاده در ابزارها</small>
    </div>
    <button class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#modelModal" onclick="openCreate()">
        <i class="fas fa-plus me-1"></i> مدل جدید
    </button>
</div>

<!-- فیلترها -->
<div class="card shadow-sm mb-3">
    <div class="card-body py-2">
        <form method="get" class="d-flex gap-3 align-items-center">
            <select name="FilterProviderId" class="form-select form-select-sm" style="width:auto">
                <option value="">همه سرویس‌دهنده‌ها</option>
                @foreach (var p in Model.Providers)
                {
                    <option value="@p.Id" selected="@(Model.FilterProviderId == p.Id)">@p.Name</option>
                }
            </select>
            <select name="FilterCapability" class="form-select form-select-sm" style="width:auto">
                <option value="">همه قابلیت‌ها</option>
                @foreach (var cap in Model.AllCapabilities)
                {
                    <option value="@cap" selected="@(Model.FilterCapability == cap.ToString())">@capLabels[cap]</option>
                }
            </select>
            <button type="submit" class="btn btn-outline-secondary btn-sm">فیلتر</button>
        </form>
    </div>
</div>

<div class="card shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th>نام</th>
                    <th>شناسه API</th>
                    <th>قابلیت‌ها</th>
                    <th>هزینه</th>
                    <th>پیش‌فرض</th>
                    <th>وضعیت</th>
                    <th class="text-center">عملیات</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var m in Model.Models)
                {
                    var caps = System.Text.Json.JsonSerializer.Deserialize<List<string>>(m.Capabilities) ?? new();
                    <tr>
                        <td>
                            <div class="fw-semibold">@m.Name</div>
                            <small class="text-muted">@m.Provider?.Name</small>
                        </td>
                        <td><code class="small">@m.ModelId</code></td>
                        <td>
                            @foreach (var c in caps)
                            {
                                if (Enum.TryParse<AiCapability>(c, out var capEnum))
                                {
                                    <span class="badge bg-@(capColors[capEnum])-subtle text-@(capColors[capEnum]) border border-@(capColors[capEnum])-subtle me-1">
                                        @capLabels[capEnum]
                                    </span>
                                }
                            }
                        </td>
                        <td class="small">
                            @if (m.CostPer1KTokens.HasValue)
                            { <span>$@m.CostPer1KTokens / 1K توکن</span> }
                            @if (m.CostPerImage.HasValue)
                            { <span>$@m.CostPerImage / تصویر</span> }
                            @if (m.CostPerSecondVideo.HasValue)
                            { <span>$@m.CostPerSecondVideo / ثانیه</span> }
                        </td>
                        <td>
                            @if (m.IsDefault)
                            {
                                <span class="badge bg-warning text-dark"><i class="fas fa-star me-1"></i>پیش‌فرض</span>
                            }
                            else
                            {
                                <form method="post" asp-page-handler="SetDefault" class="d-inline">
                                    <input type="hidden" name="id" value="@m.Id" />
                                    <button type="submit" class="btn btn-link btn-sm text-muted p-0" title="تعیین به عنوان پیش‌فرض">
                                        <i class="far fa-star"></i>
                                    </button>
                                </form>
                            }
                        </td>
                        <td>
                            @if (m.IsActive)
                            { <span class="badge bg-success">فعال</span> }
                            else
                            { <span class="badge bg-secondary">غیرفعال</span> }
                        </td>
                        <td class="text-center">
                            <button class="btn btn-sm btn-outline-primary me-1"
                                    onclick="openEdit(@m.Id, @m.AiProviderId, '@m.Name', '@m.ModelId', '@(m.Description ?? "")', '@m.Capabilities', @(m.CostPer1KTokens.HasValue ? m.CostPer1KTokens.Value.ToString("G") : "null"), @(m.CostPerImage.HasValue ? m.CostPerImage.Value.ToString("G") : "null"), @(m.CostPerSecondVideo.HasValue ? m.CostPerSecondVideo.Value.ToString("G") : "null"), @(m.MaxTokens.HasValue ? m.MaxTokens.Value.ToString() : "null"), @m.IsDefault.ToString().ToLower(), @m.SortOrder)"
                                    title="ویرایش">
                                <i class="fas fa-edit"></i>
                            </button>
                            <form method="post" asp-page-handler="Toggle" class="d-inline">
                                <input type="hidden" name="id" value="@m.Id" />
                                <button type="submit" class="btn btn-sm @(m.IsActive ? "btn-outline-warning" : "btn-outline-success") me-1"
                                        title="@(m.IsActive ? "غیرفعال کن" : "فعال کن")">
                                    <i class="fas @(m.IsActive ? "fa-pause" : "fa-play")"></i>
                                </button>
                            </form>
                            <form method="post" asp-page-handler="ApplyToAll" class="d-inline"
                                  data-confirm="این مدل به همه ابزارها اعمال شود؟"
                                  data-confirm-type="warning">
                                <input type="hidden" name="id" value="@m.Id" />
                                <button type="submit" class="btn btn-sm btn-outline-info me-1" title="اعمال به همه ابزارها">
                                    <i class="fas fa-globe"></i>
                                </button>
                            </form>
                            <form method="post" asp-page-handler="Delete" class="d-inline"
                                  data-confirm="آیا از حذف مدل «@m.Name» مطمئن هستید؟">
                                <input type="hidden" name="id" value="@m.Id" />
                                <button type="submit" class="btn btn-sm btn-outline-danger" title="حذف">
                                    <i class="fas fa-trash"></i>
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- Modal -->
<div class="modal fade" id="modelModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <form method="post" asp-page-handler="Save">
            <div class="modal-content">
                <div class="modal-header">
                    <h6 class="modal-title" id="modalTitle">مدل جدید</h6>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" asp-for="Form.Id" id="formId" />

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">سرویس‌دهنده <span class="text-danger">*</span></label>
                            <select asp-for="Form.AiProviderId" asp-items="Model.ProviderSelectList" class="form-select" id="formProviderId">
                                <option value="">انتخاب کنید</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">نام نمایشی <span class="text-danger">*</span></label>
                            <input asp-for="Form.Name" class="form-control" id="formName" placeholder="مثال: Claude Sonnet 4.6" />
                        </div>
                        <div class="col-md-8">
                            <label class="form-label">شناسه مدل <span class="text-danger">*</span></label>
                            <input asp-for="Form.ModelId" class="form-control" id="formModelId" dir="ltr" placeholder="anthropic/claude-sonnet-4-6" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">ترتیب نمایش</label>
                            <input asp-for="Form.SortOrder" type="number" class="form-control" id="formSortOrder" value="0" />
                        </div>
                        <div class="col-12">
                            <label class="form-label">قابلیت‌ها <span class="text-danger">*</span></label>
                            <div class="d-flex flex-wrap gap-3" id="capabilitiesContainer">
                                @foreach (var cap in Model.AllCapabilities)
                                {
                                    <div class="form-check">
                                        <input class="form-check-input capability-check" type="checkbox"
                                               name="Form.SelectedCapabilities" value="@cap" id="cap_@cap" />
                                        <label class="form-check-label" for="cap_@cap">@capLabels[cap]</label>
                                    </div>
                                }
                            </div>
                        </div>
                        <div class="col-12">
                            <div id="pricingGuide" class="alert alert-info py-2 px-3 mb-0 small d-none">
                                <div class="d-flex align-items-start gap-2">
                                    <i class="fas fa-info-circle mt-1 flex-shrink-0"></i>
                                    <div>
                                        <strong>چطور قیمت پیدا کنم؟</strong>
                                        <div id="pricingGuideText" class="mt-1"></div>
                                        <div class="mt-1 text-muted">
                                            نکته: اگر قیمت به صورت «per 1M token» نوشته شده، عدد را تقسیم بر ۱۰۰۰ کنید.
                                            مثال: $5 / 1M token = $0.005 / 1K token
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label d-flex align-items-center gap-1">
                                هزینه / ۱K توکن ($)
                                <i class="fas fa-question-circle text-muted small"
                                   data-bs-toggle="tooltip"
                                   title="هزینه هر ۱۰۰۰ توکن (input+output). برای مدل‌های متنی و کد. اختیاری — فقط برای گزارش مالی استفاده می‌شود."></i>
                            </label>
                            <input asp-for="Form.CostPer1KTokens" type="number" step="0.000001" class="form-control" id="formCostToken" dir="ltr" placeholder="مثال: 0.005" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label d-flex align-items-center gap-1">
                                هزینه / تصویر ($)
                                <i class="fas fa-question-circle text-muted small"
                                   data-bs-toggle="tooltip"
                                   title="هزینه تولید هر تصویر. برای مدل‌های image generation. اختیاری."></i>
                            </label>
                            <input asp-for="Form.CostPerImage" type="number" step="0.000001" class="form-control" id="formCostImage" dir="ltr" placeholder="مثال: 0.04" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label d-flex align-items-center gap-1">
                                هزینه / ثانیه ویدیو ($)
                                <i class="fas fa-question-circle text-muted small"
                                   data-bs-toggle="tooltip"
                                   title="هزینه تولید هر ثانیه ویدیو. برای مدل‌های video generation. اختیاری."></i>
                            </label>
                            <input asp-for="Form.CostPerSecondVideo" type="number" step="0.000001" class="form-control" id="formCostVideo" dir="ltr" placeholder="مثال: 0.1" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">حداکثر توکن</label>
                            <input asp-for="Form.MaxTokens" type="number" class="form-control" id="formMaxTokens" dir="ltr" />
                        </div>
                        <div class="col-md-4 d-flex align-items-end">
                            <div class="form-check">
                                <input asp-for="Form.IsDefault" class="form-check-input" type="checkbox" id="formIsDefault" />
                                <label class="form-check-label" asp-for="Form.IsDefault">مدل پیش‌فرض</label>
                            </div>
                        </div>
                        <div class="col-12">
                            <label class="form-label">توضیح</label>
                            <textarea asp-for="Form.Description" class="form-control" rows="2" id="formDescription"></textarea>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">انصراف</button>
                    <button type="submit" class="btn btn-primary btn-sm">ذخیره</button>
                </div>
            </div>
        </form>
    </div>
</div>

@section Styles {
    <link rel="stylesheet" href="~/css/pages/admin/Models.css" />
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/pages/admin/Models.js"></script>
}
