@page
@model IndexModel
@using PromptMarketPlace.Models.Enums
@{
    ViewData["Title"] = "تاریخچه پرداخت‌ها";
    var statusLabels = new Dictionary<PaymentStatus, (string label, string color)> {
        { PaymentStatus.Pending,  ("در انتظار", "warning") },
        { PaymentStatus.Verified, ("موفق",     "success") },
        { PaymentStatus.Failed,   ("ناموفق",   "danger")  },
        { PaymentStatus.Refunded, ("بازگشتی",  "info")    },
    };
}

@if (TempData["Success"] != null) { <div class="alert alert-success alert-dismissible fade show">@TempData["Success"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div> }
@if (TempData["Error"] != null)   { <div class="alert alert-danger  alert-dismissible fade show">@TempData["Error"]  <button type="button" class="btn-close" data-bs-dismiss="alert"></button></div> }

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h5 class="mb-1">پرداخت‌ها</h5>
        <small class="text-muted">مجموع: @Model.TotalCount تراکنش</small>
    </div>
</div>

<div class="card shadow-sm mb-3">
    <div class="card-body py-2">
        <form method="get" class="d-flex gap-3 align-items-center flex-wrap">
            <input type="text" name="SearchUser" value="@Model.SearchUser" class="form-control form-control-sm" placeholder="ایمیل یا نام کاربر" style="width:220px" />
            <select name="FilterStatus" class="form-select form-select-sm" style="width:auto">
                <option value="">همه وضعیت‌ها</option>
                @foreach (var s in Enum.GetValues<PaymentStatus>())
                {
                    <option value="@s" selected="@(Model.FilterStatus == s.ToString())">@statusLabels[s].label</option>
                }
            </select>
            <button type="submit" class="btn btn-outline-secondary btn-sm">جستجو</button>
        </form>
    </div>
</div>

<div class="card shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th>#</th>
                    <th>کاربر</th>
                    <th>بسته</th>
                    <th class="text-center">اعتبار</th>
                    <th class="text-center">مبلغ (ریال)</th>
                    <th>کد پیگیری</th>
                    <th class="text-center">وضعیت</th>
                    <th>تاریخ</th>
                    <th class="text-center">عملیات</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var p in Model.Payments)
                {
                    var (label, color) = statusLabels[p.Status];
                    <tr>
                        <td class="text-muted small">@p.Id</td>
                        <td>
                            <div>@p.User?.DisplayName</div>
                            <small class="text-muted">@p.User?.Email</small>
                        </td>
                        <td>@p.Package?.Name</td>
                        <td class="text-center fw-semibold">@p.CreditAmount</td>
                        <td class="text-center">@p.Amount.N0Fa()</td>
                        <td><code class="small">@(p.ZarinpalRefId ?? p.ZarinpalAuthority ?? "-")</code></td>
                        <td class="text-center"><span class="badge bg-@color">@label</span></td>
                        <td class="small text-muted">@p.CreatedAt.ToString("yy/MM/dd HH:mm")</td>
                        <td class="text-center">
                            @if (p.Status == PaymentStatus.Verified)
                            {
                                <form method="post" asp-page-handler="Refund" class="d-inline">
                                    <input type="hidden" name="id" value="@p.Id" />
                                    <button type="submit" class="btn btn-sm btn-outline-warning"
                                            onclick="return confirm('اعتبار این پرداخت بازگشت داده شود؟')">
                                        بازگشت اعتبار
                                    </button>
                                </form>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
