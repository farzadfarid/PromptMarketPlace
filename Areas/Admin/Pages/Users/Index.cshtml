@page
@model IndexModel
@using PromptMarketPlace.Models.Enums
@{ ViewData["Title"] = "مدیریت کاربران"; }

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h5 class="mb-1">کاربران</h5>
        <small class="text-muted">مجموع: @Model.TotalCount کاربر</small>
    </div>
</div>

<div class="card shadow-sm mb-3">
    <div class="card-body py-2">
        <form method="get" class="d-flex gap-2 flex-wrap align-items-center">
            <input type="text" name="Search" value="@Model.Search"
                   class="form-control form-control-sm" placeholder="نام یا ایمیل" style="width:220px" />
            <select name="FilterRole" class="form-select form-select-sm" style="width:auto">
                <option value="">همه نقش‌ها</option>
                @foreach (var r in Enum.GetValues<UserRole>())
                { <option value="@r" selected="@(Model.FilterRole == r.ToString())">@r</option> }
            </select>
            <select name="FilterStatus" class="form-select form-select-sm" style="width:auto">
                <option value="">همه وضعیت‌ها</option>
                <option value="active"  selected="@(Model.FilterStatus == "active")">فعال</option>
                <option value="blocked" selected="@(Model.FilterStatus == "blocked")">مسدود</option>
            </select>
            <button type="submit" class="btn btn-outline-secondary btn-sm">جستجو</button>
        </form>
    </div>
</div>

<div class="card shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th>نام</th>
                    <th>ایمیل</th>
                    <th class="text-center">نقش</th>
                    <th class="text-center">اجراها</th>
                    <th>تاریخ ثبت</th>
                    <th class="text-center">وضعیت</th>
                    <th class="text-center">عملیات</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var u in Model.Users)
                {
                    <tr>
                        <td class="fw-semibold">@u.DisplayName</td>
                        <td class="text-muted small">@u.Email</td>
                        <td class="text-center">
                            @{
                                var (roleLabel, roleColor) = u.Role switch {
                                    UserRole.Admin   => ("ادمین",   "danger"),
                                    UserRole.Creator => ("سازنده",  "primary"),
                                    _                => ("کاربر",   "secondary")
                                };
                            }
                            <span class="badge bg-@roleColor">@roleLabel</span>
                        </td>
                        <td class="text-center">@u.ExecutionCount</td>
                        <td class="small text-muted">@u.CreatedAt.ToShamsi("yy/MM/dd")</td>
                        <td class="text-center">
                            @if (u.IsActive)
                            { <span class="badge bg-success">فعال</span> }
                            else
                            { <span class="badge bg-danger">مسدود</span> }
                        </td>
                        <td class="text-center">
                            <a asp-page="/Users/Detail" asp-area="Admin" asp-route-id="@u.Id"
                               class="btn btn-sm btn-outline-primary">جزئیات</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@{
    var totalPages = (int)Math.Ceiling(Model.TotalCount / 30.0);
}
@if (totalPages > 1)
{
    <nav class="mt-3">
        <ul class="pagination pagination-sm">
            @for (int i = 1; i <= totalPages; i++)
            {
                <li class="page-item @(i == Model.PageNumber ? "active" : "")">
                    <a class="page-link" asp-page="/Users/Index" asp-area="Admin"
                       asp-all-route-data='@(new Dictionary<string,string>{{"Search",Model.Search??""}, {"FilterRole",Model.FilterRole??""}, {"FilterStatus",Model.FilterStatus??""}, {"PageNumber",i.ToString()}})'>@i</a>
                </li>
            }
        </ul>
    </nav>
}
