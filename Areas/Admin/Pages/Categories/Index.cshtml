@page
@model IndexModel
@{ ViewData["Title"] = "مدیریت دسته‌بندی‌ها"; }

@if (TempData["Success"] != null) { <div class="alert alert-success alert-dismissible fade show">@TempData["Success"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div> }
@if (TempData["Error"] != null)   { <div class="alert alert-danger  alert-dismissible fade show">@TempData["Error"]  <button type="button" class="btn-close" data-bs-dismiss="alert"></button></div> }

<div class="row g-4">
    <!-- فرم افزودن / ویرایش -->
    <div class="col-md-4">
        <div class="card shadow-sm">
            <div class="card-header bg-white fw-semibold">افزودن / ویرایش دسته‌بندی</div>
            <div class="card-body">
                <form method="post" asp-page-handler="Save" id="catForm">
                    <input type="hidden" asp-for="EditId" id="editId" />
                    <div class="mb-3">
                        <label class="form-label fw-semibold small">نام <span class="text-danger">*</span></label>
                        <input asp-for="Name" class="form-control form-control-sm" id="nameField" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold small">کلاس آیکون (Font Awesome)</label>
                        <input asp-for="IconClass" class="form-control form-control-sm" placeholder="fas fa-robot" id="iconField" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold small">توضیحات</label>
                        <textarea asp-for="Description" class="form-control form-control-sm" rows="2" id="descField"></textarea>
                    </div>
                    <button type="submit" class="btn btn-primary btn-sm w-100">ذخیره</button>
                    <button type="button" class="btn btn-outline-secondary btn-sm w-100 mt-2" onclick="resetForm()">ریست</button>
                </form>
            </div>
        </div>
    </div>

    <!-- جدول دسته‌بندی‌ها -->
    <div class="col-md-8">
        <div class="card shadow-sm">
            <div class="card-header bg-white fw-semibold">دسته‌بندی‌ها (@Model.Categories.Count)</div>
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th style="width:60px">ترتیب</th>
                            <th>نام</th>
                            <th>آیکون</th>
                            <th class="text-center">عملیات</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var c in Model.Categories)
                        {
                            <tr>
                                <td class="text-muted small">@c.SortOrder</td>
                                <td>
                                    <span class="fw-semibold small">@c.Name</span>
                                    @if (!string.IsNullOrEmpty(c.Description))
                                    { <div class="text-muted" style="font-size:0.75rem">@c.Description</div> }
                                </td>
                                <td>
                                    @if (!string.IsNullOrEmpty(c.IconClass))
                                    { <i class="@c.IconClass"></i> <small class="text-muted ms-1">@c.IconClass</small> }
                                </td>
                                <td class="text-center">
                                    <div class="d-flex gap-1 justify-content-center flex-wrap">
                                        <!-- ترتیب -->
                                        <form method="post" asp-page-handler="Move" class="d-inline">
                                            <input type="hidden" name="id" value="@c.Id" />
                                            <input type="hidden" name="direction" value="up" />
                                            <button type="submit" class="btn btn-sm btn-outline-secondary py-0 px-1" title="بالا">↑</button>
                                        </form>
                                        <form method="post" asp-page-handler="Move" class="d-inline">
                                            <input type="hidden" name="id" value="@c.Id" />
                                            <input type="hidden" name="direction" value="down" />
                                            <button type="submit" class="btn btn-sm btn-outline-secondary py-0 px-1" title="پایین">↓</button>
                                        </form>
                                        <!-- ویرایش -->
                                        <button type="button" class="btn btn-sm btn-outline-primary"
                                                onclick="editCat(@c.Id, '@Html.Raw(c.Name.Replace("'","\\'"  ))', '@(c.IconClass ?? "")', '@Html.Raw((c.Description ?? "").Replace("'","\\'"  ))')">
                                            ویرایش
                                        </button>
                                        <!-- حذف -->
                                        <form method="post" asp-page-handler="Delete" class="d-inline">
                                            <input type="hidden" name="id" value="@c.Id" />
                                            <button type="submit" class="btn btn-sm btn-outline-danger"
                                                    data-confirm="دسته‌بندی حذف شود؟">حذف</button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script src="~/js/pages/admin/Categories.js"></script>
}
