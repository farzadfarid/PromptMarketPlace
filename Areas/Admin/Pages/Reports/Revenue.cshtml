@page
@model RevenueModel
@{ ViewData["Title"] = "گزارش درآمد"; }

<h5 class="mb-4">گزارش درآمد</h5>

<!-- فیلتر بازه زمانی -->
<div class="card shadow-sm mb-4">
    <div class="card-body py-2">
        <form method="get" class="d-flex gap-2 align-items-center flex-wrap">
            <label class="form-label mb-0 small fw-semibold">از:</label>
            <input type="date" name="From" value="@Model.From?.ToString("yyyy-MM-dd")"
                   class="form-control form-control-sm" style="width:auto" />
            <label class="form-label mb-0 small fw-semibold">تا:</label>
            <input type="date" name="To" value="@Model.To?.ToString("yyyy-MM-dd")"
                   class="form-control form-control-sm" style="width:auto" />
            <button type="submit" class="btn btn-outline-secondary btn-sm">اعمال</button>
        </form>
    </div>
</div>

<!-- خلاصه -->
<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="card shadow-sm border-0 text-center p-3">
            <div class="text-muted small mb-1">کل درآمد</div>
            <div class="fs-4 fw-bold text-success">@Model.TotalRevenue.N0Fa() <small class="text-muted fs-6">ریال</small></div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card shadow-sm border-0 text-center p-3">
            <div class="text-muted small mb-1">خرید اعتبار</div>
            <div class="fs-4 fw-bold text-primary">@Model.PurchaseRevenue.N0Fa()</div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card shadow-sm border-0 text-center p-3">
            <div class="text-muted small mb-1">کمیسیون اجراها</div>
            <div class="fs-4 fw-bold text-info">@Model.CommissionRevenue.N0Fa()</div>
        </div>
    </div>
</div>

<!-- نمودار -->
<div class="card shadow-sm mb-4">
    <div class="card-body">
        <h6 class="fw-semibold mb-3">درآمد روزانه (ریال)</h6>
        <canvas id="revChart" height="80"></canvas>
    </div>
</div>

<!-- جدول روزانه -->
<div class="card shadow-sm">
    <div class="table-responsive">
        <table class="table table-sm mb-0">
            <thead class="table-light"><tr><th>تاریخ</th><th class="text-center">درآمد (ریال)</th></tr></thead>
            <tbody>
                @foreach (var d in Model.ByDay.Where(d => d.Amount > 0))
                {
                    <tr>
                        <td class="small">@d.Date.ToShamsi("yy/MM/dd")</td>
                        <td class="text-center small fw-semibold">@d.Amount.N0Fa()</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
<script>
    var revenueReportData = {
        chartLabels: @Html.Raw(Model.ChartLabels),
        chartData: @Html.Raw(Model.ChartData)
    };
</script>
<script src="~/js/pages/admin/reports/Revenue.js"></script>
}
