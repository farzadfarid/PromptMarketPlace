@page
@model IndexModel
@using PromptMarketPlace.Models.Enums
@{ ViewData["Title"] = "داشبورد من"; }

<div class="card border-0 shadow-sm mb-4">
    <div class="d-flex justify-content-between align-items-center p-4 pb-3">
        <h6 class="fw-bold mb-0">آخرین اجراها</h6>
        <a asp-page="/Executions/Index" class="small text-primary">مشاهده همه</a>
    </div>
    @if (!Model.RecentExecutions.Any())
    {
        <div class="text-muted small text-center py-4">
            هنوز اجرایی ندارید. <a asp-area="" asp-page="/Explore">ابزارها را کشف کنید</a>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <tbody>
                    @foreach (var exec in Model.RecentExecutions)
                    {
                        var (badge, color) = exec.Status switch {
                            ExecutionStatus.Completed => ("موفق",    "success"),
                            ExecutionStatus.Failed    => ("ناموفق",  "danger"),
                            ExecutionStatus.Refunded  => ("بازگشتی","info"),
                            ExecutionStatus.Running   => ("در جریان","warning"),
                            _                         => ("در انتظار","secondary")
                        };
                        <tr style="cursor:pointer" onclick="window.location='/user/executions/@exec.Id'">
                            <td class="fw-semibold small ps-4">@exec.App?.Title</td>
                            <td class="text-muted small">@exec.CreatedAt.ToString("yy/MM/dd HH:mm")</td>
                            <td><span class="badge bg-@color">@badge</span></td>
                            <td class="text-muted small pe-4">@exec.CreditUsed اعتبار</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@if (Model.RecommendedApps.Any())
{
    <div class="card border-0 shadow-sm p-4">
        <h6 class="fw-bold mb-4">پیشنهاد برای شما</h6>
        <div class="row g-3">
            @foreach (var app in Model.RecommendedApps)
            {
                <div class="col-md-6 col-lg-3">
                    @await Html.PartialAsync("_AppCard", app)
                </div>
            }
        </div>
    </div>
}