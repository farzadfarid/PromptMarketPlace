@page
@model EditModel
@{ ViewData["Title"] = "ویرایش پروفایل"; }

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show mb-4">
        <i class="fas fa-check-circle me-2"></i>@TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<form method="post">
    @if (!ViewData.ModelState.IsValid)
    {
        <div class="alert alert-danger mb-4"><div asp-validation-summary="All"></div></div>
    }

    <div class="row g-4">
        <div class="col-md-6">
            <div class="card border-0 shadow-sm p-4 h-100">
                <h6 class="fw-bold mb-4"><i class="fas fa-user me-2 text-primary"></i>اطلاعات عمومی</h6>

                <div class="mb-3">
                    <label asp-for="DisplayName" class="form-label">نام نمایشی <span class="text-danger">*</span></label>
                    <input asp-for="DisplayName" class="form-control" placeholder="نام نمایشی شما" required />
                    <span asp-validation-for="DisplayName" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="AvatarUrl" class="form-label">آدرس تصویر آواتار <span class="text-muted">(اختیاری)</span></label>
                    <input asp-for="AvatarUrl" class="form-control" placeholder="https://..." />
                    @if (!string.IsNullOrEmpty(Model.AvatarUrl))
                    {
                        <div class="mt-2 d-flex align-items-center gap-2">
                            <img src="@Model.AvatarUrl" alt="آواتار" class="rounded-circle border"
                                 style="width:48px;height:48px;object-fit:cover;"
                                 onerror="this.style.display='none'" />
                            <span class="text-muted small">آواتار فعلی</span>
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card border-0 shadow-sm p-4 h-100">
                <h6 class="fw-bold mb-1"><i class="fas fa-lock me-2 text-primary"></i>تغییر رمز عبور</h6>
                <p class="text-muted small mb-4">فقط در صورت تمایل، این بخش را پر کنید.</p>

                <div class="mb-3">
                    <label asp-for="CurrentPassword" class="form-label">رمز عبور فعلی</label>
                    <input asp-for="CurrentPassword" type="password" class="form-control" autocomplete="current-password" />
                </div>
                <div class="mb-3">
                    <label asp-for="NewPassword" class="form-label">رمز عبور جدید</label>
                    <input asp-for="NewPassword" type="password" class="form-control" autocomplete="new-password" />
                </div>
                <div class="mb-3">
                    <label asp-for="ConfirmPassword" class="form-label">تکرار رمز عبور جدید</label>
                    <input asp-for="ConfirmPassword" type="password" class="form-control" autocomplete="new-password" />
                    <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                </div>
            </div>
        </div>
    </div>

    <div class="mt-4">
        <button type="submit" class="btn btn-primary px-5">
            <i class="fas fa-save me-2"></i>ذخیره تغییرات
        </button>
    </div>
</form>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
