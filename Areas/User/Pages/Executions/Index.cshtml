@page
@model IndexModel
@using PromptMarketPlace.Models.Enums
@{ ViewData["Title"] = "تاریخچه اجراها"; }

<div class="d-flex justify-content-between align-items-center mb-4">
    <div class="d-flex gap-2 flex-wrap">
        @foreach (var s in new[] { (ExecutionStatus?)null, ExecutionStatus.Completed, ExecutionStatus.Failed, ExecutionStatus.Refunded })
        {
            var label = s switch { ExecutionStatus.Completed => "موفق", ExecutionStatus.Failed => "ناموفق", ExecutionStatus.Refunded => "بازگشتی", _ => "همه" };
            <a asp-page="/Executions/Index" asp-route-FilterStatus="@s"
               class="btn btn-sm @(Model.FilterStatus == s ? "btn-primary" : "btn-outline-secondary")">@label</a>
        }
    </div>
    <small class="text-muted">@Model.TotalCount.ToFarsiDigits() اجرا</small>
</div>

<div class="card border-0 shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr><th>ابزار</th><th>تاریخ</th><th class="text-center">وضعیت</th><th class="text-center">اعتبار</th><th></th></tr>
            </thead>
            <tbody>
                @foreach (var exec in Model.Executions)
                {
                    var (badge, color) = exec.Status switch {
                        ExecutionStatus.Completed => ("موفق", "success"),
                        ExecutionStatus.Failed    => ("ناموفق", "danger"),
                        ExecutionStatus.Refunded  => ("بازگشتی", "info"),
                        ExecutionStatus.Running   => ("در حال اجرا", "warning"),
                        _                         => ("در انتظار", "secondary")
                    };
                    <tr style="cursor:pointer" onclick="window.location='/user/executions/@exec.Id'">
                        <td class="fw-semibold small">@exec.App?.Title</td>
                        <td class="text-muted small">@exec.CreatedAt.ToShamsi("yy/MM/dd HH:mm")</td>
                        <td class="text-center"><span class="badge bg-@color">@badge</span></td>
                        <td class="text-center small">@exec.CreditUsed.ToFarsiDigits()</td>
                        <td>
                            <a asp-page="/Executions/Detail" asp-route-id="@exec.Id"
                               class="btn btn-sm btn-outline-primary py-0">مشاهده</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@if (Model.TotalCount > 20)
{
    var totalPages = (int)Math.Ceiling(Model.TotalCount / 20.0);
    <nav class="mt-3">
        <ul class="pagination pagination-sm justify-content-center">
            @for (int i = 1; i <= totalPages; i++)
            {
                <li class="page-item @(i == Model.PageNumber ? "active" : "")">
                    <a class="page-link" asp-page="/Executions/Index"
                       asp-route-PageNumber="@i" asp-route-FilterStatus="@Model.FilterStatus">@i.ToFarsiDigits()</a>
                </li>
            }
        </ul>
    </nav>
}