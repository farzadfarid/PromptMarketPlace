@page "/user/executions/{id:long}"
@model DetailModel
@using PromptMarketPlace.Models.Enums
@{ ViewData["Title"] = "جزئیات اجرا"; }

@if (TempData["Success"] != null)
{ <div class="alert alert-success alert-dismissible fade show">@TempData["Success"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div> }

<div class="d-flex align-items-center gap-3 mb-4">
    <a asp-page="/Executions/Index" class="btn btn-sm btn-outline-secondary">
        <i class="fas fa-arrow-right me-1"></i>بازگشت
    </a>
    <h5 class="fw-bold mb-0">@Model.Execution.App?.Title</h5>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="card border-0 shadow-sm p-3 text-center">
            <div class="small text-muted mb-1">تاریخ اجرا</div>
            <div class="fw-semibold small">@Model.Execution.CreatedAt.ToShamsi("yy/MM/dd HH:mm")</div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 shadow-sm p-3 text-center">
            <div class="small text-muted mb-1">اعتبار مصرف‌شده</div>
            <div class="fw-bold fs-5 text-primary">@Model.Execution.CreditUsed.ToFarsiDigits()</div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 shadow-sm p-3 text-center">
            <div class="small text-muted mb-1">توکن‌ها</div>
            <div class="fw-semibold">@(Model.Execution.TokensUsed?.N0Fa() ?? "-")</div>
        </div>
    </div>
</div>

@if (Model.Execution.InputValues.Any(i => !i.FieldName.StartsWith("__")))
{
    <div class="card border-0 shadow-sm p-3 p-md-4 mb-4">
        <h6 class="fw-semibold mb-3"><i class="fas fa-keyboard me-2 text-muted"></i>ورودی‌های شما</h6>
        <dl class="row mb-0">
            @foreach (var input in Model.Execution.InputValues.Where(i => !i.FieldName.StartsWith("__")))
            {
                var field = Model.Execution.App?.InputFields.FirstOrDefault(f => f.Name == input.FieldName);
                var val = input.FieldValue ?? "";
                var isImage = (val.StartsWith("/uploads/") || val.StartsWith("uploads/")) &&
                              System.Text.RegularExpressions.Regex.IsMatch(val, @"\.(jpg|jpeg|png|webp|gif)$", System.Text.RegularExpressions.RegexOptions.IgnoreCase);
                var imgSrc = isImage ? (val.StartsWith("/") ? val : "/" + val) : null;

                // برای ImageSelect: label فارسی رو از options پیدا کن
                string displayVal = val;
                if (field?.Type == PromptMarketPlace.Models.Enums.FieldType.ImageSelect && !string.IsNullOrEmpty(field.Options))
                {
                    try
                    {
                        var opts = System.Text.Json.JsonSerializer.Deserialize<List<System.Text.Json.Nodes.JsonNode>>(field.Options);
                        var matched = opts?.FirstOrDefault(o => o?["value"]?.GetValue<string>() == val);
                        if (matched != null)
                            displayVal = matched["label"]?.GetValue<string>() ?? val;
                    }
                    catch { }
                }

                <dt class="col-5 col-sm-4 small text-muted">@(field?.Label ?? input.FieldName)</dt>
                <dd class="col-7 col-sm-8 small" style="word-break:break-word;overflow-wrap:anywhere;">
                    @if (imgSrc != null)
                    {
                        <img src="@imgSrc" alt="@(field?.Label ?? input.FieldName)"
                             style="max-height:160px;max-width:100%;border-radius:8px;object-fit:contain;" />
                    }
                    else
                    {
                        @displayVal
                    }
                </dd>
            }
        </dl>
    </div>
}

@await Html.PartialAsync("_OutputRenderer", Model.Execution)

<div class="mt-4 d-flex gap-2 flex-wrap">
    @if (!string.IsNullOrEmpty(Model.Execution.App?.Slug))
    {
        <a asp-area="" asp-page="/App/Detail"
           asp-route-slug="@Model.Execution.App.Slug"
           asp-route-exec="@Model.Execution.Id"
           class="btn btn-primary">
            <i class="fas fa-redo me-1"></i>اجرای مجدد
        </a>
    }
    @if (Model.Execution.Status == ExecutionStatus.Completed)
    {
        <form method="post" asp-page-handler="TogglePublic" asp-route-id="@Model.Execution.Id">
            <button type="submit" class="btn @(Model.Execution.IsPublic ? "btn-warning" : "btn-outline-secondary")">
                <i class="fas @(Model.Execution.IsPublic ? "fa-eye-slash" : "fa-share-alt") me-1"></i>
                @(Model.Execution.IsPublic ? "خصوصی کن" : "عمومی کن")
            </button>
        </form>
    }
</div>