@page
@model CreateModel
@{ ViewData["Title"] = "ساخت ابزار جدید"; }

<div class="row justify-content-center">
    <div class="col-lg-9">

        <!-- بنر بازیابی پیش‌نویس -->
        <div id="draft-restore-banner" class="d-none alert d-flex align-items-center justify-content-between gap-3 mb-3 py-2 px-3"
             style="background:rgba(249,115,22,.08);border:1px solid rgba(249,115,22,.3);border-radius:10px;">
            <div class="small">
                <i class="fas fa-history me-2" style="color:#f97316;"></i>
                پیش‌نویس ذخیره‌شده از <strong id="draft-saved-time"></strong> بازیابی شد.
            </div>
            <button type="button" id="draft-clear-btn" class="btn btn-sm btn-outline-danger py-0 px-2" style="font-size:.75rem;">
                <i class="fas fa-trash-alt me-1"></i>پاک کردن
            </button>
        </div>

        <!-- Wizard Steps -->
        <div class="d-flex gap-0 mb-4" id="wizard-steps">
            @foreach (var (num, title) in new[] {(1,"اطلاعات پایه"),(2,"تنظیمات AI"),(3,"پرامپت")})
            {
                <div class="wizard-step flex-fill text-center py-2 px-3 border @(num==1?"border-primary bg-primary fw-semibold":"text-muted")"
                     id="step-indicator-@num" style="cursor:pointer" onclick="goToStep(@num)">
                    <span class="badge @(num==1?"bg-white text-primary":"bg-secondary") me-1">@num</span>
                    @title
                </div>
            }
        </div>

        <form method="post" enctype="multipart/form-data">
            <div asp-validation-summary="All" class="alert alert-danger py-2 small"></div>

            <!-- مرحله ۱ -->
            <div id="step-1" class="wizard-step-content">
                <div class="card border-0 shadow-sm p-4 mb-3">
                    <h6 class="fw-semibold mb-4">اطلاعات پایه</h6>
                    <div class="mb-3">
                        <label class="form-label">عنوان ابزار <span class="text-danger">*</span></label>
                        <input asp-for="Form.Title" id="form-title" class="form-control" placeholder="مثال: تولید متن تبلیغاتی" />
                        <span asp-validation-for="Form.Title" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">توضیح کوتاه <span class="text-danger">*</span>
                            <small class="text-muted">(حداکثر ۱۶۰ کاراکتر)</small>
                        </label>
                        <input asp-for="Form.ShortDescription" id="form-short-desc" class="form-control"
                               placeholder="یک جمله که ابزار شما را توصیف کند" maxlength="160" />
                        <span asp-validation-for="Form.ShortDescription" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">توضیح کامل <span class="text-danger">*</span></label>
                        <textarea asp-for="Form.Description" id="form-description" class="form-control" rows="5"
                                  placeholder="توضیح کامل ابزار، موارد استفاده، نمونه‌ها..."></textarea>
                        <span asp-validation-for="Form.Description" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">تصویر کاور ابزار <small class="text-muted">(اختیاری — JPG، PNG، WEBP)</small></label>
                        <div class="thumbnail-upload-box" id="thumbnail-box" onclick="document.getElementById('thumbnail-input').click()">
                            <img id="thumbnail-preview" src="" class="d-none" alt="preview" />
                            <div id="thumbnail-placeholder">
                                <i class="fas fa-cloud-upload-alt fa-2x mb-2"></i>
                                <div class="small">کلیک کنید یا تصویر را اینجا بکشید</div>
                                <div class="text-muted" style="font-size:.72rem;">حداکثر ۲ مگابایت</div>
                            </div>
                        </div>
                        <input type="file" asp-for="Form.Thumbnail" id="thumbnail-input" accept=".jpg,.jpeg,.png,.webp" class="d-none" />
                        <div class="form-text text-muted mt-1">
                            <i class="fas fa-info-circle me-1"></i>اندازه توصیه‌شده: <strong>۷۵۰ × ۴۰۴</strong> پیکسل — فرمت: JPG، PNG، WEBP — حداکثر ۲ مگابایت
                        </div>
                    </div>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">دسته‌بندی <span class="text-danger">*</span></label>
                            <select asp-for="Form.CategoryId" id="form-category" asp-items="Model.CategoryList"
                                    class="form-select">
                                <option value="0">انتخاب دسته‌بندی</option>
                            </select>
                            <span asp-validation-for="Form.CategoryId" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">تگ‌ها <small class="text-muted">(با کاما جدا کنید)</small></label>
                            <input asp-for="Form.Tags" id="form-tags" class="form-control" placeholder="تبلیغات، مارکتینگ، محتوا" />
                        </div>
                    </div>
                </div>
                <div class="d-flex justify-content-end">
                    <button type="button" class="btn btn-primary" onclick="goToStep(2)">
                        بعدی <i class="fas fa-arrow-left ms-1"></i>
                    </button>
                </div>
            </div>

            <!-- مرحله ۲ -->
            <div id="step-2" class="wizard-step-content d-none">
                <div class="card border-0 shadow-sm p-4 mb-3">
                    <h6 class="fw-semibold mb-4">تنظیمات هوش مصنوعی</h6>
                    <div class="mb-3">
                        <label class="form-label">نوع خروجی <span class="text-danger">*</span></label>
                        <div class="row g-2" id="output-type-selector">
                            @foreach (var (type, icon, label) in new[] {
                                (OutputType.Text,"fa-align-left","متن"),
                                (OutputType.Image,"fa-image","تصویر"),
                                (OutputType.Video,"fa-video","ویدیو"),
                                (OutputType.Code,"fa-code","کد"),
                                (OutputType.Audio,"fa-music","صدا"),
                                (OutputType.Form,"fa-file-alt","فرم")
                            })
                            {
                                <div class="col-4 col-md-2">
                                    <input type="radio" asp-for="Form.OutputType" value="@type"
                                           id="ot_@type" class="btn-check" onchange="filterModels('@type')" />
                                    <label for="ot_@type" class="btn btn-outline-secondary w-100 py-3">
                                        <i class="fas @icon d-block mb-1"></i>
                                        <small>@label</small>
                                    </label>
                                </div>
                            }
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">مدل هوش مصنوعی <span class="text-danger">*</span></label>
                        <select asp-for="Form.AiModelId" class="form-select" id="ai-model-select">
                            <option value="0">ابتدا نوع خروجی را انتخاب کنید</option>
                        </select>
                        <span asp-validation-for="Form.AiModelId" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label class="form-label d-flex align-items-center gap-2">
                            هزینه اعتباری پیشنهادی
                            <span class="badge" style="background:rgba(249,115,22,.12);border:1px solid rgba(249,115,22,.25);color:#fed7aa;font-size:.65rem;font-weight:500;">ادمین می‌تواند تغییر دهد</span>
                        </label>
                        <div class="input-group" style="max-width:200px;">
                            <span class="input-group-text"><i class="fas fa-coins"></i></span>
                            <input asp-for="Form.CreditCost" type="number" class="form-control" min="1" max="1000" id="credit-cost-input" />
                            <span class="input-group-text small">اعتبار</span>
                        </div>
                        <div class="text-muted mt-1 small">
                            پیشنهاد بر اساس نوع خروجی: <strong id="pricing-value">—</strong> اعتبار
                        </div>
                        <span asp-validation-for="Form.CreditCost" class="text-danger small"></span>
                    </div>
                </div>
                <div class="d-flex justify-content-between">
                    <button type="button" class="btn btn-outline-secondary" onclick="goToStep(1)">
                        <i class="fas fa-arrow-right me-1"></i>قبلی
                    </button>
                    <button type="button" class="btn btn-primary" onclick="goToStep(3)">
                        بعدی <i class="fas fa-arrow-left ms-1"></i>
                    </button>
                </div>
            </div>

            <!-- مرحله ۳ -->
            <div id="step-3" class="wizard-step-content d-none">
                <div class="row g-4 align-items-start">

                    <!-- ستون فیلدها -->
                    <div class="col-lg-5">
                        <div class="card border-0 shadow-sm p-4" style="position:sticky;top:72px;">
                            <div class="d-flex align-items-center justify-content-between mb-3">
                                <div class="d-flex align-items-center gap-2">
                                    <h6 class="fw-bold mb-0">فیلدهای ورودی</h6>
                                    <button type="button" tabindex="0" class="btn p-0 help-icon-btn"
                                            data-bs-toggle="popover" data-bs-trigger="focus" data-bs-placement="right"
                                            data-bs-title="فیلدهای ورودی چیست؟"
                                            data-bs-content="فیلدها اطلاعاتی هستند که کاربر هنگام استفاده از ابزار وارد می‌کند. هر فیلد یک متغیر در پرامپت می‌شود. مثلاً فیلدی با نام subject در پرامپت به صورت {subject} استفاده می‌شود.">
                                        <i class="fas fa-question-circle" style="font-size:.8rem;color:var(--dk-muted);"></i>
                                    </button>
                                </div>
                                <span id="field-count-badge" class="badge rounded-pill"
                                      style="background:rgba(249,115,22,.15);border:1px solid rgba(249,115,22,.3);color:#fed7aa;">
                                    ۰ فیلد
                                </span>
                            </div>

                            <!-- فرم افزودن -->
                            <div class="rounded-3 p-3 mb-3" style="background:var(--dk-surface2);border:1px dashed var(--dk-border2);">
                                <div class="row g-2 mb-2">
                                    <div class="col-6">
                                        <label class="form-label small fw-semibold mb-1 d-flex align-items-center gap-1">
                                            نام متغیر <span class="text-danger">*</span>
                                            <button type="button" tabindex="0" class="btn p-0 help-icon-btn"
                                                    data-bs-toggle="popover" data-bs-trigger="focus" data-bs-placement="top"
                                                    data-bs-content="نامی که در پرامپت استفاده می‌شود. فقط حروف کوچک انگلیسی، عدد و _ مجاز است. مثال: subject یا brand_name">
                                                <i class="fas fa-question-circle" style="font-size:.68rem;color:var(--dk-muted);"></i>
                                            </button>
                                        </label>
                                        <input type="text" id="nf-name" class="form-control form-control-sm" dir="ltr" placeholder="subject" />
                                        <div id="nf-name-err" class="text-danger d-none" style="font-size:.7rem;"></div>
                                    </div>
                                    <div class="col-6">
                                        <label class="form-label small fw-semibold mb-1">نوع فیلد</label>
                                        <select id="nf-type" class="form-select form-select-sm">
                                            <option value="Text">متن ساده</option>
                                            <option value="Textarea">متن چند خطی</option>
                                            <option value="Select">انتخابی (dropdown)</option>
                                            <option value="Number">عدد</option>
                                            <option value="Checkbox">بله / خیر</option>
                                            <option value="FileUpload">آپلود تصویر</option>
                                            <option value="DatePicker">تاریخ</option>
                                        </select>
                                    </div>
                                </div>
                                <div class="mb-2">
                                    <label class="form-label small fw-semibold mb-1">عنوان نمایشی <span class="text-danger">*</span></label>
                                    <input type="text" id="nf-label" class="form-control form-control-sm" placeholder="مثال: موضوع ایمیل" />
                                    <div id="nf-label-err" class="text-danger d-none" style="font-size:.7rem;"></div>
                                </div>
                                <div class="row g-2 mb-2">
                                    <div class="col-8">
                                        <label class="form-label small mb-1">Placeholder <small class="text-muted">(اختیاری)</small></label>
                                        <input type="text" id="nf-placeholder" class="form-control form-control-sm" />
                                    </div>
                                    <div class="col-4 d-flex align-items-end pb-1">
                                        <div class="form-check mb-0">
                                            <input type="checkbox" id="nf-required" class="form-check-input" checked />
                                            <label class="form-check-label small" for="nf-required">اجباری</label>
                                        </div>
                                    </div>
                                </div>
                                <div id="nf-options-wrap" class="mb-2 d-none">
                                    <label class="form-label small fw-semibold mb-1 d-flex align-items-center gap-1">
                                        گزینه‌ها
                                        <button type="button" tabindex="0" class="btn p-0 help-icon-btn"
                                                data-bs-toggle="popover" data-bs-trigger="focus" data-bs-placement="top"
                                                data-bs-content="هر خط یک گزینه. مثال: فارسی / انگلیسی / آلمانی">
                                            <i class="fas fa-question-circle" style="font-size:.68rem;color:var(--dk-muted);"></i>
                                        </button>
                                    </label>
                                    <textarea id="nf-options" class="form-control form-control-sm" rows="3" dir="ltr"
                                              placeholder="گزینه اول&#10;گزینه دوم&#10;گزینه سوم"></textarea>
                                </div>
                                <button type="button" class="btn btn-primary btn-sm w-100 mt-1" id="add-field-btn">
                                    <i class="fas fa-plus me-1"></i>افزودن به لیست
                                </button>
                            </div>

                            <!-- لیست فیلدها -->
                            <div id="fields-empty-state" class="text-center py-3" style="color:var(--dk-muted);font-size:.82rem;">
                                <i class="fas fa-layer-group fa-2x mb-2 d-block opacity-25"></i>
                                هنوز فیلدی اضافه نشده.
                            </div>
                            <div id="fields-cards-list"></div>
                        </div>
                    </div>

                    <!-- ستون پرامپت -->
                    <div class="col-lg-7">
                        <div class="alert small mb-3 d-flex gap-2 align-items-start"
                             style="background:rgba(249,115,22,.08);border:1px solid rgba(249,115,22,.2);color:var(--dk-text);border-radius:10px;">
                            <i class="fas fa-lightbulb mt-1 flex-shrink-0" style="color:#f97316;"></i>
                            <span>فیلدها را از پنل سمت چپ اضافه کنید. سپس در پرامپت <code dir="ltr">{</code> بزنید تا لیست انتخاب فیلد ظاهر شود.</span>
                        </div>

                        <div class="card border-0 shadow-sm p-4">
                            <!-- System Context -->
                            <div class="mb-4">
                                <div class="d-flex align-items-center gap-2 mb-2">
                                    <label class="form-label fw-semibold mb-0">System Context</label>
                                    <small class="text-muted">(اختیاری)</small>
                                    <button type="button" tabindex="0" class="btn p-0 help-icon-btn"
                                            data-bs-toggle="popover" data-bs-trigger="focus" data-bs-placement="top"
                                            data-bs-title="System Context چیست؟"
                                            data-bs-content="شخصیت و نقش هوش مصنوعی را تعریف می‌کند. قبل از هر درخواست کاربر، مخفیانه به مدل ارسال می‌شود. مثال: You are a professional email writer. Always write formal emails.">
                                        <i class="fas fa-question-circle" style="font-size:.85rem;color:var(--dk-muted);"></i>
                                    </button>
                                </div>
                                <textarea asp-for="Form.SystemContext" id="system-context" class="form-control" rows="2" dir="ltr"
                                          placeholder="You are a professional email writer..."></textarea>
                                <div class="mt-1">
                                    <button type="button" class="btn btn-sm py-0 px-2 dir-toggle" onclick="toggleDir('system-context',this)" style="font-size:.72rem;border:1px solid var(--dk-border2);color:var(--dk-muted);">
                                        <i class="fas fa-align-right me-1"></i>RTL / LTR
                                    </button>
                                </div>
                            </div>

                            <!-- پرامپت اصلی -->
                            <div>
                                <div class="d-flex align-items-center gap-2 mb-2">
                                    <label class="form-label fw-semibold mb-0">پرامپت اصلی <span class="text-danger">*</span></label>
                                    <button type="button" tabindex="0" class="btn p-0 help-icon-btn"
                                            data-bs-toggle="popover" data-bs-trigger="focus" data-bs-placement="top"
                                            data-bs-title="پرامپت اصلی"
                                            data-bs-content="دستورالعمل اصلی برای هوش مصنوعی. وقتی { می‌زنید لیست فیلدهای تعریف‌شده ظاهر می‌شود. مثال: یک ایمیل رسمی درباره {subject} برای {recipient} بنویس.">
                                        <i class="fas fa-question-circle" style="font-size:.85rem;color:var(--dk-muted);"></i>
                                    </button>
                                </div>
                                <textarea asp-for="Form.Prompt" class="form-control" rows="11"
                                          id="prompt-textarea"
                                          style="font-family:monospace;font-size:.9rem;"
                                          placeholder="پرامپت خود را اینجا بنویسید...&#10;&#10;{ را بزنید تا فیلدهای تعریف‌شده نمایش داده شود."></textarea>
                                <div class="mt-1">
                                    <button type="button" class="btn btn-sm py-0 px-2 dir-toggle" onclick="toggleDir('prompt-textarea',this)" style="font-size:.72rem;border:1px solid var(--dk-border2);color:var(--dk-muted);">
                                        <i class="fas fa-align-right me-1"></i>RTL / LTR
                                    </button>
                                </div>

                                <!-- Field quick-picker (ظاهر می‌شود وقتی { زده می‌شود) -->
                                <div id="field-quickpick" class="d-none mt-2 p-2 rounded-2"
                                     style="background:var(--dk-surface2);border:1px solid rgba(249,115,22,.3);">
                                    <div class="d-flex align-items-center gap-2 flex-wrap">
                                        <small style="color:#f97316;font-size:.72rem;white-space:nowrap;">
                                            <i class="fas fa-bolt me-1"></i>انتخاب فیلد:
                                        </small>
                                        <div id="quickpick-chips" class="d-flex gap-1 flex-wrap"></div>
                                    </div>
                                </div>

                                <div class="d-flex align-items-start justify-content-between mt-2 gap-2">
                                    <span asp-validation-for="Form.Prompt" class="text-danger small"></span>
                                    <div id="variable-chips" class="d-flex flex-wrap gap-1 justify-content-end flex-fill"></div>
                                </div>
                            </div>

                            <div class="alert alert-warning small mt-3 mb-0">
                                <i class="fas fa-lock me-1"></i>
                                پرامپت با رمزنگاری AES-256 ذخیره می‌شود و هرگز به کاربران نمایش داده نخواهد شد.
                            </div>
                        </div>
                    </div>
                </div>

                <input type="hidden" id="fields-json-input" name="Form.FieldsJson" />

                <div class="d-flex justify-content-between mt-4">
                    <button type="button" class="btn btn-outline-secondary" onclick="goToStep(2)">
                        <i class="fas fa-arrow-right me-1"></i>قبلی
                    </button>
                    <button type="submit" class="btn btn-success px-4" onclick="serializeFields()">
                        <i class="fas fa-save me-1"></i>ذخیره ابزار
                    </button>
                </div>
            </div>
        </form>
    </div>
</div>

@section Styles {
    <style>
    .thumbnail-upload-box {
        border: 2px dashed var(--dk-border2);
        border-radius: 12px;
        aspect-ratio: 750 / 404;
        max-width: 480px;
        position: relative;
        cursor: pointer; overflow: hidden;
        transition: border-color .2s;
        background: var(--dk-surface2);
        color: var(--dk-muted2);
    }
    .thumbnail-upload-box:hover { border-color: var(--creator-accent); color: var(--dk-text); }
    .thumbnail-upload-box #thumbnail-preview {
        position: absolute; inset: 0;
        width: 100%; height: 100%; object-fit: cover;
    }
    .thumbnail-upload-box #thumbnail-placeholder {
        position: absolute; inset: 0;
        display: flex; flex-direction: column;
        align-items: center; justify-content: center;
        text-align: center;
    }
    </style>
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        var createPageData = { allModels: @Html.Raw(Model.ModelsJson) };
        var pricingMapData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.PricingByType));
    </script>
    <script src="~/js/pages/creator/apps/Create.js"></script>
    <script>
    document.getElementById('thumbnail-input').addEventListener('change', function() {
        var file = this.files[0];
        if (!file) return;
        var reader = new FileReader();
        reader.onload = function(e) {
            var img = document.getElementById('thumbnail-preview');
            var ph  = document.getElementById('thumbnail-placeholder');
            img.src = e.target.result;
            img.classList.remove('d-none');
            ph.classList.add('d-none');
        };
        reader.readAsDataURL(file);
    });
    </script>
}
