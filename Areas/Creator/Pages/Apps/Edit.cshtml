@page
@model EditModel
@{ ViewData["Title"] = "ویرایش: " + Model.App.Title; }

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show">
        @TempData["Error"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="row justify-content-center">
    <div class="col-lg-9">

        <!-- آمار مصرف توکن -->
        @if (Model.AvgTokensAll.HasValue)
        {
            <div class="alert @(Model.IsUnprofitable ? "alert-danger" : "alert-info") py-2 px-3 mb-3 d-flex align-items-center gap-3 flex-wrap small">
                <i class="fas fa-microchip"></i>
                <div class="d-flex gap-4 flex-wrap flex-grow-1">
                    <span>
                        <span class="text-muted">میانگین توکن (کل): </span>
                        <strong>@Model.AvgTokensAll.Value.N0Fa()</strong>
                    </span>
                    @if (Model.AvgTokens30d.HasValue)
                    {
                        <span>
                            <span class="text-muted">میانگین ۳۰ روز: </span>
                            <strong>@Model.AvgTokens30d.Value.N0Fa()</strong>
                        </span>
                    }
                    <span>
                        <span class="text-muted">هزینه اجرا: </span>
                        <strong>@Model.App.CreditCost.ToFarsiDigits() اعتبار</strong>
                    </span>
                </div>
                @if (Model.IsUnprofitable)
                {
                    <span class="badge bg-danger">
                        <i class="fas fa-exclamation-triangle me-1"></i>احتمال زیان‌دهی — افزایش هزینه اجرا توصیه می‌شود
                    </span>
                }
                <button type="button" class="btn btn-link p-0 help-popover-btn"
                        data-help-id="tokenStats" title="راهنما" style="line-height:1">
                    <i class="fas fa-question-circle @(Model.IsUnprofitable ? "text-white" : "")"></i>
                </button>
            </div>
        }

        <!-- ماشین حساب تخمین توکن -->
        <div class="card border-0 shadow-sm mb-3">
            <div class="card-header d-flex align-items-center gap-2 py-2">
                <h6 class="mb-0 small fw-semibold flex-grow-1">
                    <i class="fas fa-calculator me-2 text-primary"></i>ماشین حساب تخمین توکن
                </h6>
                <button type="button" class="btn btn-link p-0 text-muted help-popover-btn"
                        data-help-id="calculator" title="راهنما" style="line-height:1;font-size:.9rem">
                    <i class="fas fa-question-circle"></i>
                </button>
                <button class="btn btn-sm btn-outline-secondary py-0 px-2"
                        data-bs-toggle="collapse" data-bs-target="#creatorCalcBox">
                    نمایش / پنهان
                </button>
            </div>
            <div class="collapse" id="creatorCalcBox">
                <div class="card-body pt-2"
                     id="creatorTokenCalc"
                     data-prompt="@Model.PromptCharCount"
                     data-sys="@Model.SystemContextCharCount"
                     data-fields="@(System.Text.Json.JsonSerializer.Serialize(Model.ExistingFields.Select(f => f.Type.ToString())))"
                     data-outputtype="@Model.App.OutputType"
                     data-creditcost="@Model.App.CreditCost">
                    <table class="table table-sm small mb-2">
                        <tbody>
                            <tr>
                                <td class="text-muted">System Context</td>
                                <td class="text-end fw-semibold" id="ctc-sys">0</td>
                                <td class="text-muted ps-1" style="font-size:.7rem">توکن</td>
                            </tr>
                            <tr>
                                <td class="text-muted">پرامپت قالب</td>
                                <td class="text-end fw-semibold" id="ctc-prompt">0</td>
                                <td class="text-muted ps-1" style="font-size:.7rem">توکن</td>
                            </tr>
                            <tr>
                                <td class="text-muted">فیلدهای ورودی (@Model.ExistingFields.Count فیلد)</td>
                                <td class="text-end fw-semibold" id="ctc-fields">0</td>
                                <td class="text-muted ps-1" style="font-size:.7rem">توکن</td>
                            </tr>
                            <tr>
                                <td>
                                    <div class="text-muted">خروجی تخمینی</div>
                                    <div class="d-flex align-items-center gap-1 mt-1">
                                        <input type="range" id="ctc-slider" min="100" max="4000" step="100" value="500"
                                               class="form-range flex-grow-1" oninput="updateCreatorCalc()">
                                        <span id="ctc-out-lbl" class="text-primary fw-semibold" style="min-width:36px;font-size:.8rem">500</span>
                                    </div>
                                </td>
                                <td class="text-end fw-semibold" id="ctc-out">500</td>
                                <td class="text-muted ps-1" style="font-size:.7rem">توکن</td>
                            </tr>
                        </tbody>
                        <tfoot>
                            <tr class="fw-bold">
                                <td class="border-top pt-2">مجموع تخمینی</td>
                                <td class="text-end border-top pt-2" id="ctc-total">—</td>
                                <td class="text-muted ps-1 border-top pt-2" style="font-size:.7rem">توکن</td>
                            </tr>
                        </tfoot>
                    </table>
                    <div class="text-center py-2 rounded" style="background:rgba(13,110,253,.06);border:1px solid rgba(13,110,253,.2);">
                        <div class="text-muted small">هزینه اجرای پیشنهادی</div>
                        <div class="fw-bold fs-5 text-primary" id="ctc-credits">—</div>
                        <div class="text-muted" style="font-size:.68rem">اعتبار &nbsp;|&nbsp; ۱٬۰۰۰ توکن = ۱ اعتبار</div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Wizard Steps -->
        <div class="d-flex gap-0 mb-4" id="wizard-steps">
            @foreach (var (num, title) in new[] { (1,"اطلاعات پایه"), (2,"تنظیمات AI"), (3,"فیلدها و پرامپت") })
            {
                <div class="wizard-step flex-fill text-center py-2 px-3 border @(num==1?"border-primary bg-primary fw-semibold":"text-muted")"
                     id="step-indicator-@num" style="cursor:pointer" onclick="goToStep(@num)">
                    <span class="badge @(num==1?"bg-white text-primary":"bg-secondary") me-1">@num</span>
                    @title
                </div>
            }
        </div>

        <form method="post" asp-route-appId="@Model.App.Id" enctype="multipart/form-data">
            <div asp-validation-summary="All" class="alert alert-danger small py-2"></div>

            <!-- ─── مرحله ۱: اطلاعات پایه ─── -->
            <div id="step-1" class="wizard-step-content">
                <div class="card border-0 shadow-sm p-4 mb-3">
                    <h6 class="fw-bold mb-4">اطلاعات پایه</h6>
                    <div class="mb-3">
                        <label class="form-label">عنوان ابزار <span class="text-danger">*</span></label>
                        <input asp-for="Form.Title" class="form-control" />
                        <span asp-validation-for="Form.Title" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">توضیح کوتاه <span class="text-danger">*</span>
                            <small class="text-muted">(حداکثر ۱۶۰ کاراکتر)</small>
                        </label>
                        <input asp-for="Form.ShortDescription" class="form-control" maxlength="160" />
                        <span asp-validation-for="Form.ShortDescription" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">توضیح کامل <span class="text-danger">*</span></label>
                        <textarea asp-for="Form.Description" class="form-control" rows="5"></textarea>
                        <span asp-validation-for="Form.Description" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">تصویر کاور <small class="text-muted">(اختیاری — JPG، PNG، WEBP)</small></label>
                        <div class="thumbnail-upload-box" id="thumbnail-box" onclick="document.getElementById('thumbnail-input').click()">
                            @if (!string.IsNullOrEmpty(Model.App.ThumbnailUrl))
                            {
                                <img id="thumbnail-preview" src="@Model.App.ThumbnailUrl" alt="thumbnail" style="width:100%;height:100%;object-fit:cover;" />
                                <div id="thumbnail-placeholder" class="d-none">
                                    <i class="fas fa-cloud-upload-alt fa-2x mb-2"></i>
                                    <div class="small">کلیک برای تغییر تصویر</div>
                                </div>
                            }
                            else
                            {
                                <img id="thumbnail-preview" src="" class="d-none" alt="preview" />
                                <div id="thumbnail-placeholder">
                                    <i class="fas fa-cloud-upload-alt fa-2x mb-2"></i>
                                    <div class="small">کلیک کنید یا تصویر را اینجا بکشید</div>
                                    <div class="text-muted" style="font-size:.72rem;">حداکثر ۵ مگابایت</div>
                                </div>
                            }
                        </div>
                        <input type="file" asp-for="Form.Thumbnail" id="thumbnail-input" accept=".jpg,.jpeg,.png,.webp" class="d-none" />
                        <div class="form-text text-muted mt-1">
                            <i class="fas fa-info-circle me-1"></i>اندازه توصیه‌شده: <strong>۷۵۰ × ۴۰۴</strong> — JPG، PNG، WEBP — حداکثر ۵ مگابایت
                        </div>
                    </div>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">دسته‌بندی <span class="text-danger">*</span></label>
                            <select asp-for="Form.CategoryId" asp-items="Model.CategoryList" class="form-select"></select>
                            <span asp-validation-for="Form.CategoryId" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">تگ‌ها <small class="text-muted">(با کاما جدا کنید)</small></label>
                            <input asp-for="Form.Tags" class="form-control" placeholder="تبلیغات، مارکتینگ، محتوا" />
                        </div>
                    </div>
                </div>
                <div class="d-flex justify-content-end">
                    <button type="button" class="btn btn-primary" onclick="goToStep(2)">
                        بعدی <i class="fas fa-arrow-left ms-1"></i>
                    </button>
                </div>
            </div>

            <!-- ─── مرحله ۲: تنظیمات AI ─── -->
            <div id="step-2" class="wizard-step-content d-none">
                <div class="card border-0 shadow-sm p-4 mb-3">
                    <h6 class="fw-bold mb-4">تنظیمات هوش مصنوعی</h6>

                    @if (!Model.CanEditPrompt)
                    {
                        <div class="alert alert-info small mb-3">
                            <i class="fas fa-info-circle me-1"></i>
                            ابزار فعال است. برای ویرایش مدل و پرامپت باید ابتدا ابزار را تعلیق کنید.
                        </div>
                    }

                    <div class="mb-3">
                        <div class="d-flex align-items-center gap-2 mb-2">
                            <label class="form-label mb-0">نوع خروجی <span class="text-danger">*</span></label>
                            <button type="button" tabindex="0" class="btn p-0 help-icon-btn"
                                    data-bs-toggle="popover" data-bs-trigger="focus" data-bs-placement="top"
                                    data-bs-title="نوع خروجی"
                                    data-bs-content="نوع محتوایی که هوش مصنوعی تولید می‌کند. مدل‌های نمایش داده شده بر اساس این انتخاب فیلتر می‌شوند.">
                                <i class="fas fa-question-circle" style="font-size:.85rem;color:var(--dk-muted);"></i>
                            </button>
                        </div>
                        <div class="row g-2" id="output-type-selector">
                            @foreach (var (type, icon, label) in new[] {
                                (OutputType.Text,"fa-align-left","متن"),
                                (OutputType.Image,"fa-image","تصویر"),
                                (OutputType.Video,"fa-video","ویدیو"),
                                (OutputType.Code,"fa-code","کد"),
                                (OutputType.Audio,"fa-music","صدا"),
                                (OutputType.Form,"fa-file-alt","فرم")
                            })
                            {
                                <div class="col-4 col-md-2">
                                    <input type="radio" asp-for="Form.OutputType" value="@type"
                                           id="ot_@type" class="btn-check"
                                           onchange="filterModels('@type')"
                                           disabled="@(!Model.CanEditPrompt)" />
                                    <label for="ot_@type" class="btn btn-outline-secondary w-100 py-3">
                                        <i class="fas @icon d-block mb-1"></i>
                                        <small>@label</small>
                                    </label>
                                </div>
                            }
                        </div>
                    </div>

                    @if (!Model.CanEditPrompt)
                    {
                        <input type="hidden" asp-for="Form.AiModelId" />
                        <input type="hidden" asp-for="Form.OutputType" />
                    }
                    <div class="mb-3">
                        <label class="form-label">مدل هوش مصنوعی <span class="text-danger">*</span></label>
                        <select asp-for="Form.AiModelId" class="form-select" id="ai-model-select"
                                disabled="@(!Model.CanEditPrompt)">
                            <option value="0">انتخاب مدل...</option>
                        </select>
                        <span asp-validation-for="Form.AiModelId" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">هزینه اعتباری</label>
                        <input asp-for="Form.CreditCost" type="number" min="1" class="form-control" dir="ltr" style="max-width:160px;" />
                        @{
                            var creditHint = Model.App.OutputType switch {
                                OutputType.Video => ("ویدیو: هر ~۸ ثانیه ≈ ۲۰ اعتبار (AvalAI Veo)", "fa-video"),
                                OutputType.Audio => ("صدا: هر متن کوتاه ≈ ۳ اعتبار", "fa-music"),
                                OutputType.Image => ("تصویر: هر تصویر ≈ ۵ اعتبار", "fa-image"),
                                _                => ("متن/کد: ۱ اعتبار = ۱٬۰۰۰ توکن — از ماشین حساب استفاده کنید", "fa-calculator")
                            };
                        }
                        <div class="text-muted mt-1 small">
                            <i class="fas @creditHint.Item2 me-1"></i>@creditHint.Item1
                        </div>
                    </div>
                </div>
                <div class="d-flex justify-content-between">
                    <button type="button" class="btn btn-outline-secondary" onclick="goToStep(1)">
                        <i class="fas fa-arrow-right me-1"></i>قبلی
                    </button>
                    <button type="button" class="btn btn-primary" onclick="goToStep(3)">
                        بعدی <i class="fas fa-arrow-left ms-1"></i>
                    </button>
                </div>
            </div>

            <!-- ─── مرحله ۳: فیلدها و پرامپت ─── -->
            <div id="step-3" class="wizard-step-content d-none">
                <div class="row g-4 align-items-start">

                    <!-- ستون فیلدها -->
                    <div class="col-lg-5">
                        <div class="card border-0 shadow-sm p-4" style="position:sticky;top:72px;">
                            <div class="d-flex align-items-center justify-content-between mb-3">
                                <div class="d-flex align-items-center gap-2">
                                    <h6 class="fw-bold mb-0">فیلدهای ورودی</h6>
                                    <button type="button" tabindex="0" class="btn p-0 help-icon-btn"
                                            data-bs-toggle="popover" data-bs-trigger="focus" data-bs-placement="right"
                                            data-bs-title="فیلدهای ورودی"
                                            data-bs-content="هر فیلد یک متغیر در پرامپت می‌شود که کاربر آن را پر می‌کند. تغییر فیلدها ممکن است روی پرامپت تأثیر بگذارد.">
                                        <i class="fas fa-question-circle" style="font-size:.8rem;color:var(--dk-muted);"></i>
                                    </button>
                                </div>
                                <span id="field-count-badge" class="badge rounded-pill"
                                      style="background:rgba(249,115,22,.15);border:1px solid rgba(249,115,22,.3);color:#fed7aa;">
                                    @toPersianNum(Model.ExistingFields.Count) فیلد
                                </span>
                            </div>

                            <!-- فرم افزودن -->
                            <div class="rounded-3 p-3 mb-3" style="background:var(--dk-surface2);border:1px dashed var(--dk-border2);">
                                <div class="row g-2 mb-2">
                                    <div class="col-6">
                                        <label class="form-label small fw-semibold mb-1 d-flex align-items-center gap-1">
                                            نام متغیر <span class="text-danger">*</span>
                                            <button type="button" tabindex="0" class="btn p-0 help-icon-btn"
                                                    data-bs-toggle="popover" data-bs-trigger="focus" data-bs-placement="top"
                                                    data-bs-content="فقط حروف کوچک انگلیسی، عدد و _ مجاز است. مثال: subject یا brand_name">
                                                <i class="fas fa-question-circle" style="font-size:.68rem;color:var(--dk-muted);"></i>
                                            </button>
                                        </label>
                                        <input type="text" id="nf-name" class="form-control form-control-sm" dir="ltr" placeholder="subject" />
                                        <div id="nf-name-err" class="text-danger d-none" style="font-size:.7rem;"></div>
                                    </div>
                                    <div class="col-6">
                                        <label class="form-label small fw-semibold mb-1">نوع فیلد</label>
                                        <select id="nf-type" class="form-select form-select-sm">
                                            <option value="Text">متن ساده</option>
                                            <option value="Textarea">متن چند خطی</option>
                                            <option value="Select">انتخابی (dropdown)</option>
                                            <option value="ImageSelect">انتخاب تصویری</option>
                                            <option value="Number">عدد</option>
                                            <option value="Checkbox">بله / خیر</option>
                                            <option value="FileUpload">آپلود تصویر</option>
                                            <option value="AudioUpload">آپلود صدا</option>
                                            <option value="DatePicker">تاریخ</option>
                                        </select>
                                    </div>
                                </div>
                                <div class="mb-2">
                                    <label class="form-label small fw-semibold mb-1">عنوان نمایشی <span class="text-danger">*</span></label>
                                    <input type="text" id="nf-label" class="form-control form-control-sm" placeholder="مثال: موضوع ایمیل" />
                                    <div id="nf-label-err" class="text-danger d-none" style="font-size:.7rem;"></div>
                                </div>
                                <div class="row g-2 mb-2">
                                    <div class="col-8">
                                        <label class="form-label small mb-1">Placeholder <small class="text-muted">(اختیاری)</small></label>
                                        <input type="text" id="nf-placeholder" class="form-control form-control-sm" />
                                    </div>
                                    <div class="col-4 d-flex align-items-end pb-1">
                                        <div class="form-check mb-0">
                                            <input type="checkbox" id="nf-required" class="form-check-input" checked />
                                            <label class="form-check-label small" for="nf-required">اجباری</label>
                                        </div>
                                    </div>
                                </div>
                                <div id="nf-options-wrap" class="mb-2 d-none">
                                    <label class="form-label small fw-semibold mb-1 d-flex align-items-center gap-1">
                                        گزینه‌ها
                                        <button type="button" tabindex="0" class="btn p-0 help-icon-btn"
                                                data-bs-toggle="popover" data-bs-trigger="focus" data-bs-placement="top"
                                                data-bs-content="هر خط یک گزینه. مثال: فارسی / انگلیسی / آلمانی">
                                            <i class="fas fa-question-circle" style="font-size:.68rem;color:var(--dk-muted);"></i>
                                        </button>
                                    </label>
                                    <textarea id="nf-options" class="form-control form-control-sm" rows="3" dir="ltr"
                                              placeholder="گزینه اول&#10;گزینه دوم&#10;گزینه سوم"></textarea>
                                </div>

                                <div id="nf-imgopt-wrap" class="mb-2 d-none">
                                    <label class="form-label small fw-semibold mb-1">گزینه‌های تصویری</label>
                                    <div class="small text-muted mb-2" style="font-size:.72rem;">
                                        برای هر گزینه: نام فارسی + URL تصویر نمونه + مقدار ارسالی به پرامپت
                                    </div>
                                    <div id="nf-imgopt-rows"></div>
                                    <button type="button" id="add-imgopt-btn" class="btn btn-sm w-100 mt-1"
                                            style="background:rgba(249,115,22,.08);border:1px dashed rgba(249,115,22,.3);color:#f97316;font-size:.8rem;">
                                        <i class="fas fa-plus me-1"></i>افزودن گزینه
                                    </button>
                                </div>

                                <button type="button" class="btn btn-primary btn-sm w-100 mt-1" id="add-field-btn">
                                    <i class="fas fa-plus me-1"></i>افزودن به لیست
                                </button>
                            </div>

                            <div id="fields-empty-state" class="text-center py-3 @(Model.ExistingFields.Any() ? "d-none" : "")" style="color:var(--dk-muted);font-size:.82rem;">
                                <i class="fas fa-layer-group fa-2x mb-2 d-block opacity-25"></i>
                                هنوز فیلدی اضافه نشده.
                            </div>
                            <div id="fields-cards-list"></div>
                        </div>
                    </div>

                    <!-- ستون پرامپت -->
                    <div class="col-lg-7">
                        <div class="alert small mb-3 d-flex gap-2 align-items-start"
                             style="background:rgba(249,115,22,.08);border:1px solid rgba(249,115,22,.2);color:var(--dk-text);border-radius:10px;">
                            <i class="fas fa-lightbulb mt-1 flex-shrink-0" style="color:#f97316;"></i>
                            <span>فیلدها را از پنل سمت چپ مدیریت کنید. در پرامپت <code dir="ltr">{</code> بزنید تا لیست انتخاب فیلد ظاهر شود.</span>
                        </div>

                        <div class="card border-0 shadow-sm p-4">
                            <!-- System Context -->
                            <div class="mb-4">
                                <div class="d-flex align-items-center gap-2 mb-2">
                                    <label class="form-label fw-semibold mb-0">System Context</label>
                                    <small class="text-muted">(اختیاری)</small>
                                    <button type="button" tabindex="0" class="btn p-0 help-icon-btn"
                                            data-bs-toggle="popover" data-bs-trigger="focus" data-bs-placement="top"
                                            data-bs-title="System Context چیست؟"
                                            data-bs-content="شخصیت و نقش هوش مصنوعی را تعریف می‌کند. قبل از هر درخواست کاربر مخفیانه ارسال می‌شود. مثال: You are a professional email writer.">
                                        <i class="fas fa-question-circle" style="font-size:.85rem;color:var(--dk-muted);"></i>
                                    </button>
                                </div>
                                @if (Model.CanEditPrompt)
                                {
                                    <textarea asp-for="Form.SystemContext" id="system-context" class="form-control" rows="2" dir="ltr"></textarea>
                                    <div class="mt-1">
                                        <button type="button" class="btn btn-sm py-0 px-2" onclick="toggleDir('system-context',this)" style="font-size:.72rem;border:1px solid var(--dk-border2);color:var(--dk-muted);">
                                            <i class="fas fa-align-right me-1"></i>RTL / LTR
                                        </button>
                                    </div>
                                }
                                else
                                {
                                    <textarea asp-for="Form.SystemContext" class="form-control" rows="2" dir="ltr" readonly></textarea>
                                    <div class="form-text text-muted">
                                        <i class="fas fa-lock me-1"></i>برای ویرایش، ابتدا ابزار را تعلیق کنید.
                                    </div>
                                }
                            </div>

                            <!-- پرامپت اصلی -->
                            @if (Model.CanEditPrompt)
                            {
                                <div>
                                    <div class="d-flex align-items-center gap-2 mb-2">
                                        <label class="form-label fw-semibold mb-0">پرامپت اصلی <span class="text-danger">*</span></label>
                                        <button type="button" tabindex="0" class="btn p-0 help-icon-btn"
                                                data-bs-toggle="popover" data-bs-trigger="focus" data-bs-placement="top"
                                                data-bs-title="پرامپت اصلی"
                                                data-bs-content="دستورالعمل اصلی برای هوش مصنوعی. وقتی { می‌زنید لیست فیلدهای تعریف‌شده ظاهر می‌شود.">
                                            <i class="fas fa-question-circle" style="font-size:.85rem;color:var(--dk-muted);"></i>
                                        </button>
                                    </div>
                                    <textarea asp-for="Form.NewPrompt" class="form-control" rows="11"
                                              id="prompt-textarea"
                                              style="font-family:monospace;font-size:.9rem;"></textarea>
                                    <div class="mt-1">
                                        <button type="button" class="btn btn-sm py-0 px-2" onclick="toggleDir('prompt-textarea',this)" style="font-size:.72rem;border:1px solid var(--dk-border2);color:var(--dk-muted);">
                                            <i class="fas fa-align-right me-1"></i>RTL / LTR
                                        </button>
                                    </div>

                                    <!-- Field quick-picker -->
                                    <div id="field-quickpick" class="d-none mt-2 p-2 rounded-2"
                                         style="background:var(--dk-surface2);border:1px solid rgba(249,115,22,.3);">
                                        <div class="d-flex align-items-center gap-2 flex-wrap">
                                            <small style="color:#f97316;font-size:.72rem;white-space:nowrap;">
                                                <i class="fas fa-bolt me-1"></i>انتخاب فیلد:
                                            </small>
                                            <div id="quickpick-chips" class="d-flex gap-1 flex-wrap"></div>
                                        </div>
                                    </div>

                                    <div class="d-flex align-items-start justify-content-between mt-2 gap-2">
                                        <div id="variable-chips" class="d-flex flex-wrap gap-1 flex-fill"></div>
                                    </div>

                                    <!-- ─── Video Tags Helper ─── -->
                                    <div id="video-tags-helper" class="d-none mt-3 rounded-3 p-3"
                                         style="background:rgba(99,102,241,.06);border:1px solid rgba(99,102,241,.22);">
                                        <div class="d-flex align-items-center gap-2 mb-2">
                                            <i class="fas fa-video" style="color:#818cf8;font-size:.82rem;"></i>
                                            <span class="fw-semibold" style="font-size:.8rem;color:#a5b4fc;">تگ‌های کنترل ویدیو</span>
                                            <span class="ms-auto" style="font-size:.68rem;color:var(--dk-muted);">کلیک کنید تا در پرامپت درج شود</span>
                                        </div>

                                        <div class="mb-2">
                                            <div style="font-size:.7rem;color:var(--dk-muted);" class="mb-1">⏱ مدت ویدیو</div>
                                            <div class="d-flex flex-wrap gap-1 align-items-center">
                                                <button type="button" class="vt-chip" onclick="insertVideoTag('[seconds:4]')">[seconds:4]</button>
                                                <button type="button" class="vt-chip" onclick="insertVideoTag('[seconds:8]')">[seconds:8]</button>
                                                <button type="button" class="vt-chip" onclick="insertVideoTag('[seconds:{duration}]')">[seconds:{duration}]</button>
                                                <span style="font-size:.68rem;color:var(--dk-muted);">مدت ثابت (ثانیه) یا از فیلد</span>
                                            </div>
                                        </div>

                                        <div class="mb-2">
                                            <div style="font-size:.7rem;color:var(--dk-muted);" class="mb-1">📐 نسبت تصویر</div>
                                            <div class="d-flex flex-wrap gap-1 align-items-center">
                                                <button type="button" class="vt-chip" onclick="insertVideoTag('[aspect:16:9]')">[aspect:16:9]</button>
                                                <button type="button" class="vt-chip" onclick="insertVideoTag('[aspect:9:16]')">[aspect:9:16]</button>
                                                <button type="button" class="vt-chip" onclick="insertVideoTag('[aspect:1:1]')">[aspect:1:1]</button>
                                                <button type="button" class="vt-chip" onclick="insertVideoTag('[aspect:{platform}]')">[aspect:{platform}]</button>
                                                <span style="font-size:.68rem;color:var(--dk-muted);">افقی / عمودی / مربع / از فیلد</span>
                                            </div>
                                        </div>

                                        <div>
                                            <div style="font-size:.7rem;color:var(--dk-muted);" class="mb-1">👤 حضور انسان</div>
                                            <div class="d-flex flex-wrap gap-1 mb-1">
                                                <button type="button" class="vt-chip vt-green" onclick="insertVideoTag('[persons:dont_allow]')">[persons:dont_allow]</button>
                                                <button type="button" class="vt-chip vt-yellow" onclick="insertVideoTag('[persons:allow_adults]')">[persons:allow_adults]</button>
                                                <button type="button" class="vt-chip vt-red" onclick="insertVideoTag('[persons:allow_all]')">[persons:allow_all]</button>
                                            </div>
                                            <div class="d-flex flex-wrap gap-3" style="font-size:.68rem;color:var(--dk-muted);">
                                                <span>🟢 <code>dont_allow</code> — بدون آدم (محصول‌محور، پیش‌فرض)</span>
                                                <span>🟡 <code>allow_adults</code> — با بازیگر بزرگسال</span>
                                                <span>🔴 <code>allow_all</code> — همه سنین</span>
                                            </div>
                                        </div>
                                    </div>

                                    <div class="alert alert-warning small mt-3 mb-0">
                                        <i class="fas fa-lock me-1"></i>
                                        پرامپت با رمزنگاری AES-256 ذخیره می‌شود و هرگز به کاربران نمایش داده نخواهد شد.
                                    </div>
                                </div>
                            }
                            else
                            {
                                <div class="alert alert-secondary small mb-0">
                                    <i class="fas fa-lock me-1"></i>
                                    پرامپت قفل است. برای ویرایش، ابتدا ابزار را از بخش مدیریت تعلیق کنید.
                                </div>
                            }
                        </div>
                    </div>
                </div>

                <input type="hidden" id="fields-json-input" name="Form.FieldsJson" />

                <div class="d-flex justify-content-between mt-4">
                    <button type="button" class="btn btn-outline-secondary" onclick="goToStep(2)">
                        <i class="fas fa-arrow-right me-1"></i>قبلی
                    </button>
                    <button type="submit" class="btn btn-success px-4" onclick="serializeFields()">
                        <i class="fas fa-save me-1"></i>ذخیره تغییرات
                    </button>
                </div>
            </div>

        </form>
    </div>
</div>

@functions {
    string toPersianNum(int n) => System.Text.RegularExpressions.Regex.Replace(n.ToString(), @"\d",
        m => "۰۱۲۳۴۵۶۷۸۹"[int.Parse(m.Value)].ToString());
}

@section Styles {
    <style>
    .thumbnail-upload-box {
        border: 2px dashed var(--dk-border2);
        border-radius: 12px;
        aspect-ratio: 750 / 404;
        max-width: 480px;
        position: relative;
        cursor: pointer; overflow: hidden;
        transition: border-color .2s;
        background: var(--dk-surface2);
        color: var(--dk-muted2);
    }
    .thumbnail-upload-box:hover { border-color: var(--creator-accent); color: var(--dk-text); }
    .thumbnail-upload-box #thumbnail-preview {
        position: absolute; inset: 0;
        width: 100%; height: 100%; object-fit: cover;
    }
    .thumbnail-upload-box #thumbnail-placeholder {
        position: absolute; inset: 0;
        display: flex; flex-direction: column;
        align-items: center; justify-content: center;
        text-align: center;
    }
    .help-icon-btn:focus { outline: none; }
    .vt-chip {
        font-family: monospace; font-size: .7rem; padding: .18rem .45rem;
        border-radius: 6px; border: 1px solid rgba(99,102,241,.3);
        background: rgba(99,102,241,.1); color: #a5b4fc;
        cursor: pointer; transition: all .15s; white-space: nowrap;
    }
    .vt-chip:hover { background: rgba(99,102,241,.25); border-color: rgba(99,102,241,.55); color: #c7d2fe; }
    .vt-green  { border-color: rgba(34,197,94,.3)  !important; background: rgba(34,197,94,.08)  !important; color: #86efac !important; }
    .vt-green:hover  { background: rgba(34,197,94,.2)  !important; }
    .vt-yellow { border-color: rgba(234,179,8,.3)   !important; background: rgba(234,179,8,.08)  !important; color: #fde047 !important; }
    .vt-yellow:hover { background: rgba(234,179,8,.2)  !important; }
    .vt-red    { border-color: rgba(239,68,68,.3)   !important; background: rgba(239,68,68,.08)  !important; color: #fca5a5 !important; }
    .vt-red:hover    { background: rgba(239,68,68,.2)  !important; }
    </style>
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        var createPageData = { allModels: @Html.Raw(Model.ModelsJson) };
        var editPageData = {
            existingFields: @Html.Raw(Model.ExistingFieldsJson),
            canEditPrompt: @Html.Raw(Model.CanEditPrompt.ToString().ToLower()),
            selectedModelId: @Model.App.AiModelId
        };
    </script>
    <script src="~/js/pages/creator/apps/Create.js"></script>
    <script src="~/js/pages/creator/apps/Edit.js"></script>
    <script>
    document.getElementById('thumbnail-input').addEventListener('change', function() {
        var file = this.files[0];
        if (!file) return;
        var reader = new FileReader();
        reader.onload = function(e) {
            var img = document.getElementById('thumbnail-preview');
            var ph  = document.getElementById('thumbnail-placeholder');
            img.src = e.target.result;
            img.classList.remove('d-none');
            if (ph) ph.classList.add('d-none');
        };
        reader.readAsDataURL(file);
    });
    </script>
    <script>
    (function () {
        // ─── Calculator ───────────────────────────────────
        var FIELD_TOKENS = { Textarea: 300, Text: 50, Select: 5, Number: 5, Checkbox: 3 };
        var el = document.getElementById('creatorTokenCalc');
        if (el) {
            var promptTokens = Math.round((parseInt(el.dataset.prompt) || 0) / 3.5);
            var sysTokens    = Math.round((parseInt(el.dataset.sys)    || 0) / 3.5);
            var fields       = JSON.parse(el.dataset.fields || '[]');
            var fieldTokens  = fields.reduce(function (s, t) { return s + (FIELD_TOKENS[t] || 30); }, 0);
            var outputType   = (el.dataset.outputtype || '').toLowerCase();
            var creditCost   = parseInt(el.dataset.creditcost) || 0;
            var isMediaOutput = outputType === 'video' || outputType === 'audio' || outputType === 'image';

            document.getElementById('ctc-sys').textContent    = sysTokens.toLocaleString('fa-IR');
            document.getElementById('ctc-prompt').textContent = promptTokens.toLocaleString('fa-IR');
            document.getElementById('ctc-fields').textContent = fieldTokens.toLocaleString('fa-IR');

            if (isMediaOutput) {
                // Video/Audio/Image: token estimation is not meaningful — cost is API-based, not token-based
                var sliderRow = document.getElementById('ctc-slider');
                if (sliderRow) sliderRow.closest('tr').style.opacity = '0.35';
                document.getElementById('ctc-out').textContent = '—';
                document.getElementById('ctc-total').textContent = '—';
                var typeLabel = outputType === 'video' ? 'ویدیو' : outputType === 'audio' ? 'صدا' : 'تصویر';
                document.getElementById('ctc-credits').textContent = creditCost.toLocaleString('fa-IR') + ' اعتبار';
                var noteEl = document.querySelector('#creatorCalcBox .text-muted.small');
                if (noteEl) noteEl.textContent = 'هزینه ' + typeLabel + ' بر اساس API — از هزینه اجرای تنظیم‌شده استفاده می‌شود';
                var subEl = document.querySelector('#ctc-credits + div');
                if (subEl) subEl.textContent = 'اعتبار | هزینه ثابت API (نه توکن‌محور)';
            }

            window.updateCreatorCalc = function () {
                if (isMediaOutput) return;
                var outVal = parseInt(document.getElementById('ctc-slider').value) || 500;
                document.getElementById('ctc-out-lbl').textContent = outVal.toLocaleString('fa-IR');
                document.getElementById('ctc-out').textContent     = outVal.toLocaleString('fa-IR');
                var total   = sysTokens + promptTokens + fieldTokens + outVal;
                var credits = Math.ceil(total / 1000);
                document.getElementById('ctc-total').textContent   = total.toLocaleString('fa-IR');
                document.getElementById('ctc-credits').textContent = credits.toLocaleString('fa-IR') + ' اعتبار';
            };
            updateCreatorCalc();
        }

        // ─── Help Popovers ────────────────────────────────
        var helpData = {
            tokenStats: {
                title: '<i class="fas fa-microchip me-1 text-primary"></i> مصرف توکن واقعی',
                content: [
                    '<div style="font-size:.82rem;line-height:1.75;direction:rtl;text-align:right">',
                    '<p class="mb-2">این بخش آمار واقعی مصرف توکن در اجراهای موفق ابزار را نمایش می‌دهد. هر اجرای AI یک بار توکن مصرف می‌کند؛ هرچه توکن بیشتری مصرف شود، هزینه واقعی بیشتر است.</p>',
                    '<hr class="my-2">',
                    '<dl class="mb-0">',
                    '<dt class="mb-1">📊 میانگین توکن (کل)</dt>',
                    '<dd class="text-muted mb-2">میانگین تعداد توکن در <strong>تمام اجراهای موفق</strong> از ابتدا. هم توکن ورودی (پرامپت + فیلدها) و هم توکن خروجی (پاسخ AI) را شامل می‌شود.</dd>',
                    '<dt class="mb-1">📅 میانگین توکن (۳۰ روز)</dt>',
                    '<dd class="text-muted mb-2">میانگین <strong>۳۰ روز اخیر</strong>؛ نشان می‌دهد آیا مصرف در حال افزایش است یا کاهش. این عدد برای تصمیم‌گیری درباره تغییر هزینه اجرا مهم‌تر است.</dd>',
                    '<dt class="mb-1">💰 هزینه اعتبار</dt>',
                    '<dd class="text-muted mb-2">تعداد اعتباری که از کاربر برای هر اجرا دریافت می‌شود. استاندارد پلتفرم: <strong>هر ۱ اعتبار = ۱٬۰۰۰ توکن</strong>.</dd>',
                    '<dt class="mb-1">⚠️ هشدار زیان‌دهی</dt>',
                    '<dd class="text-muted mb-0">اگر میانگین ۳۰ روز از مقدار <em>(اعتبار × ۱۰۰۰)</em> بیشتر شود فعال می‌شود؛ یعنی درآمد اعتباری کافی نیست تا هزینه واقعی API را پوشش دهد.</dd>',
                    '</dl></div>'
                ].join('')
            },
            calculator: {
                title: '<i class="fas fa-calculator me-1 text-primary"></i> ماشین حساب تخمین توکن',
                content: [
                    '<div style="font-size:.82rem;line-height:1.75;direction:rtl;text-align:right">',
                    '<p class="mb-2">این ابزار تخمین می‌زند <strong>هر اجرای ابزار</strong> چه مقدار توکن مصرف می‌کند تا بتوانید هزینه اجرای مناسب تعیین کنید.</p>',
                    '<hr class="my-2">',
                    '<dl class="mb-0">',
                    '<dt class="mb-1">📝 System Context</dt>',
                    '<dd class="text-muted mb-2">متن System Context به توکن تبدیل می‌شود. فرمول: <strong>کاراکتر ÷ ۳.۵</strong>.</dd>',
                    '<dt class="mb-1">📄 پرامپت قالب</dt>',
                    '<dd class="text-muted mb-2">طول ثابت پرامپت ابزار. با همان فرمول کاراکتر ÷ ۳.۵ تخمین زده می‌شود.</dd>',
                    '<dt class="mb-1">🔢 فیلدهای ورودی</dt>',
                    '<dd class="text-muted mb-2">بر اساس نوع فیلد تخمین می‌زنیم کاربر چه مقدار تایپ می‌کند:<br>',
                    '<code>Textarea ≈ ۳۰۰</code> &nbsp; <code>Text ≈ ۵۰</code> &nbsp; <code>Select/Number ≈ ۵</code></dd>',
                    '<dt class="mb-1">🤖 خروجی تخمینی</dt>',
                    '<dd class="text-muted mb-2">توکن‌هایی که AI در پاسخ تولید می‌کند. با slider تنظیم کنید: پاسخ کوتاه ۳۰۰-۵۰۰، پاسخ بلند ۱۰۰۰-۲۰۰۰.</dd>',
                    '<dt class="mb-1">💡 هزینه پیشنهادی</dt>',
                    '<dd class="text-muted mb-0">فرمول: <strong>⌈مجموع ÷ ۱۰۰۰⌉</strong> اعتبار. حداقل هزینه‌ای که باید تنظیم کنید تا ابزار زیان‌ده نباشد.</dd>',
                    '</dl></div>'
                ].join('')
            }
        };

        document.querySelectorAll('.help-popover-btn').forEach(function (btn) {
            var id = btn.dataset.helpId;
            var data = helpData[id];
            if (!data) return;
            new bootstrap.Popover(btn, {
                html: true,
                title: data.title,
                content: data.content,
                trigger: 'click',
                placement: 'auto',
                customClass: 'help-popover'
            });
        });

        document.addEventListener('click', function (e) {
            if (!e.target.closest('.help-popover-btn') && !e.target.closest('.popover')) {
                document.querySelectorAll('.help-popover-btn').forEach(function (btn) {
                    var pop = bootstrap.Popover.getInstance(btn);
                    if (pop) pop.hide();
                });
            }
        });
    })();
    </script>
    <script>
    // ─── Video Tags Helper ─────────────────────────────────────────────────────
    function insertVideoTag(tag) {
        var ta = document.getElementById('prompt-textarea');
        if (!ta) return;
        var s = ta.selectionStart, e = ta.selectionEnd;
        ta.value = ta.value.substring(0, s) + tag + ta.value.substring(e);
        ta.selectionStart = ta.selectionEnd = s + tag.length;
        ta.focus();
        ta.dispatchEvent(new Event('input'));
    }
    function syncVideoTagsHelper() {
        var checked = document.querySelector('#output-type-selector input[type=radio]:checked');
        var isVideo = checked && checked.value === 'Video';
        var helper = document.getElementById('video-tags-helper');
        if (helper) helper.classList.toggle('d-none', !isVideo);
    }
    document.querySelectorAll('#output-type-selector input[type=radio]').forEach(function(r) {
        r.addEventListener('change', syncVideoTagsHelper);
    });
    // initialise based on current selection
    syncVideoTagsHelper();
    </script>
}
