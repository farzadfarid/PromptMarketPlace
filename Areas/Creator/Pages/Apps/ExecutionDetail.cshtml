@page "/Creator/Apps/Executions/{appId:int}/{id:long}"
@model ExecutionDetailModel
@using PromptMarketPlace.Models.Enums
@{ ViewData["Title"] = "جزئیات اجرا"; }

<div class="d-flex align-items-center gap-3 mb-4">
    <a asp-area="Creator" asp-page="/Apps/Executions" asp-route-appId="@Model.Execution.AppId"
       class="btn btn-sm btn-outline-secondary">
        <i class="fas fa-arrow-right me-1"></i>بازگشت به اجراها
    </a>
    <h5 class="fw-bold mb-0">@Model.Execution.App?.Title</h5>
    <span class="ms-auto">
        @{
            var (el, ec) = Model.Execution.Status switch {
                ExecutionStatus.Completed => ("موفق",     "success"),
                ExecutionStatus.Failed    => ("ناموفق",   "danger"),
                ExecutionStatus.Refunded  => ("بازگشتی",  "info"),
                _                         => ("در جریان", "warning")
            };
        }
        <span class="badge bg-@ec fs-6">@el</span>
    </span>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="card border-0 shadow-sm p-3 text-center">
            <div class="small text-muted mb-1">کاربر</div>
            @{ var _avU = Model.Execution.User?.AvatarUrl; var _dnU = Model.Execution.User?.DisplayName ?? "—"; }
            @if (!string.IsNullOrEmpty(_avU))
            {
                <img src="@_avU" class="rounded-circle mb-1 mx-auto d-block" style="width:32px;height:32px;object-fit:cover;" alt="@_dnU" />
            }
            else
            {
                <div class="rounded-circle bg-secondary text-white d-inline-flex align-items-center justify-content-center mb-1 mx-auto" style="width:32px;height:32px;font-size:.7rem;">@_dnU.FirstOrDefault()</div>
            }
            <div class="fw-semibold small">@_dnU</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm p-3 text-center">
            <div class="small text-muted mb-1">تاریخ اجرا</div>
            <div class="fw-semibold small">@Model.Execution.CreatedAt.ToShamsi("yyyy/MM/dd HH:mm:ss")</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm p-3 text-center">
            <div class="small text-muted mb-1">اعتبار مصرف‌شده</div>
            <div class="fw-bold fs-5 text-primary">@Model.Execution.CreditUsed.N0Fa()</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm p-3 text-center">
            <div class="small text-muted mb-1">توکن‌ها</div>
            <div class="fw-semibold">@(Model.Execution.TokensUsed?.N0Fa() ?? "-")</div>
        </div>
    </div>
</div>

@if (Model.Execution.InputValues.Any(i => !i.FieldName.StartsWith("__")))
{
    <div class="card border-0 shadow-sm p-4 mb-4">
        <h6 class="fw-semibold mb-3"><i class="fas fa-keyboard me-2 text-muted"></i>ورودی‌های کاربر</h6>
        <dl class="row mb-0">
            @foreach (var input in Model.Execution.InputValues.Where(i => !i.FieldName.StartsWith("__")))
            {
                var field = Model.Execution.App?.InputFields.FirstOrDefault(f => f.Name == input.FieldName);
                var val = (input.FieldValue ?? "").TrimEnd('/');
                var isUpload = val.StartsWith("/uploads/") || val.StartsWith("uploads/");
                var src = isUpload ? (val.StartsWith("/") ? val : "/" + val) : null;
                var isImage = src != null && System.Text.RegularExpressions.Regex.IsMatch(val, @"\.(jpg|jpeg|png|webp|gif)$", System.Text.RegularExpressions.RegexOptions.IgnoreCase);
                var isAudio = src != null && System.Text.RegularExpressions.Regex.IsMatch(val, @"\.(mp3|wav|ogg|m4a|aac)$", System.Text.RegularExpressions.RegexOptions.IgnoreCase);
                var isVideo = src != null && System.Text.RegularExpressions.Regex.IsMatch(val, @"\.(mp4|webm|mov)$", System.Text.RegularExpressions.RegexOptions.IgnoreCase);
                <dt class="col-sm-3 small text-muted">@(field?.Label ?? input.FieldName)</dt>
                <dd class="col-sm-9 small">
                    @if (isImage)
                    {
                        <img src="@src" alt="@(field?.Label ?? input.FieldName)"
                             style="max-height:160px;max-width:100%;border-radius:8px;object-fit:contain;" />
                    }
                    else if (isAudio)
                    {
                        <audio controls class="w-100" style="border-radius:8px;"><source src="@src" /></audio>
                        <a href="@src" download class="btn btn-outline-secondary btn-sm mt-1">
                            <i class="fas fa-download me-1"></i>دانلود
                        </a>
                    }
                    else if (isVideo)
                    {
                        <video controls style="max-width:100%;max-height:240px;border-radius:8px;">
                            <source src="@src" type="video/mp4" />
                        </video>
                        <a href="@src" download class="btn btn-outline-secondary btn-sm mt-1">
                            <i class="fas fa-download me-1"></i>دانلود
                        </a>
                    }
                    else
                    {
                        @val
                    }
                </dd>
            }
        </dl>
    </div>
}

@await Html.PartialAsync("_OutputRenderer", Model.Execution)
