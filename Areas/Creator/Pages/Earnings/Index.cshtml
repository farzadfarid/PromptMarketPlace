@page
@model IndexModel
@{ ViewData["Title"] = "درآمد و برداشت"; }

@if (TempData["Success"] != null) { <div class="alert alert-success alert-dismissible fade show">@TempData["Success"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div> }
@if (TempData["Error"] != null) { <div class="alert alert-danger alert-dismissible fade show">@TempData["Error"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div> }

<div class="row g-4 mb-4">
    <div class="col-md-4">
        <div class="card border-0 shadow-sm p-4 text-center">
            <div class="small text-muted mb-1">موجودی قابل برداشت</div>
            <div class="fs-3 fw-bold text-success">@(Model.Wallet?.EarningBalance.N0Fa() ?? "0") ریال</div>
            <button class="btn btn-outline-success btn-sm mt-3" data-bs-toggle="modal" data-bs-target="#withdrawModal">
                <i class="fas fa-money-bill me-1"></i>درخواست برداشت
            </button>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 shadow-sm p-4 text-center">
            <div class="small text-muted mb-1">کل درآمد تاریخی</div>
            <div class="fs-3 fw-bold text-primary">@(Model.Wallet?.TotalEarned.N0Fa() ?? "0") ریال</div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 shadow-sm p-4 text-center">
            <div class="small text-muted mb-1">کل برداشت‌ها</div>
            <div class="fs-3 fw-bold">@(Model.Wallet?.TotalWithdrawn.N0Fa() ?? "0") ریال</div>
        </div>
    </div>
</div>

<div class="row g-4">
    <div class="col-lg-7">
        <div class="card border-0 shadow-sm p-4">
            <h6 class="fw-semibold mb-3">تاریخچه درآمد</h6>
            <div class="table-responsive">
                <table class="table table-sm table-hover mb-0">
                    <thead class="table-light"><tr><th>توضیح</th><th class="text-end">مبلغ (ریال)</th><th>تاریخ</th></tr></thead>
                    <tbody>
                        @foreach (var t in Model.EarnTransactions)
                        {
                            <tr>
                                <td class="small">@t.Description</td>
                                <td class="text-end text-success fw-semibold small">+@(t.MoneyAmount?.N0Fa())</td>
                                <td class="text-muted small">@t.CreatedAt.ToShamsi("yy/MM/dd")</td>
                            </tr>
                        }
                    </tbody>
                </table>
                @if (!Model.EarnTransactions.Any())
                { <p class="text-center text-muted small py-3">هنوز درآمدی ثبت نشده.</p> }
            </div>
        </div>
    </div>
    <div class="col-lg-5">
        <div class="card border-0 shadow-sm p-4">
            <h6 class="fw-semibold mb-3">درخواست‌های برداشت</h6>
            @foreach (var w in Model.WithdrawalRequests)
            {
                var (badge, color) = w.Status switch {
                    WithdrawalStatus.Paid => ("پرداخت شد", "success"),
                    WithdrawalStatus.Approved => ("تأیید شده", "primary"),
                    WithdrawalStatus.Rejected => ("رد شد", "danger"),
                    _ => ("در انتظار", "warning")
                };
                <div class="d-flex justify-content-between align-items-center mb-2 pb-2 border-bottom">
                    <div>
                        <div class="fw-semibold small">@w.Amount.N0Fa() ریال</div>
                        <div class="text-muted" style="font-size:.72rem;">@w.CreatedAt.ToShamsi("yy/MM/dd")</div>
                    </div>
                    <span class="badge bg-@color">@badge</span>
                </div>
            }
            @if (!Model.WithdrawalRequests.Any())
            { <p class="text-muted small text-center py-3">درخواستی ثبت نشده.</p> }
        </div>
    </div>
</div>

<!-- Modal -->
<div class="modal fade" id="withdrawModal" tabindex="-1">
    <div class="modal-dialog">
        <form method="post" asp-page-handler="Withdraw">
            <div class="modal-content">
                <div class="modal-header"><h6 class="modal-title">درخواست برداشت</h6><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">مبلغ (ریال) <span class="text-danger">*</span></label>
                        <input asp-for="Form.Amount" type="number" class="form-control" dir="ltr" />
                        <span asp-validation-for="Form.Amount" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">شماره شبا <span class="text-danger">*</span></label>
                        <input asp-for="Form.Sheba" class="form-control" dir="ltr" placeholder="IR000000000000000000000000" />
                        <span asp-validation-for="Form.Sheba" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">نام صاحب حساب <span class="text-danger">*</span></label>
                        <input asp-for="Form.AccountOwner" class="form-control" />
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">انصراف</button>
                    <button type="submit" class="btn btn-success btn-sm">ثبت درخواست</button>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
