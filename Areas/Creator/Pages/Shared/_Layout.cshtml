@inject PromptMarketPlace.Services.Interfaces.IMessageService _msgSvc
@inject PromptMarketPlace.Services.Interfaces.ICreatorHelper _ch
@inject PromptMarketPlace.Services.Interfaces.IReviewService _reviewSvc
@inject PromptMarketPlace.Services.Interfaces.INotificationService _notifSvc
@using System.Security.Claims
@{
    var _cid = await _ch.GetCreatorProfileIdAsync(User);
    var _creatorUnread = _cid.HasValue ? await _msgSvc.UnreadCountAsync(forAdmin: false, creatorProfileId: _cid.Value) : 0;
    var _creatorUserId = User.FindFirstValue(ClaimTypes.NameIdentifier) ?? "";
    var _creatorNotifItems = _creatorUserId != "" ? await _notifSvc.GetRecentAsync(_creatorUserId, 10) : new();
    var _creatorNotifUnread = _creatorUserId != "" ? await _notifSvc.GetUnreadCountAsync(_creatorUserId) : 0;
}
<!DOCTYPE html>
<html lang="fa" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - پنل سازنده</title>
    <link href="~/css/vazirmatn.css" rel="stylesheet" />
    <link href="~/css/bootstrap5-3-3.css" rel="stylesheet" />
    <link href="~/css/font-awesome.css" rel="stylesheet" />
    <link href="~/css/site.css" rel="stylesheet" />
    <link href="~/css/pages/creator/creator-layout.css" rel="stylesheet" />
    <link href="~/css/notification-bell.css" rel="stylesheet" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body class="creator-layout">
<div class="sidebar-backdrop" id="sidebarBackdrop"></div>
<div class="creator-shell">

    <!-- Sidebar -->
    <aside class="creator-sidebar" id="creatorSidebar">
        <div class="creator-sidebar__header">
            <div class="creator-brand">
                <img src="~/images/logo.png" alt="Prompt Market Place" class="creator-brand__logo" />
                <div class="creator-brand__label-only">پنل سازنده</div>
            </div>
        </div>

        <nav class="creator-nav">
            <a class="creator-nav__item @(ViewContext.RouteData.Values["page"]?.ToString()?.Contains("Dashboard") == true ? "active" : "")"
               asp-area="Creator" asp-page="/Dashboard/Index">
                <i class="fas fa-chart-line"></i><span>داشبورد</span>
            </a>

            <div class="creator-nav__section">ابزارهای من</div>
            <a class="creator-nav__item @(ViewContext.RouteData.Values["page"]?.ToString() == "/Apps/Index" ? "active" : "")"
               asp-area="Creator" asp-page="/Apps/Index">
                <i class="fas fa-th-large"></i><span>لیست ابزارها</span>
            </a>
            <a class="creator-nav__item @(ViewContext.RouteData.Values["page"]?.ToString()?.Contains("Create") == true ? "active" : "")"
               asp-area="Creator" asp-page="/Apps/Create">
                <i class="fas fa-plus-circle"></i><span>ابزار جدید</span>
                <span class="creator-nav__badge">جدید</span>
            </a>

            <div class="creator-nav__section">مالی</div>
            <a class="creator-nav__item @(ViewContext.RouteData.Values["page"]?.ToString()?.Contains("Earnings") == true ? "active" : "")"
               asp-area="Creator" asp-page="/Earnings/Index">
                <i class="fas fa-money-bill-wave"></i><span>درآمد و برداشت</span>
            </a>

            <div class="creator-nav__section">نظرات کاربران</div>
            @{ var _pendingReviews = _cid.HasValue ? await _reviewSvc.GetPendingCountForCreatorAsync(_cid.Value) : 0; }
            <a class="creator-nav__item @(ViewContext.RouteData.Values["page"]?.ToString()?.Contains("Reviews") == true ? "active" : "")"
               asp-area="Creator" asp-page="/Reviews/Index">
                <i class="fas fa-star"></i><span>نظرات</span>
                @if (_pendingReviews > 0)
                {
                    <span class="creator-nav__badge" style="background:#f59e0b;">@_pendingReviews</span>
                }
            </a>

            <div class="creator-nav__section">ارتباط با ادمین</div>
            <a class="creator-nav__item @(ViewContext.RouteData.Values["page"]?.ToString()?.Contains("Messages") == true ? "active" : "")"
               asp-area="Creator" asp-page="/Messages/Index">
                <i class="fas fa-comments"></i><span>پیام‌ها</span>
                @if (_creatorUnread > 0)
                {
                    <span class="creator-nav__badge" style="background:#ef4444;">@_creatorUnread</span>
                }
            </a>

            <div class="creator-nav__section">حساب کاربری</div>
            <a class="creator-nav__item @(ViewContext.RouteData.Values["page"]?.ToString()?.Contains("Profile") == true ? "active" : "")"
               asp-area="Creator" asp-page="/Profile/Edit">
                <i class="fas fa-user-edit"></i><span>ویرایش پروفایل</span>
            </a>
        </nav>

        <div class="creator-sidebar__footer">
            <a href="/" class="creator-sidebar__back">
                <i class="fas fa-arrow-right"></i>بازگشت به سایت
            </a>
            <form method="post" asp-area="" asp-page="/Auth/Logout" class="mt-2">
                <button type="submit" class="creator-sidebar__logout">
                    <i class="fas fa-arrow-right-from-bracket"></i>خروج از حساب
                </button>
            </form>
        </div>
    </aside>

    <!-- Main -->
    <div class="creator-main">
        <header class="creator-topbar">
            <div class="creator-topbar__title d-flex align-items-center gap-2">
                <button class="sidebar-toggle d-md-none" id="sidebarToggle" aria-label="منو">
                    <i class="fas fa-bars"></i>
                </button>
                <h6 class="mb-0 fw-semibold">@ViewData["Title"]</h6>
            </div>
            <div class="creator-topbar__actions">
                <a href="/" class="btn btn-sm btn-ghost d-none d-md-inline-flex align-items-center gap-2">
                    <i class="fas fa-external-link-alt fa-xs"></i>مشاهده سایت
                </a>

                <!-- زنگ اعلان -->
                <div class="notif-bell-wrap" id="notifBellWrap">
                    <button class="notif-bell-btn @(_creatorNotifUnread > 0 ? "has-unread" : "")"
                            id="notifBellBtn" type="button" aria-label="اعلان‌ها">
                        <i class="fas fa-bell"></i>
                        <span class="notif-badge @(_creatorNotifUnread == 0 ? "hidden" : "pulse")" id="notifBadge">
                            @(_creatorNotifUnread > 99 ? "۹۹+" : _creatorNotifUnread.ToString().Replace("0","۰").Replace("1","۱").Replace("2","۲").Replace("3","۳").Replace("4","۴").Replace("5","۵").Replace("6","۶").Replace("7","۷").Replace("8","۸").Replace("9","۹"))
                        </span>
                    </button>
                    <div class="notif-dropdown" id="notifDropdown">
                        <div class="notif-dropdown__header">
                            <span class="notif-dropdown__title">اعلان‌ها</span>
                            <button class="notif-mark-all-btn" id="notifMarkAll" type="button">همه خوانده شد</button>
                        </div>
                        <div class="notif-list" id="notifList">
                            @if (!_creatorNotifItems.Any())
                            {
                                <div class="notif-empty"><i class="fas fa-bell-slash"></i>اعلانی وجود ندارد</div>
                            }
                            else
                            {
                                @foreach (var n in _creatorNotifItems)
                                {
                                    var catIcon = n.Category switch {
                                        "app_review"  => "fa-clipboard-check",
                                        "app_status"  => "fa-check-circle",
                                        "open_prompt" => "fa-lock-open",
                                        "review"      => "fa-star",
                                        "withdrawal"  => "fa-money-bill-wave",
                                        _             => "fa-bell"
                                    };
                                    <div class="notif-item @(n.IsRead ? "" : "unread")" data-cat="@n.Category"
                                         @(n.Link != null ? $"onclick=\"location.href='{n.Link}'\"" : "")>
                                        <div class="notif-icon"><i class="fas @catIcon"></i></div>
                                        <div class="notif-item__body">
                                            <div class="notif-item__title">@n.Title</div>
                                            @if (!string.IsNullOrEmpty(n.Message))
                                            {
                                                <div class="notif-item__msg">@n.Message</div>
                                            }
                                            <div class="notif-item__time" data-time="@n.CreatedAt.ToString("o")">
                                                @n.CreatedAt.ToShamsi("yyyy/MM/dd HH:mm")
                                            </div>
                                        </div>
                                    </div>
                                }
                            }
                        </div>
                    </div>
                </div>

                <div class="creator-topbar__badge">
                    <i class="fas fa-star text-warning me-1"></i>
                    <span class="small fw-medium">سازنده</span>
                </div>
            </div>
        </header>

        <main class="creator-content">
            @RenderBody()
        </main>
    </div>
</div>

<script src="~/js/jquery-3.7.1.js"></script>
<script src="~/js/bootstrap5-3-3.js"></script>
<script src="~/js/chart.umd.min.js"></script>
<link rel="stylesheet" href="~/css/confirm-dialog.css" />
<script src="~/js/confirm-dialog.js"></script>
<script src="~/js/notification-bell.js"></script>
<script>
document.addEventListener('DOMContentLoaded', function () {
    document.querySelectorAll('.validation-summary-valid').forEach(function (ul) {
        var a = ul.closest('.alert'); if (a) a.style.display = 'none';
    });
});
(function(){
    var toggle = document.getElementById('sidebarToggle');
    var sidebar = document.getElementById('creatorSidebar');
    var backdrop = document.getElementById('sidebarBackdrop');
    if (!toggle) return;
    function open(){ sidebar.classList.add('open'); backdrop.classList.add('show'); }
    function close(){ sidebar.classList.remove('open'); backdrop.classList.remove('show'); }
    toggle.addEventListener('click', open);
    backdrop.addEventListener('click', close);
})();
</script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
