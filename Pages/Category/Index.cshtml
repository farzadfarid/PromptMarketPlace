@page "/category/{slug}"
@model IndexModel
@{ ViewData["Title"] = Model.Category.Name; }

<div class="container py-5">
    <div class="d-flex align-items-center gap-3 mb-5">
        <div class="rounded-circle bg-primary bg-opacity-10 d-flex align-items-center justify-content-center"
             style="width:56px;height:56px;">
            <i class="@(Model.Category.IconClass ?? "fas fa-cube") text-primary fa-lg"></i>
        </div>
        <div>
            <h3 class="fw-bold mb-0">@Model.Category.Name</h3>
            @if (!string.IsNullOrEmpty(Model.Category.Description))
            {
                <p class="text-muted mb-0">@Model.Category.Description</p>
            }
        </div>
    </div>

    @if (!Model.Result.Items.Any())
    {
        <div class="text-center py-5 text-muted">
            <p>هنوز ابزاری در این دسته‌بندی منتشر نشده است.</p>
        </div>
    }
    else
    {
        <div class="row g-3">
            @foreach (var app in Model.Result.Items)
            {
                <div class="col-md-6 col-lg-4 col-xl-3">
                    @await Html.PartialAsync("_AppCard", app)
                </div>
            }
        </div>
    }
</div>
