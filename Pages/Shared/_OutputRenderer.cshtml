@model AppExecution

@if (Model == null) { return; }

@if (Model.Status == ExecutionStatus.Failed)
{
    <div class="alert alert-danger mt-4">
        <i class="fas fa-exclamation-circle me-2"></i>
        <strong>اجرا ناموفق بود:</strong>
        @(Model.ErrorMessage ?? "خطای ناشناخته")
    </div>
    return;
}

<div class="output-result output-card mt-0">
    <div class="output-card-header">
        <div class="output-card-title">
            <i class="fas fa-check-circle"></i>
            نتیجه اجرا
        </div>
        <small class="text-muted">@Model.CreatedAt.ToShamsi("HH:mm")</small>
    </div>

    @if (Model.OutputType == OutputType.Text || Model.OutputType == OutputType.Form)
    {
        <div class="output-text-area" id="outputTextContent">@Model.OutputText</div>
        <div class="output-actions">
            <button class="btn btn-outline-secondary btn-sm" onclick="copyOutput()">
                <i class="fas fa-copy me-1"></i>کپی
            </button>
            <button class="btn btn-outline-danger btn-sm" id="pdfBtn" onclick="downloadPdf()">
                <i class="fas fa-file-pdf me-1"></i>دانلود PDF
            </button>
        </div>
    }
    else if (Model.OutputType == OutputType.Code)
    {
        <div class="position-relative">
            <pre class="output-text-area" style="font-family:monospace;font-size:.88rem;max-height:500px;overflow:auto;"><code id="outputCode">@Model.OutputText</code></pre>
            <button class="btn btn-sm btn-outline-secondary position-absolute top-0 start-0 m-2"
                    onclick="copyOutput()">
                <i class="fas fa-copy me-1"></i>کپی کد
            </button>
        </div>
    }
    else if (Model.OutputType == OutputType.Image && !string.IsNullOrEmpty(Model.OutputImageUrl))
    {
        <div class="text-center" id="imgWrapper">
            <img src="@Model.OutputImageUrl"
                 class="output-img img-fluid"
                 style="max-width:100%;height:auto;max-height:600px;border-radius:12px;display:block;margin:0 auto;"
                 alt="خروجی تصویر"
                 loading="lazy"
                 onerror="this.closest('#imgWrapper').innerHTML='<div class=\'alert alert-warning py-2\'><i class=\'fas fa-image-slash me-1\'></i>تصویر در دسترس نیست یا منقضی شده است.</div>'" />
        </div>
        <div class="output-actions justify-content-center mt-3">
            <a href="@Model.OutputImageUrl" download class="btn btn-outline-primary btn-sm">
                <i class="fas fa-download me-1"></i>دانلود تصویر
            </a>
        </div>
    }
    else if (Model.OutputType == OutputType.Image && string.IsNullOrEmpty(Model.OutputImageUrl))
    {
        <div class="alert alert-warning py-2">
            <i class="fas fa-exclamation-triangle me-1"></i>
            تصویر ذخیره نشد. لطفاً ابزار را مجدداً اجرا کنید.
        </div>
    }
    else if (Model.OutputType == OutputType.Video && !string.IsNullOrEmpty(Model.OutputVideoUrl))
    {
        var isLocalVideo = Model.OutputVideoUrl!.StartsWith("/uploads/");
        <video controls class="output-video" preload="auto">
            <source src="@Model.OutputVideoUrl" type="video/mp4" />
        </video>
        @if (!isLocalVideo)
        {
            <div class="alert alert-warning mt-2 py-2 small">
                <i class="fas fa-exclamation-triangle me-1"></i>
                ویدیو روی سرور ذخیره نشده — لینک موقت است و ممکن است منقضی شود.
            </div>
        }
        <div class="output-actions justify-content-center">
            <a href="@Model.OutputVideoUrl" download class="btn btn-outline-primary btn-sm">
                <i class="fas fa-download me-1"></i>دانلود ویدیو
            </a>
        </div>
    }
    else if (Model.OutputType == OutputType.Audio && !string.IsNullOrEmpty(Model.OutputAudioUrl))
    {
        <audio controls class="w-100" style="border-radius:8px;">
            <source src="@Model.OutputAudioUrl" />
        </audio>
        <div class="output-actions">
            <a href="@Model.OutputAudioUrl" download class="btn btn-outline-primary btn-sm">
                <i class="fas fa-download me-1"></i>دانلود صدا
            </a>
        </div>
    }
    else
    {
        <div class="alert alert-warning">خروجی در دسترس نیست.</div>
    }

    @if (Model.TokensUsed.HasValue)
    {
        <div class="output-meta">
            <span><i class="fas fa-microchip me-1"></i>@Model.TokensUsed.Value.N0Fa() توکن</span>
            <span><i class="fas fa-coins me-1"></i>@Model.CreditUsed اعتبار مصرف شد</span>
        </div>
    }
</div>

<script src="~/js/shared/output-renderer.js"></script>
