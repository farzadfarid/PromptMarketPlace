@page "/app/{slug}"
@model DetailModel
@using System.Security.Claims
@{ ViewData["Title"] = Model.App.Title; }

<canvas id="stars-canvas" aria-hidden="true"></canvas>

<div class="dp container py-4" style="position:relative;z-index:1;">
    <div class="row g-4">

        <!-- اطلاعات ابزار + خروجی + فرم -->
        <div class="col-lg-8">

            <!-- هدر ابزار -->
            <div class="app-header d-flex gap-3">
                @if (!string.IsNullOrEmpty(Model.App.ThumbnailUrl))
                {
                    <img src="@Model.App.ThumbnailUrl" class="app-thumb" alt="@Model.App.Title" />
                }
                else
                {
                    <div class="app-thumb d-flex align-items-center justify-content-center"
                         style="background:rgba(249,115,22,.12);border:2px solid rgba(249,115,22,.25);border-radius:14px;width:72px;height:72px;flex-shrink:0;">
                        <i class="fas fa-robot fa-xl" style="color:#f97316;"></i>
                    </div>
                }
                <div class="flex-grow-1">
                    <div class="d-flex align-items-start gap-2 flex-wrap mb-1">
                        <h3 class="app-title mb-0">@Model.App.Title</h3>
                        <span class="badge bg-secondary-subtle border border-secondary-subtle">
                            @Model.App.OutputType
                        </span>
                        @if (Model.App.IsPromptPublic)
                        {
                            <span class="badge" style="background:rgba(99,102,241,.15);border:1px solid rgba(99,102,241,.35);color:#818cf8;">
                                <i class="fas fa-lock-open me-1"></i>پرامپت باز
                            </span>
                        }
                    </div>
                    <p class="app-desc mb-2">@Model.App.ShortDescription</p>
                    <div class="d-flex gap-2 flex-wrap">
                        <span class="app-stat"><i class="fas fa-play-circle text-primary"></i>@Model.App.ExecutionCount.N0Fa() اجرا</span>
                        <span class="app-stat"><i class="fas fa-star" style="color:#f59e0b;"></i>@Model.App.AverageRating.ToFarsiDigits("0.0")</span>
                        <span class="app-stat"><i class="fas fa-coins text-primary"></i>@Model.App.CreditCost.ToFarsiDigits() اعتبار / اجرا</span>
                    </div>
                </div>
            </div>

            <!-- خطا -->
            @if (!string.IsNullOrEmpty(Model.RunError))
            {
                <div class="alert alert-danger mb-3">
                    <i class="fas fa-exclamation-circle me-2"></i>@Model.RunError
                </div>
            }

            <!-- خروجی آخرین اجرا -->
            @if (Model.LastExecution != null)
            {
                @await Html.PartialAsync("_OutputRenderer", Model.LastExecution)
                <div id="inputPreviewContainer" class="d-none input-preview-strip"></div>
            }

            <!-- Skeleton Loading (hidden by default, shown via JS) -->
            <div id="outputSkeleton" class="output-card d-none" style="margin-bottom:1.5rem;">
                <div class="output-card-header">
                    <div class="output-card-title" style="color:#6b7fa0;">
                        <span class="skel-status-icon"></span>
                        <span id="skelLabel">در حال پردازش...</span>
                    </div>
                </div>

                <!-- Text skeleton -->
                <div id="skelText" class="d-none skel-lines">
                    <div class="skel skel-line" style="width:100%;"></div>
                    <div class="skel skel-line" style="width:88%;"></div>
                    <div class="skel skel-line" style="width:100%;"></div>
                    <div class="skel skel-line" style="width:72%;"></div>
                    <div class="skel skel-line" style="width:93%;"></div>
                    <div class="skel skel-line" style="width:56%;"></div>
                </div>

                <!-- Image skeleton -->
                <div id="skelImage" class="d-none">
                    <div class="skel skel-image"></div>
                </div>

                <!-- Video skeleton -->
                <div id="skelVideo" class="d-none">
                    <div class="skel-video-wrap">
                        <div class="skel-video-shimmer"></div>
                        <i class="fas fa-film skel-video-icon"></i>
                        <div class="skel-video-label">در حال تولید ویدیو...</div>
                        <div class="skel-dots">
                            <span></span><span></span><span></span>
                        </div>
                        <div class="skel-video-eta">
                            <i class="fas fa-clock me-1"></i>معمولاً ۴ تا ۸ دقیقه طول می‌کشد
                        </div>
                    </div>
                </div>

                <!-- Audio skeleton -->
                <div id="skelAudio" class="d-none">
                    <div class="skel-audio-wrap">
                        <i class="fas fa-music skel-audio-icon"></i>
                        <div class="skel-waveform">
                            <div class="skel-waveform-bar"></div>
                            <div class="skel-waveform-bar"></div>
                            <div class="skel-waveform-bar"></div>
                            <div class="skel-waveform-bar"></div>
                            <div class="skel-waveform-bar"></div>
                            <div class="skel-waveform-bar"></div>
                            <div class="skel-waveform-bar"></div>
                            <div class="skel-waveform-bar"></div>
                            <div class="skel-waveform-bar"></div>
                            <div class="skel-waveform-bar"></div>
                            <div class="skel-waveform-bar"></div>
                            <div class="skel-waveform-bar"></div>
                        </div>
                    </div>
                </div>

                <!-- Code skeleton -->
                <div id="skelCode" class="d-none">
                    <div class="skel skel-code"></div>
                </div>
            </div>

            <!-- فرم اجرا -->
            <div class="card border-0 p-4 mb-4">
                <h5 class="fw-semibold mb-3">
                    <i class="fas fa-play me-2 text-primary"></i>اجرای ابزار
                </h5>

                @if (!User.Identity!.IsAuthenticated)
                {
                    <div class="alert alert-info d-flex align-items-center gap-3">
                        <i class="fas fa-info-circle fa-lg"></i>
                        <div>
                            برای استفاده از این ابزار باید وارد حساب خود شوید.
                            <div class="mt-2">
                                <a asp-page="/Auth/Login" asp-route-returnUrl="@($"/app/{Model.App.Slug}")"
                                   class="btn btn-primary btn-sm me-2">ورود</a>
                                <a asp-page="/Auth/Register" class="btn btn-outline-primary btn-sm">ثبت‌نام رایگان</a>
                            </div>
                        </div>
                    </div>
                }
                else
                {
                    <form method="post" asp-page-handler="Run" enctype="multipart/form-data"
                          id="runForm" data-output-type="@Model.App.OutputType.ToString().ToLower()">
                        @foreach (var field in Model.App.InputFields)
                        {
                            <div class="mb-3">
                                <label class="form-label fw-semibold">
                                    @field.Label
                                    @if (field.IsRequired) { <span class="text-danger">*</span> }
                                </label>

                                @{ var savedVal = Model.Inputs.GetValueOrDefault(field.Name, ""); }
                                @if (field.Type == FieldType.Textarea)
                                {
                                    <textarea name="Inputs[@field.Name]" class="form-control"
                                              rows="3" placeholder="@field.Placeholder"
                                              @(field.IsRequired ? "required" : "")
                                              maxlength="@(field.MaxLength ?? 2000)">@savedVal</textarea>
                                }
                                else if (field.Type == FieldType.Select && field.Options != null)
                                {
                                    List<string> options;
                                    try {
                                        var objs = System.Text.Json.JsonSerializer.Deserialize<List<System.Text.Json.JsonElement>>(field.Options) ?? new();
                                        options = objs.Select(o => o.ValueKind == System.Text.Json.JsonValueKind.String
                                            ? o.GetString() ?? ""
                                            : (o.TryGetProperty("label", out var lbl) ? lbl.GetString() ?? "" :
                                               o.TryGetProperty("value", out var val) ? val.GetString() ?? "" : "")
                                        ).Where(s => s != "").ToList();
                                    } catch { options = new(); }
                                    <select name="Inputs[@field.Name]" class="form-select"
                                            @(field.IsRequired ? "required" : "")>
                                        <option value="">انتخاب کنید...</option>
                                        @foreach (var opt in options)
                                        {
                                            if (opt == savedVal)
                                            { <option value="@opt" selected>@opt</option> }
                                            else
                                            { <option value="@opt">@opt</option> }
                                        }
                                    </select>
                                }
                                else if (field.Type == FieldType.ImageSelect && field.Options != null)
                                {
                                    var imgOpts = new List<(string label, string val, string image)>();
                                    try {
                                        var els = System.Text.Json.JsonSerializer.Deserialize<List<System.Text.Json.JsonElement>>(field.Options) ?? new();
                                        foreach (var el in els)
                                        {
                                            var lbl = el.TryGetProperty("label", out var lp) ? lp.GetString() ?? "" : "";
                                            var v   = el.TryGetProperty("value", out var vp) ? vp.GetString() ?? lbl : lbl;
                                            var img = el.TryGetProperty("image", out var ip) ? ip.GetString() ?? "" : "";
                                            if (!string.IsNullOrEmpty(lbl)) imgOpts.Add((lbl, v, img));
                                        }
                                    } catch { }
                                    <div class="img-select-grid">
                                        @foreach (var opt in imgOpts)
                                        {
                                            var isSelected = opt.val == savedVal || opt.label == savedVal;
                                            <label class="img-select-card @(isSelected ? "selected" : "")">
                                                <input type="radio" name="Inputs[@field.Name]" value="@opt.val"
                                                       class="d-none" @(isSelected ? "checked" : "")
                                                       @(field.IsRequired ? "required" : "") />
                                                @if (!string.IsNullOrEmpty(opt.image))
                                                {
                                                    <img src="@opt.image" alt="@opt.label" loading="lazy" />
                                                }
                                                else
                                                {
                                                    <div class="img-select-placeholder"><i class="fas fa-image"></i></div>
                                                }
                                                <div class="is-label">@opt.label</div>
                                            </label>
                                        }
                                    </div>
                                }
                                else if (field.Type == FieldType.Number)
                                {
                                    <input type="number" name="Inputs[@field.Name]" class="form-control"
                                           placeholder="@field.Placeholder" dir="ltr" value="@savedVal"
                                           @(field.IsRequired ? "required" : "") />
                                }
                                else if (field.Type == FieldType.Checkbox)
                                {
                                    <div class="form-check">
                                        <input type="checkbox" name="Inputs[@field.Name]" value="true"
                                               class="form-check-input" id="field_@field.Id"
                                               @(savedVal == "true" ? "checked" : "") />
                                        <label class="form-check-label" for="field_@field.Id">@field.HelpText</label>
                                    </div>
                                }
                                else if (field.Type == FieldType.AudioUpload)
                                {
                                    <div class="upload-drop-area border border-2 rounded-3 p-3 text-center"
                                         id="uploadArea_@field.Name"
                                         style="border-style:dashed!important;cursor:pointer;transition:all .2s;"
                                         onclick="document.getElementById('file_@field.Name').click()"
                                         data-required="@(field.IsRequired ? "true" : "false")"
                                         data-fieldname="@field.Name"
                                         data-filetype="audio">
                                        <div id="uploadPlaceholder_@field.Name">
                                            <i class="fas fa-microphone fa-2x text-muted mb-2"></i>
                                            <div class="small text-muted">برای آپلود کلیک کنید یا فایل صوتی را اینجا رها کنید</div>
                                            <div class="text-muted" style="font-size:.72rem;">MP3، WAV، M4A، OGG — حداکثر ۵۰ مگابایت</div>
                                        </div>
                                        <div id="uploadPreview_@field.Name" class="d-none py-2">
                                            <i class="fas fa-music fa-2x mb-2" style="color:#f97316;"></i>
                                            <div class="small fw-semibold mt-1" id="uploadFileName_@field.Name" style="color:#e2e8f0;"></div>
                                        </div>
                                    </div>
                                    <div id="uploadError_@field.Name" class="text-danger small mt-1 d-none">
                                        لطفاً یک فایل صوتی انتخاب کنید.
                                    </div>
                                    <input type="file" name="Files[@field.Name]"
                                           id="file_@field.Name" accept="audio/*"
                                           class="d-none"
                                           onchange="handleAudioUpload(this, '@field.Name')" />
                                }
                                else if (field.Type == FieldType.FileUpload)
                                {
                                    <div class="upload-drop-area border border-2 rounded-3 p-3 text-center"
                                         id="uploadArea_@field.Name"
                                         style="border-style:dashed!important;cursor:pointer;transition:all .2s;"
                                         onclick="document.getElementById('file_@field.Name').click()"
                                         data-required="@(field.IsRequired ? "true" : "false")"
                                         data-fieldname="@field.Name">
                                        <div id="uploadPlaceholder_@field.Name">
                                            <i class="fas fa-cloud-upload-alt fa-2x text-muted mb-2"></i>
                                            <div class="small text-muted">برای آپلود کلیک کنید یا تصویر را اینجا رها کنید</div>
                                            <div class="text-muted" style="font-size:.72rem;">JPG، PNG، WEBP — حداکثر ۱۰ مگابایت</div>
                                        </div>
                                        <div id="uploadPreview_@field.Name" class="d-none">
                                            <img id="previewImg_@field.Name" src="#" alt="پیش‌نمایش"
                                                 class="img-fluid rounded mb-2" style="max-height:200px;object-fit:contain;" />
                                            <div class="small text-muted" id="uploadFileName_@field.Name"></div>
                                        </div>
                                    </div>
                                    <div id="uploadError_@field.Name" class="text-danger small mt-1 d-none">
                                        لطفاً یک تصویر انتخاب کنید.
                                    </div>
                                    <input type="file" name="Files[@field.Name]"
                                           id="file_@field.Name" accept="image/*"
                                           class="d-none"
                                           onchange="handleFileUpload(this, '@field.Name')" />
                                }
                                else
                                {
                                    <input type="text" name="Inputs[@field.Name]" class="form-control"
                                           placeholder="@field.Placeholder" value="@savedVal"
                                           @(field.IsRequired ? "required" : "")
                                           maxlength="@(field.MaxLength ?? 500)" />
                                }

                                @if (!string.IsNullOrEmpty(field.HelpText) && field.Type != FieldType.Checkbox)
                                {
                                    <div class="form-text">@field.HelpText</div>
                                }
                            </div>
                        }

                        <div class="d-flex align-items-center justify-content-between mt-3 pt-2"
                             style="border-top:1px solid rgba(255,255,255,.06);">
                            <div class="small text-muted">
                                موجودی: <strong style="color:#e2e8f0;">@Model.UserBalance اعتبار</strong>
                                @if (Model.UserBalance < Model.App.CreditCost)
                                {
                                    <a asp-page="/Credits/Packages" class="text-danger ms-2 small">
                                        <i class="fas fa-plus me-1"></i>شارژ کنید
                                    </a>
                                }
                            </div>
                            <button type="submit" id="runBtn" class="btn btn-primary px-4"
                                    @(Model.UserBalance < Model.App.CreditCost ? "disabled" : "")>
                                <i class="fas fa-play me-2"></i>اجرا (@Model.App.CreditCost.ToFarsiDigits() اعتبار)
                            </button>
                        </div>
                    </form>
                }
            </div>

            <!-- توضیحات کامل -->
            <div class="card border-0 p-4 mb-4">
                <h5 class="fw-semibold mb-3">
                    <i class="fas fa-info-circle text-primary me-2"></i>درباره این ابزار
                </h5>
                <div style="white-space:pre-wrap;line-height:1.9;color:#a0b0cc;">@Model.App.Description</div>
            </div>

            <!-- نظرات -->
            <div class="card border-0 p-4">
                <h5 class="fw-semibold mb-3">
                    <i class="fas fa-comments text-primary me-2"></i>نظرات کاربران
                </h5>

                @if (TempData["ReviewPending"] != null)
                {
                    <div class="alert alert-info alert-dismissible fade show small mb-3">
                        <i class="fas fa-clock me-2"></i>نظر شما ثبت شد و پس از تایید نمایش داده می‌شود.
                        <button type="button" class="btn-close btn-sm" data-bs-dismiss="alert"></button>
                    </div>
                }
                @if (TempData["ReviewError"] != null)
                {
                    <div class="alert alert-danger alert-dismissible fade show small mb-3">
                        <i class="fas fa-exclamation-circle me-2"></i>@TempData["ReviewError"]
                        <button type="button" class="btn-close btn-sm" data-bs-dismiss="alert"></button>
                    </div>
                }

                @if (User.Identity.IsAuthenticated && !Model.HasReviewed)
                {
                    <form method="post" asp-page-handler="Review"
                          class="p-3 mb-4 rounded"
                          style="background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.07);">
                        <div class="mb-2">
                            <label class="form-label small">امتیاز شما</label>
                            <input type="hidden" name="rating" id="ratingValue" value="0" />
                            <div class="d-flex gap-1 align-items-center" id="starRating">
                                @for (int i = 1; i <= 5; i++)
                                {
                                    <span class="star-lbl" data-val="@i"
                                          style="cursor:pointer;font-size:1.8rem;line-height:1;transition:color .12s;">
                                        <i class="fas fa-star"></i>
                                    </span>
                                }
                            </div>
                            <div id="starError" class="text-danger small mt-1" style="display:none;">لطفاً امتیاز خود را انتخاب کنید.</div>
                        </div>
                        <textarea name="comment" class="form-control form-control-sm mb-2"
                                  rows="2" placeholder="نظر خود را بنویسید (اختیاری)"></textarea>
                        <button type="submit" class="btn btn-sm btn-outline-primary">ثبت نظر</button>
                    </form>
                }

                @foreach (var review in Model.Reviews)
                {
                    <div class="d-flex gap-3 mb-3 pb-3" style="border-bottom:1px solid rgba(255,255,255,.06);">
                        <div class="rounded-circle d-flex align-items-center justify-content-center flex-shrink-0"
                             style="width:40px;height:40px;background:rgba(249,115,22,.1);border:1px solid rgba(249,115,22,.15);">
                            <i class="fas fa-user" style="color:#f97316;font-size:.8rem;"></i>
                        </div>
                        <div class="flex-grow-1">
                            <div class="d-flex align-items-center gap-2 mb-1">
                                <strong class="small" style="color:#e2e8f0;">@review.User?.DisplayName</strong>
                                <div>
                                    @for (int i = 1; i <= 5; i++)
                                    {
                                        <i class="@(i <= review.Rating ? "fas" : "far") fa-star"
                                           style="font-size:.7rem;color:@(i <= review.Rating ? "#f59e0b" : "#2a3a5a");"></i>
                                    }
                                </div>
                                @if (review.IsVerifiedPurchase)
                                {
                                    <span class="badge bg-success-subtle border border-success-subtle" style="font-size:.65rem;">
                                        <i class="fas fa-check me-1"></i>خریدار تأیید شده
                                    </span>
                                }
                                <span style="font-size:.7rem;color:#4a5a78;">@review.CreatedAt.ToShamsi("yy/MM/dd")</span>
                            </div>
                            @if (!string.IsNullOrEmpty(review.Comment))
                            {
                                <p class="mb-0 small" style="color:#8897b0;">@review.Comment</p>
                            }
                            @if (!string.IsNullOrEmpty(review.CreatorReply))
                            {
                                <div class="mt-2 me-3 p-2 rounded border-start border-primary border-2 small"
                                     style="background:rgba(249,115,22,.06);">
                                    <span class="fw-semibold" style="color:#f97316;">پاسخ سازنده:</span>
                                    <span style="color:#8897b0;margin-right:.35rem;">@review.CreatorReply</span>
                                </div>
                            }
                        </div>
                    </div>
                }

                @if (!Model.Reviews.Any())
                {
                    <p class="small text-center py-3" style="color:#4a5a78;">هنوز نظری ثبت نشده است.</p>
                }
            </div>
        </div>

        <!-- Sidebar -->
        <div class="col-lg-4">

            <!-- سازنده -->
            <div class="card border-0 p-3 mb-3">
                <h6 class="fw-semibold mb-3" style="color:#8897b0;font-size:.8rem;text-transform:uppercase;letter-spacing:.06em;">
                    سازنده ابزار
                </h6>
                <a asp-page="/Creator/Profile"
                   asp-route-username="@Model.App.Creator.User.UserName"
                   class="d-flex align-items-center gap-3 text-decoration-none">
                    <div class="rounded-circle d-flex align-items-center justify-content-center flex-shrink-0"
                         style="width:48px;height:48px;background:rgba(249,115,22,.12);border:1.5px solid rgba(249,115,22,.2);">
                        <i class="fas fa-user" style="color:#f97316;"></i>
                    </div>
                    <div>
                        <div class="fw-semibold" style="color:#e2e8f0;">@Model.App.Creator.User.DisplayName</div>
                        <div class="d-flex gap-1 flex-wrap mt-1">
                            @if (Model.App.Creator.IsVerified)
                            {
                                <span class="badge bg-primary-subtle border border-primary-subtle" style="font-size:.65rem;">
                                    <i class="fas fa-check me-1"></i>تأیید شده
                                </span>
                            }
                            @if (Model.App.Creator.IsFoundingCreator)
                            {
                                <span class="badge bg-warning-subtle border border-warning-subtle" style="font-size:.65rem;">
                                    <i class="fas fa-star me-1"></i>بنیان‌گذار
                                </span>
                            }
                        </div>
                    </div>
                </a>
            </div>

            <!-- گالری نمونه -->
            @if (Model.App.ShowcaseItems.Any())
            {
                <div class="card border-0 p-3 mb-3">
                    <h6 class="fw-semibold mb-3" style="color:#8897b0;font-size:.8rem;text-transform:uppercase;letter-spacing:.06em;">
                        نمونه خروجی‌ها
                    </h6>
                    <div class="row g-2">
                    @foreach (var item in Model.App.ShowcaseItems.Take(6))
                    {
                        <div class="col-6 showcase-item"
                             role="button" style="cursor:pointer;"
                             data-bs-toggle="modal" data-bs-target="#showcaseModal"
                             data-caption="@(item.Caption ?? "")"
                             data-text="@(item.OutputText ?? "")"
                             data-imgurl="@(item.OutputUrl ?? "")"
                             data-type="@item.OutputType">
                            @if (item.OutputType == OutputType.Video && !string.IsNullOrEmpty(item.OutputUrl))
                            {
                                <div class="rounded overflow-hidden d-flex align-items-center justify-content-center"
                                     style="height:90px;background:#070d1a;position:relative;border:1px solid rgba(255,255,255,.07);">
                                    <video muted preload="metadata" style="width:100%;height:100%;object-fit:cover;opacity:.7;">
                                        <source src="@item.OutputUrl#t=0.1" />
                                    </video>
                                    <i class="fas fa-play-circle fa-2x text-white"
                                       style="position:absolute;filter:drop-shadow(0 1px 4px #000a);"></i>
                                    @if (!string.IsNullOrEmpty(item.Caption))
                                    {
                                        <span class="position-absolute bottom-0 start-0 end-0 px-1 pb-1"
                                              style="font-size:.6rem;color:#ffffffcc;background:linear-gradient(transparent,#000a);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">@item.Caption</span>
                                    }
                                </div>
                            }
                            else if (item.OutputType == OutputType.Audio && !string.IsNullOrEmpty(item.OutputUrl))
                            {
                                <div class="rounded d-flex flex-column align-items-center justify-content-center gap-1"
                                     style="height:90px;background:rgba(249,115,22,.06);border:1px solid rgba(249,115,22,.15);">
                                    <i class="fas fa-music fa-lg" style="color:#f97316;"></i>
                                    <span style="font-size:.65rem;color:#6b7fa0;">@(item.Caption ?? "صدا")</span>
                                </div>
                            }
                            else if (item.OutputType == OutputType.Image && !string.IsNullOrEmpty(item.OutputUrl))
                            {
                                <img src="@item.OutputUrl" class="rounded w-100"
                                     alt="@item.Caption" style="height:90px;object-fit:cover;display:block;border:1px solid rgba(255,255,255,.07);" />
                            }
                            else if (!string.IsNullOrEmpty(item.OutputText))
                            {
                                <div class="rounded p-2"
                                     style="height:90px;overflow:hidden;font-size:.7rem;line-height:1.4;color:#8897b0;background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.07);">
                                    @item.OutputText[..Math.Min(item.OutputText.Length, 120)]
                                </div>
                            }
                        </div>
                    }
                    </div>
                </div>
            }


            <!-- تگ‌ها -->
            @if (Model.App.Tags.Any())
            {
                <div class="card border-0 p-3">
                    <h6 class="fw-semibold mb-2" style="color:#8897b0;font-size:.8rem;text-transform:uppercase;letter-spacing:.06em;">
                        تگ‌ها
                    </h6>
                    @foreach (var tag in Model.App.Tags)
                    {
                        <a asp-page="/Explore" asp-route-Search="@tag.TagName"
                           class="badge text-decoration-none me-1 mb-1"
                           style="background:rgba(255,255,255,.06);color:#8897b0;border:1px solid rgba(255,255,255,.08);font-size:.8rem;">
                            #@tag.TagName
                        </a>
                    }
                </div>
            }

            <!-- پرامپت باز -->
            @if (Model.App.IsPromptPublic && !string.IsNullOrEmpty(Model.PublicPrompt))
            {
                <div class="card border-0 p-3 mt-2" style="background:rgba(99,102,241,.07);border:1px solid rgba(99,102,241,.2)!important;">
                    <div class="d-flex align-items-center gap-2 mb-2">
                        <i class="fas fa-lock-open" style="color:#818cf8;"></i>
                        <span class="fw-semibold" style="color:#a5b4fc;">پرامپت باز</span>
                        <button id="copyPromptBtn" class="btn btn-sm ms-auto"
                                style="background:rgba(99,102,241,.2);color:#a5b4fc;border:1px solid rgba(99,102,241,.3);">
                            <i class="fas fa-copy me-1"></i>کپی
                        </button>
                    </div>
                    <pre id="publicPromptText"
                         style="white-space:pre-wrap;font-family:inherit;font-size:.85rem;color:#cbd5e1;background:rgba(0,0,0,.2);border-radius:8px;padding:12px;max-height:260px;overflow-y:auto;margin:0;">@Model.PublicPrompt</pre>
                    <div class="mt-2 small" style="color:#94a3b8;">
                        <i class="fas fa-info-circle me-1"></i>اجرای این ابزار <strong style="color:#fbbf24;">@Model.App.CreditCost.ToFarsiDigits() اعتبار</strong> نیاز دارد.
                    </div>
                </div>
            }

            <!-- ابزارهای مشابه -->
            @if (Model.SimilarApps.Any())
            {
                <div class="card border-0 p-3 mt-2">
                    <h6 class="fw-semibold mb-3 d-flex align-items-center gap-2" style="color:#8897b0;font-size:.75rem;text-transform:uppercase;letter-spacing:.08em;">
                        <i class="fas fa-layer-group" style="color:#f97316;font-size:.7rem;"></i>
                        ابزارهای مشابه
                    </h6>
                    <div class="d-flex flex-column gap-2">
                        @foreach (var similar in Model.SimilarApps)
                        {
                            
                                var outIcon = similar.OutputType switch {
                                    OutputType.Image => "fa-image",
                                    OutputType.Video => "fa-video",
                                    OutputType.Audio => "fa-music",
                                    OutputType.Code  => "fa-code",
                                    _                => "fa-font"
                                };
                            
                            <a asp-page="/App/Detail" asp-route-slug="@similar.Slug"
                               class="similar-app-card text-decoration-none">
                                <div class="similar-app-thumb">
                                    @if (!string.IsNullOrEmpty(similar.ThumbnailUrl))
                                    {
                                        <img src="@similar.ThumbnailUrl" alt="@similar.Title" />
                                    }
                                    else
                                    {
                                        <div class="similar-app-thumb-placeholder">
                                            <i class="fas fa-robot"></i>
                                        </div>
                                    }
                                </div>
                                <div class="similar-app-info">
                                    <div class="similar-app-title">@similar.Title</div>
                                    <div class="similar-app-meta">
                                        <span><i class="fas @outIcon me-1"></i>@similar.OutputType</span>
                                        <span><i class="fas fa-coins me-1"></i>@similar.CreditCost.ToFarsiDigits()</span>
                                    </div>
                                </div>
                                <i class="fas fa-chevron-left similar-app-arrow"></i>
                            </a>
                        }
                    </div>
                </div>
            }

        </div>
    </div>
</div>

<!-- Modal خارج از .dp تا stacking context تداخل نداشته باشه -->
<button id="showcaseModalTrigger" type="button" class="d-none"
        data-bs-toggle="modal" data-bs-target="#showcaseModal"></button>
<div class="modal fade" id="showcaseModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h6 class="modal-title fw-semibold" id="showcaseModalTitle">نمونه خروجی</h6>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-3" id="showcaseModalBody"></div>
        </div>
    </div>
</div>

@section Styles {
    <link rel="stylesheet" href="~/css/dark-public.css" />
    <link rel="stylesheet" href="~/css/pages/public/Detail.css" />
}
@section Scripts {
    <script src="~/js/pages/public/Detail.js"></script>
}
