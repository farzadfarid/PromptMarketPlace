@page
@model FailedModel
@{
    ViewData["Title"] = "پرداخت ناموفق";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card border-0 shadow-sm text-center p-5">
                <div class="mb-4">
                    <div class="rounded-circle bg-danger bg-opacity-10 d-inline-flex align-items-center justify-content-center"
                         style="width:80px;height:80px">
                        <i class="fas fa-times-circle text-danger fa-3x"></i>
                    </div>
                </div>
                <h4 class="fw-bold mb-2">پرداخت ناموفق</h4>
                <p class="text-muted mb-4">@Model.ErrorMessage</p>
                <div class="d-flex gap-2 justify-content-center">
                    <a asp-page="/Credits/Packages" class="btn btn-primary">
                        <i class="fas fa-redo me-1"></i>تلاش مجدد
                    </a>
                    <a asp-page="/Index" class="btn btn-outline-secondary">بازگشت به خانه</a>
                </div>
            </div>
        </div>
    </div>
</div>
