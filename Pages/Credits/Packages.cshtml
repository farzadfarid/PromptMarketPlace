@page
@model PackagesModel
@{
    ViewData["Title"] = "خرید اعتبار";
}

<div class="dp container py-5">
    <div class="text-center mb-5">
        <h2 class="fw-bold mb-2">خرید اعتبار</h2>
        <p class="mb-3" style="color:#6b7fa0;">اعتبار خریداری کنید و از تمام ابزارهای هوش مصنوعی استفاده کنید</p>
        <div class="d-inline-flex align-items-center gap-2 rounded-pill px-4 py-2"
             style="background:rgba(249,115,22,.1);border:1px solid rgba(249,115,22,.2);">
            <i class="fas fa-coins text-warning"></i>
            <span style="color:#fed7aa;">موجودی فعلی شما: <strong>@Model.CurrentBalance.N0Fa() اعتبار</strong></span>
        </div>
    </div>

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger text-center">@TempData["Error"]</div>
    }

    <div class="row g-4 justify-content-center">
        @foreach (var package in Model.Packages)
        {
            <div class="col-md-6 col-lg-3">
                <div class="card h-100 border-0 position-relative
                            @(package.IsBestValue ? "best-value-card" : "")">
                    @if (package.IsBestValue)
                    {
                        <div class="position-absolute top-0 start-50 translate-middle">
                            <span class="badge bg-primary px-3 py-2 rounded-pill">بهترین انتخاب</span>
                        </div>
                    }
                    <div class="card-body text-center p-4 @(package.IsBestValue ? "pt-5" : "")">
                        <h5 class="fw-bold mb-1">@package.Name</h5>
                        <div class="my-3">
                            <span class="display-6 fw-bold text-primary">@package.CreditAmount.N0Fa()</span>
                            <span style="color:#6b7fa0;">اعتبار</span>
                        </div>
                        <div class="small mb-1" style="color:#6b7fa0;">
                            هر اعتبار ≈ @((package.PriceRial / package.CreditAmount).N0Fa()) ریال
                        </div>
                        <div class="fs-5 fw-semibold mb-4">
                            @package.PriceRial.N0Fa() <span class="small" style="color:#6b7fa0;">ریال</span>
                        </div>
                        <form method="post" asp-page-handler="Buy">
                            <input type="hidden" name="packageId" value="@package.Id" />
                            <button type="submit"
                                    class="btn w-100 @(package.IsBestValue ? "btn-primary" : "btn-outline-primary")">
                                <i class="fas fa-shopping-cart me-1"></i> خرید
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        }
    </div>

    <div class="text-center mt-5">
        <small style="color:#4a5a78;">
            <i class="fas fa-shield-alt me-1 text-success"></i>
            پرداخت امن از طریق درگاه زرین‌پال
        </small>
    </div>
</div>

@section Styles {
    <link rel="stylesheet" href="~/css/pages/public/Packages.css" />
}
