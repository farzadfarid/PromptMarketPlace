@page
@model SuccessModel
@{
    ViewData["Title"] = "پرداخت موفق";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card border-0 shadow-sm text-center p-5">
                <div class="mb-4">
                    <div class="rounded-circle bg-success bg-opacity-10 d-inline-flex align-items-center justify-content-center"
                         style="width:80px;height:80px">
                        <i class="fas fa-check-circle text-success fa-3x"></i>
                    </div>
                </div>

                @if (!string.IsNullOrEmpty(Model.InfoMessage))
                {
                    <p class="text-muted">@Model.InfoMessage</p>
                }
                else
                {
                    <h4 class="fw-bold mb-2">پرداخت با موفقیت انجام شد</h4>
                    <p class="text-muted">@Model.CreditAdded اعتبار به حساب شما افزوده شد.</p>
                    @if (!string.IsNullOrEmpty(Model.RefId))
                    {
                        <div class="bg-light rounded p-3 mb-3">
                            <small class="text-muted">کد پیگیری</small>
                            <div class="fw-bold fs-5" dir="ltr">@Model.RefId</div>
                        </div>
                    }
                }

                <div class="bg-primary bg-opacity-10 rounded p-3 mb-4">
                    <small class="text-muted">موجودی فعلی</small>
                    <div class="fw-bold fs-4 text-primary">
                        <i class="fas fa-coins me-1 text-warning"></i>@Model.NewBalance اعتبار
                    </div>
                </div>

                <div class="d-flex gap-2 justify-content-center">
                    <a asp-page="/Explore" class="btn btn-primary">
                        <i class="fas fa-th-large me-1"></i>مشاهده ابزارها
                    </a>
                    <a asp-area="User" asp-page="/Wallet/Index" class="btn btn-outline-secondary">
                        تاریخچه خرید
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
