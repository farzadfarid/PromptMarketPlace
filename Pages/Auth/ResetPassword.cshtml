@page
@model ResetPasswordModel
@{ ViewData["Title"] = "تعیین رمز عبور جدید"; }

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card border-0 shadow-sm">
                <div class="card-body p-4">
                    <h5 class="fw-bold mb-4 text-center">تعیین رمز عبور جدید</h5>

                    @if (Model.InvalidLink)
                    {
                        <div class="alert alert-danger text-center">
                            <i class="fas fa-exclamation-triangle me-2"></i>لینک بازیابی نامعتبر یا منقضی شده است.
                        </div>
                        <a asp-page="/Auth/ForgotPassword" class="btn btn-outline-primary w-100">درخواست مجدد</a>
                    }
                    else if (Model.Success)
                    {
                        <div class="alert alert-success text-center">
                            <i class="fas fa-check-circle me-2"></i>رمز عبور با موفقیت تغییر یافت.
                        </div>
                        <a asp-page="/Auth/Login" class="btn btn-primary w-100">ورود به حساب</a>
                    }
                    else
                    {
                        <form method="post">
                            <input type="hidden" asp-for="Email" />
                            <input type="hidden" asp-for="Token" />

                            @if (!ViewData.ModelState.IsValid)
                            {
                                <div class="alert alert-danger small">
                                    <div asp-validation-summary="All"></div>
                                </div>
                            }

                            <div class="mb-3">
                                <label class="form-label fw-semibold">رمز عبور جدید</label>
                                <input asp-for="NewPassword" type="password" class="form-control"
                                       dir="ltr" autocomplete="new-password" />
                                <span asp-validation-for="NewPassword" class="text-danger small"></span>
                            </div>
                            <div class="mb-4">
                                <label class="form-label fw-semibold">تکرار رمز عبور جدید</label>
                                <input asp-for="ConfirmPassword" type="password" class="form-control"
                                       dir="ltr" autocomplete="new-password" />
                                <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                            </div>
                            <button type="submit" class="btn btn-primary w-100 fw-semibold">ذخیره رمز عبور</button>
                        </form>
                        <div class="text-center mt-3 small">
                            <a asp-page="/Auth/Login">بازگشت به ورود</a>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
