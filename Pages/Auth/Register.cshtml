@page
@model RegisterModel
@{ ViewData["Title"] = "ثبت‌نام"; }

<div class="auth-page dp">
    <div class="container py-5">
        <div class="row justify-content-center">
            <div class="col-md-6 col-lg-5">

                <div class="auth-card">
                    <div class="text-center mb-4">
                        <img src="~/images/logo.png" alt="Prompt Market Place" class="auth-logo mb-3" />
                        <h5 class="auth-title">ثبت‌نام در پرامپت مارکت</h5>
                        <p class="auth-subtitle">به دنیای هوش مصنوعی بپیوند</p>
                    </div>

                    <form method="post">
                        @if (!ViewData.ModelState.IsValid)
                        {
                            <div asp-validation-summary="All" class="auth-alert-danger small py-2 px-3 rounded-2 mb-3"></div>
                        }

                        <div class="mb-3">
                            <label class="auth-label">نام نمایشی</label>
                            <input asp-for="Form.DisplayName" class="form-control auth-input"
                                   placeholder="چه اسمی روی پروفایلت نشون داده بشه؟" />
                            <span asp-validation-for="Form.DisplayName" class="text-danger small"></span>
                        </div>
                        <div class="mb-3">
                            <label class="auth-label">ایمیل</label>
                            <input asp-for="Form.Email" class="form-control auth-input" dir="ltr" placeholder="example@email.com" />
                            <span asp-validation-for="Form.Email" class="text-danger small"></span>
                        </div>
                        <div class="mb-3">
                            <label class="auth-label">رمز عبور</label>
                            <input asp-for="Form.Password" class="form-control auth-input" dir="ltr" placeholder="••••••••" />
                            <span asp-validation-for="Form.Password" class="text-danger small"></span>
                        </div>
                        <div class="mb-4">
                            <label class="auth-label">تکرار رمز عبور</label>
                            <input asp-for="Form.ConfirmPassword" class="form-control auth-input" dir="ltr" placeholder="••••••••" />
                            <span asp-validation-for="Form.ConfirmPassword" class="text-danger small"></span>
                        </div>

                        <div class="auth-creator-card mb-4">
                            <div class="form-check mb-0">
                                <input asp-for="Form.WantToBeCreator" class="form-check-input auth-check" type="checkbox" />
                                <label class="form-check-label auth-creator-label" asp-for="Form.WantToBeCreator">
                                    می‌خواهم سازنده باشم
                                </label>
                                <div class="auth-creator-hint">
                                    ابزارهای AI بساز و از هر استفاده درآمد کسب کن
                                </div>
                            </div>
                        </div>

                        <div class="mb-4">
                            <label class="auth-label">کد امنیتی</label>
                            <div class="d-flex align-items-center gap-2 mb-2">
                                <img src="/Auth/CaptchaImage" id="captchaImg"
                                     alt="کد امنیتی" class="auth-captcha-img" />
                                <button type="button" class="btn auth-btn-outline-sm" onclick="refreshCaptcha()" title="کد جدید">
                                    <i class="fas fa-redo-alt"></i>
                                </button>
                            </div>
                            <input asp-for="Form.CaptchaInput" class="form-control auth-input" dir="rtl"
                                   placeholder="کد بالا را وارد کنید" autocomplete="off" maxlength="5" />
                            <span asp-validation-for="Form.CaptchaInput" class="text-danger small"></span>
                        </div>

                        <button type="submit" class="btn btn-primary w-100 auth-submit">ثبت‌نام</button>
                    </form>

                    <div class="auth-divider">
                        <span>یا</span>
                    </div>
                    <div class="text-center">
                        <span class="auth-footer-text">حساب دارید؟</span>
                        <a asp-page="/Auth/Login" class="auth-link">وارد شوید</a>
                    </div>
                </div>

            </div>
        </div>
    </div>
</div>

@section Styles {
    <link rel="stylesheet" href="~/css/dark-public.css" />
    <style>
    .auth-page { min-height: 80vh; }

    .auth-card {
        background: #131929;
        border: 1px solid rgba(255,255,255,.08);
        border-radius: 18px;
        padding: 2rem;
        box-shadow: 0 8px 40px rgba(0,0,0,.4);
    }

    .auth-logo {
        height: 90px;
        width: auto;
        border-radius: 14px;
        display: block;
        margin: 0 auto;
    }

    .auth-title { color: #e2e8f0; font-weight: 700; margin-bottom: .25rem; }
    .auth-subtitle { color: #6b7fa0; font-size: .85rem; margin-bottom: 0; }

    .auth-label {
        display: block;
        color: #94a3b8;
        font-size: .85rem;
        font-weight: 500;
        margin-bottom: .4rem;
    }

    .auth-input {
        background: #0d1525 !important;
        background-color: #0d1525 !important;
        border: 1px solid rgba(255,255,255,.1) !important;
        color: #e2e8f0 !important;
        border-radius: 10px !important;
    }
    .auth-input:focus {
        background: #0d1525 !important;
        background-color: #0d1525 !important;
        border-color: rgba(99,102,241,.6) !important;
        box-shadow: 0 0 0 3px rgba(99,102,241,.12) !important;
        color: #e2e8f0 !important;
    }
    .auth-input::placeholder { color: #3d5070 !important; }

    .auth-check {
        background-color: #0d1525 !important;
        border-color: rgba(255,255,255,.2) !important;
    }
    .auth-check:checked {
        background-color: #6366f1 !important;
        border-color: #6366f1 !important;
    }
    .auth-check-label { color: #94a3b8; font-size: .85rem; }

    .auth-creator-card {
        background: rgba(249,115,22,.07);
        border: 1px solid rgba(249,115,22,.2);
        border-radius: 12px;
        padding: .9rem 1rem;
    }
    .auth-creator-label {
        color: #fed7aa;
        font-weight: 600;
        font-size: .9rem;
        cursor: pointer;
    }
    .auth-creator-hint { color: #9a7560; font-size: .8rem; margin-top: .2rem; }

    .auth-captcha-img {
        height: 50px;
        border-radius: 8px;
        border: 1px solid rgba(255,255,255,.12);
    }

    .auth-btn-outline-sm {
        background: rgba(255,255,255,.05);
        border: 1px solid rgba(255,255,255,.12);
        color: #94a3b8;
        border-radius: 8px;
        padding: .35rem .7rem;
        font-size: .85rem;
        transition: all .15s;
    }
    .auth-btn-outline-sm:hover { background: rgba(255,255,255,.1); color: #e2e8f0; }

    .auth-submit {
        border-radius: 10px !important;
        padding: .65rem !important;
        font-weight: 600 !important;
        font-size: .95rem !important;
    }

    .auth-divider {
        display: flex; align-items: center; gap: .75rem;
        margin: 1.5rem 0;
        color: #3d5070; font-size: .8rem;
    }
    .auth-divider::before, .auth-divider::after {
        content: '';
        flex: 1;
        height: 1px;
        background: rgba(255,255,255,.08);
    }

    .auth-footer-text { color: #6b7fa0; font-size: .88rem; }
    .auth-link { color: #818cf8; font-size: .88rem; text-decoration: none; margin-right: .3rem; }
    .auth-link:hover { color: #a5b4fc; text-decoration: underline; }

    .auth-alert-danger {
        background: rgba(239,68,68,.12);
        border: 1px solid rgba(239,68,68,.25);
        color: #fca5a5;
    }
    .auth-alert-danger:empty { display: none; }
    .validation-summary-valid { display: none !important; }
    </style>
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function refreshCaptcha() {
            document.getElementById('captchaImg').src = '/Auth/CaptchaImage?t=' + Date.now();
        }
    </script>
}
