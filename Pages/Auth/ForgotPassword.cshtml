@page
@model ForgotPasswordModel
@{ ViewData["Title"] = "فراموشی رمز"; }

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card border-0 shadow-sm">
                <div class="card-body p-4">
                    <h5 class="fw-bold mb-4 text-center">بازیابی رمز عبور</h5>
                    @if (Model.Submitted)
                    {
                        <div class="alert alert-success">
                            اگر ایمیل در سیستم موجود باشد، لینک بازیابی ارسال می‌شود.
                        </div>
                        <a asp-page="/Auth/Login" class="btn btn-outline-primary w-100">بازگشت به ورود</a>
                    }
                    else
                    {
                        <form method="post">
                            <div class="mb-3">
                                <label class="form-label">ایمیل</label>
                                <input asp-for="Email" class="form-control" dir="ltr" />
                                <span asp-validation-for="Email" class="text-danger small"></span>
                            </div>
                            <button type="submit" class="btn btn-primary w-100">ارسال لینک بازیابی</button>
                        </form>
                        <div class="text-center mt-3 small">
                            <a asp-page="/Auth/Login">بازگشت به ورود</a>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
